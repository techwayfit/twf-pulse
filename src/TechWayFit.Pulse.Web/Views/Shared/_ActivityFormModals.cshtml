                    <div class="mb-3">
                        <label class="form-label fw-medium">Break Message</label>
                        <textarea class="form-control" id="breakMessage" rows="2" placeholder="e.g., Take a short break. Grab a coffee and relax!"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Break Duration (minutes)</label>
                        <input type="number" class="form-control" id="breakDurationMinutes" value="15" min="1" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="breakShowCountdown" checked />
                            <label class="form-check-label" for="breakShowCountdown">Show countdown timer to participants</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="breakAllowReadySignal" checked />
                            <label class="form-check-label" for="breakAllowReadySignal">Allow participants to signal when they are back</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="window.saveBreakActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>