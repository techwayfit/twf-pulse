<!-- Quadrant Item Scoring Activity Modal -->
<div class="modal fade" id="quadrantModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ics ics-chart-increasing ic-sm ic-mr"></i>Create Item Scoring Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body modal-body-scroll">
                <form id="quadrantForm">
                    <!-- Basic info -->
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label class="form-label fw-medium">Activity Title *</label>
                            <input type="text" class="form-control" id="quadrantTitle" required placeholder="e.g., Prioritise Tech Debt Items" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="quadrantDuration" value="10" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Instructions / Prompt</label>
                        <textarea class="form-control" id="quadrantPrompt" rows="2" placeholder="e.g., Score each item on how complex and how much effort it requires"></textarea>
                    </div>

                    <!-- Axis labels -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">X-Axis Label</label>
                            <input type="text" class="form-control" id="quadrantXAxis" value="Complexity" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Y-Axis Label</label>
                            <input type="text" class="form-control" id="quadrantYAxis" value="Effort" />
                        </div>
                    </div>

                    <!-- X Score options -->
                    <div class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label fw-medium mb-0">X-Axis Score Options *</label>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','1-10')">1–10</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','1-5')">1–5</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','fibonacci')">Fibonacci</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','odd')">Odd</button>
                            </div>
                        </div>
                        <small class="text-muted d-block mb-2">Value is used for averaging. Label &amp; Description are shown to participants in the dropdown.</small>
                        <table class="table table-sm mb-1">
                            <thead><tr><th style="width:20%">Value *</th><th style="width:25%">Label</th><th>Description (optional)</th><th style="width:40px"></th></tr></thead>
                            <tbody id="quadrantXScoreBody"></tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="window.quadrantModal_addRow('x')"><i class="fas fa-plus me-1"></i>Add Option</button>
                    </div>

                    <!-- Y shares X toggle -->
                    <div class="mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="quadrantYSharesX" checked onchange="window.quadrantModal_toggleYPanel(this.checked)" />
                            <label class="form-check-label" for="quadrantYSharesX">Y-axis uses the same score options as X-axis</label>
                        </div>
                    </div>

                    <!-- Y Score options (hidden by default) -->
                    <div id="quadrantYScorePanel" style="display:none" class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label fw-medium mb-0">Y-Axis Score Options *</label>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','1-10')">1–10</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','1-5')">1–5</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','fibonacci')">Fibonacci</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','odd')">Odd</button>
                            </div>
                        </div>
                        <table class="table table-sm mb-1">
                            <thead><tr><th style="width:20%">Value *</th><th style="width:25%">Label</th><th>Description (optional)</th><th style="width:40px"></th></tr></thead>
                            <tbody id="quadrantYScoreBody"></tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="window.quadrantModal_addRow('y')"><i class="fas fa-plus me-1"></i>Add Option</button>
                    </div>

                    <!-- Items -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-medium mb-0">Items to Score * <span class="text-muted fw-normal">(one per line, max 200)</span></label>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('quadrantCsvUpload').click()">
                                <i class="fas fa-file-import me-1"></i>Import CSV
                            </button>
                        </div>
                        <input type="file" id="quadrantCsvUpload" accept=".csv,.tsv,.txt" class="d-none" />
                        <div id="quadrantCsvColPicker" class="card card-body py-2 mb-2 d-none">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="text-muted small"><i class="fas fa-table-columns me-1"></i>Multiple columns detected. Pick the column to import:</span>
                                <select id="quadrantCsvColSelect" class="form-select form-select-sm" style="width:auto;max-width:220px;"></select>
                                <button type="button" class="btn btn-sm btn-primary" data-csv-apply>Apply</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-csv-cancel>Cancel</button>
                            </div>
                        </div>
                        <textarea class="form-control font-monospace" id="quadrantItems" rows="8" placeholder="Deploy frequency&#10;Incident response time&#10;Code review turnaround&#10;..."></textarea>
                    </div>

                    <!-- Chart options -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Bubble Size</label>
                            <select class="form-select" id="quadrantBubbleSize">
                                <option value="0">Proportional to response count</option>
                                <option value="1">Uniform (same size for all)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="quadrantAllowNotes" />
                                <label class="form-check-label" for="quadrantAllowNotes">Allow participants to add a note per item</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="window.saveQuadrantActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>
<script>
(function() {
    const modalEl = document.getElementById('quadrantModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            if (!document.getElementById('quadrantXScoreBody').hasChildNodes()) {
                window.quadrantModal_renderScoreTable('x', QuadrantActivity.defaultNumeric(1, 10));
                window.quadrantModal_toggleYPanel(true);
            }
            CsvHelper.wireTextareaPaste('quadrantItems');
            CsvHelper.bindFileUpload({
                fileInputId: 'quadrantCsvUpload',
                textareaId: 'quadrantItems',
                columnPickerId: 'quadrantCsvColPicker',
                columnSelectId: 'quadrantCsvColSelect',
                maxRows: 200
            });
        });
    }
})();
</script>

