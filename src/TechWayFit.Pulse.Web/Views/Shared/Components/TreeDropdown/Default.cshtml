@using TechWayFit.Pulse.Web.ViewComponents.TreeDropdown
@model TechWayFit.Pulse.Web.ViewComponents.TreeDropdown.TreeDropdownViewModel

<div class="dropdown tree-dropdown @Model.CssClass" data-dropdown-id="@Model.Id">
    <input type="hidden" name="@Model.Name" id="@Model.Id" value="@Model.Value" />
    
    <button class="btn btn-outline-secondary dropdown-toggle w-100 d-flex justify-content-between align-items-center" 
            type="button" 
            id="dropdown-@Model.Id" 
            data-bs-toggle="dropdown" 
            data-bs-auto-close="outside"
            aria-expanded="false">
        <span class="dropdown-text">@(string.IsNullOrEmpty(Model.Value) ? Model.Placeholder : GetSelectedText(Model.Items, Model.Value))</span>
    </button>
    
    <div class="dropdown-menu" aria-labelledby="dropdown-@Model.Id">
        @if (Model.AllowClear)
        {
            <div class="dropdown-item tree-item" data-value="" data-level="0">
                <span class="tree-item-text">All Groups</span>
            </div>
        }
        
        @foreach (var item in Model.Items.Where(i => i.ParentValue == null).OrderBy(i => i.Text))
        {
            @await Html.PartialAsync("_TreeDropdownItem", item, new ViewDataDictionary(ViewData) 
            { 
                ["AllItems"] = Model.Items,
                ["SelectedValue"] = Model.Value 
            })
        }
    </div>
</div>

@{
    string GetSelectedText(IEnumerable<TreeDropdownItem> items, string value)
    {
        if (string.IsNullOrEmpty(value)) return Model.Placeholder;
        
        var item = items.FirstOrDefault(i => i.Value == value);
        if (item == null) return Model.Placeholder;
        
        var path = new List<string>();
        var current = item;
        
        while (current != null)
        {
            path.Insert(0, current.Text);
            current = items.FirstOrDefault(i => i.Value == current.ParentValue);
        }
        
        return string.Join(" → ", path);
    }
}

<script>
    (function() {
        const dropdownElement = document.querySelector('[data-dropdown-id="@Model.Id"]');
  if (!dropdownElement) return;
        
      // Render tree icons using IconHelper when dropdown is shown
        if (window.IconHelper) {
const renderIcons = function() {
 const iconElements = dropdownElement.querySelectorAll('.tree-icon-display[data-icon]');
 iconElements.forEach(element => {
       const iconValue = element.getAttribute('data-icon');
            if (iconValue && !element.querySelector('i')) {
         element.innerHTML = IconHelper.toFontAwesome(iconValue);
            }
  });
       };
       
   // Render icons on load
            renderIcons();
         
            // Re-render when dropdown is shown (in case new items are added dynamically)
  const dropdownButton = dropdownElement.querySelector('.dropdown-toggle');
            if (dropdownButton) {
       dropdownButton.addEventListener('shown.bs.dropdown', renderIcons);
            }
        }
        
     // Handle tree toggle clicks
        dropdownElement.addEventListener('click', function(e) {
            const toggle = e.target.closest('.tree-toggle');
   if (toggle) {
      e.preventDefault();
         e.stopPropagation();
         
         const targetId = toggle.getAttribute('data-target');
       const target = document.getElementById(targetId);
      const icon = toggle.querySelector('i');
     
  if (target && icon) {
              target.classList.toggle('show');
          if (target.classList.contains('show')) {
                 icon.className = 'fas fa-chevron-down';
  } else {
      icon.className = 'fas fa-chevron-right';
             }
         }
          }
        });
  
        // Handle tree item selection (but not when clicking toggle)
        dropdownElement.addEventListener('click', function(e) {
            if (e.target.closest('.tree-toggle')) return;
            
        const treeItem = e.target.closest('.tree-item');
            if (treeItem) {
              const value = treeItem.getAttribute('data-value');
        const text = treeItem.querySelector('.tree-item-text').textContent;
       const hiddenInput = dropdownElement.querySelector('input[type="hidden"]');
        const dropdownText = dropdownElement.querySelector('.dropdown-text');
    
       // Update value
         hiddenInput.value = value;
                dropdownText.textContent = value ? text : '@Model.Placeholder';
        
      // Remove selected class from all items
      dropdownElement.querySelectorAll('.tree-item').forEach(item => {
item.classList.remove('selected');
  });
     
      // Add selected class to clicked item
              if (value) {
          treeItem.classList.add('selected');
    }
            
    // Close dropdown
    const dropdownButton = dropdownElement.querySelector('[data-bs-toggle="dropdown"]');
    if (dropdownButton) {
const bsDropdown = bootstrap.Dropdown.getInstance(dropdownButton);
    if (bsDropdown) {
    bsDropdown.hide();
        }
         }
      
     e.preventDefault();
    e.stopPropagation();
            }
     });
    })();
</script>
