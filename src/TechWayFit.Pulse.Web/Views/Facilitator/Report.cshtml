@model TechWayFit.Pulse.Web.Models.SessionReportViewModel
@using Markdig

@{
    ViewData["Title"] = $"Session Report - {Model.SessionCode}";
}

<div class="container container-wide session-report-page py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4 report-no-print">
        <div>
            <h2 class="mb-1">Session Report</h2>
            <p class="text-muted mb-0">Code: <span class="badge bg-primary">@Model.SessionCode</span></p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="@Url.Action("Dashboard", "Facilitator")">Back to Dashboard</a>
            <button type="button" class="btn btn-primary" id="downloadPdfBtn">Download PDF</button>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-8">
                    <h4 class="mb-1">@Model.SessionTitle</h4>
                    <p class="text-muted mb-2">Status: <strong>@Model.Status</strong></p>
                    @if (!string.IsNullOrWhiteSpace(Model.Goal))
                    {
                        <p class="mb-2"><strong>Goal:</strong> @Model.Goal</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Context))
                    {
                        <p class="mb-0"><strong>Context:</strong> @Model.Context</p>
                    }
                </div>
                <div class="col-lg-4">
                    <div class="small text-muted">Generated @Model.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="small mt-2"><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="small"><strong>Last Updated:</strong> @Model.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="small"><strong>Planned Start:</strong> @(Model.PlannedStart?.ToString("yyyy-MM-dd HH:mm") ?? "Not set")</div>
                    <div class="small"><strong>Planned End:</strong> @(Model.PlannedEnd?.ToString("yyyy-MM-dd HH:mm") ?? "Not set")</div>
                </div>
            </div>

            <hr />

            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="h4 mb-0">@Model.ParticipantCount</div>
                        <small class="text-muted">Participants</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="h4 mb-0">@Model.Activities.Count</div>
                        <small class="text-muted">Activities</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="h4 mb-0">@Model.TotalResponses</div>
                        <small class="text-muted">Total Responses</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="h4 mb-0">@Model.Activities.Sum(x => x.ResponseCount)</div>
                        <small class="text-muted">Recorded Entries</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Participant Details</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Participants.Count == 0)
            {
                <div class="p-4 text-muted">No participants found for this session.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Participant</th>
                                <th>Joined At</th>
                                @foreach (var column in Model.ParticipantColumns)
                                {
                                    <th>@column.Label</th>
                                }
                                <th>Responses</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var participant in Model.Participants.OrderBy(p => p.JoinedAt))
                            {
                                <tr>
                                    <td>@participant.DisplayName</td>
                                    <td>@participant.JoinedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    @foreach (var column in Model.ParticipantColumns)
                                    {
                                        <td>@(participant.Dimensions.TryGetValue(column.Id, out var value) ? value : "-")</td>
                                    }
                                    <td>@participant.ResponseCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @foreach (var activity in Model.Activities.OrderBy(a => a.Order))
    {
        <div class="card shadow-sm mb-4 report-activity-block">
            <div class="card-header bg-white">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-0">#@activity.Order @activity.Title</h5>
                        <small class="text-muted">@activity.Type @if (!string.IsNullOrWhiteSpace(activity.Prompt)) { <text>• @activity.Prompt</text> }</small>
                    </div>
                    <div class="small text-muted">
                        Responses: <strong>@activity.ResponseCount</strong>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-4"><small class="text-muted">Opened</small><div>@(activity.OpenedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div></div>
                    <div class="col-md-4"><small class="text-muted">Closed</small><div>@(activity.ClosedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div></div>
                    <div class="col-md-4"><small class="text-muted">Duration</small><div>@(activity.DurationMinutes.HasValue ? $"{activity.DurationMinutes} min" : "-")</div></div>
                </div>

                <h6 class="mb-2">Responses</h6>
                @if (activity.Responses.Count == 0)
                {
                    <div class="text-muted">No responses recorded.</div>
                }
                else
                {
                    var isQuadrant = string.Equals(activity.Type, "Quadrant", StringComparison.OrdinalIgnoreCase);
                    var isAiSummary = string.Equals(activity.Type, "AiSummary", StringComparison.OrdinalIgnoreCase);
                    var xAxisLabel = string.IsNullOrWhiteSpace(activity.QuadrantXAxisLabel) ? "X Axis" : activity.QuadrantXAxisLabel;
                    var yAxisLabel = string.IsNullOrWhiteSpace(activity.QuadrantYAxisLabel) ? "Y Axis" : activity.QuadrantYAxisLabel;

                    @if (isAiSummary)
                    {
                        var summaryItem = activity.Responses.OrderBy(r => r.CreatedAt).LastOrDefault();
                        if (summaryItem is null || string.IsNullOrWhiteSpace(summaryItem.Summary))
                        {
                            <div class="text-muted">No AI summary generated.</div>
                        }
                        else
                        {
                            <div class="report-ai-summary-block">
                                <div class="report-ai-summary-meta">
                                    <span>@summaryItem.ParticipantName</span>
                                    <span>@summaryItem.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                                <div class="report-ai-summary-content">
                                    @Html.Raw(RenderMarkdownAsHtml(summaryItem.Summary))
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        var isQnA = string.Equals(activity.Type, "QnA", StringComparison.OrdinalIgnoreCase);
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0 @(isQuadrant ? "report-table-quadrant" : "")">
                                @if (isQuadrant)
                                {
                                    <colgroup>
                                        <col class="report-col-idx" />
                                        <col class="report-col-question" />
                                        <col class="report-col-participant" />
                                        <col class="report-col-axis" />
                                        <col class="report-col-axis" />
                                        <col class="report-col-submitted" />
                                    </colgroup>
                                }
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        @if (isQuadrant)
                                        {
                                            <th>Question</th>
                                        }
                                        else if (isQnA)
                                        {
                                            <th>Text</th>
                                            <th>Upvotes</th>
                                        }
                                        else
                                        {
                                            <th>Participant</th>
                                            <th>Response</th>
                                        }
                                        @if (isQuadrant)
                                        {
                                            <th>@xAxisLabel</th>
                                            <th>@yAxisLabel</th>
                                        }
                                        <th>Submitted At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var responseIndex = 0;
                                    }
                                    @foreach (var response in activity.Responses)
                                    {
                                        responseIndex++;
                                        <tr>
                                            <td>@responseIndex</td>
                                            @if (isQuadrant)
                                            {
                                                <td class="report-question-cell"
                                                    title="@(string.IsNullOrWhiteSpace(response.Question) ? "-" : response.Question)">
                                                    @TruncateReportText(response.Question, 150)
                                                </td>
                                                <td>@response.ParticipantName</td>
                                                <td>@(string.IsNullOrWhiteSpace(response.XAxisValue) ? "-" : response.XAxisValue)</td>
                                                <td>@(string.IsNullOrWhiteSpace(response.YAxisValue) ? "-" : response.YAxisValue)</td>
                                            }
                                            else if (isQnA)
                                            {
                                                <td class="report-qna-text-cell">@response.Summary</td>
                                                <td>@(response.UpvoteCount ?? 0)</td>
                                            }
                                            else
                                            {
                                                <td>@response.ParticipantName</td>
                                                <td>@response.Summary</td>
                                            }
                                            <td>@response.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const downloadBtn = document.getElementById('downloadPdfBtn');
            if (downloadBtn) {
                downloadBtn.addEventListener('click', function () {
                    window.print();
                });
            }
        })();
    </script>
}

@functions {
    private static string TruncateReportText(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= maxLength
            ? value
            : $"{value[..maxLength].TrimEnd()}...";
    }

    private static string RenderMarkdownAsHtml(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "<p class=\"text-muted mb-0\">No AI summary generated.</p>";
        }

        var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
        return Markdown.ToHtml(value, pipeline);
    }
}

<style>
    .report-ai-summary-block {
        border: 1px solid #d7e4e8;
        border-radius: 12px;
        background: #f8fbfc;
        padding: 1rem 1.1rem;
    }

    .report-ai-summary-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        color: #6c7f85;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
    }

    .report-ai-summary-content {
        color: #1f2d33;
    }

    .report-ai-summary-content > :last-child {
        margin-bottom: 0;
    }

    .report-table-quadrant {
        table-layout: fixed;
        width: 100%;
    }

    .report-table-quadrant .report-col-idx {
        width: 52px;
    }

    .report-table-quadrant .report-col-question {
        width: 340px;
    }

    .report-table-quadrant .report-col-participant {
        width: 180px;
    }

    .report-table-quadrant .report-col-axis {
        width: 130px;
    }

    .report-table-quadrant .report-col-submitted {
        width: 190px;
    }

    .report-table-quadrant .report-question-cell {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .report-qna-text-cell {
        white-space: normal;
        word-break: break-word;
    }

    @@media print {
        .report-no-print,
        .navbar,
        .footer-dark {
            display: none !important;
        }

        .session-report-page {
            max-width: 100% !important;
        }

        .report-activity-block {
            page-break-inside: avoid;
        }
    }
</style>
