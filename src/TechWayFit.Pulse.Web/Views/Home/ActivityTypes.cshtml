@{
    ViewData["Title"] = "Activity Types — TechWayFit Pulse";
}

<main class="py-5">
    <div class="container">
        <!-- Header -->
        <div class="mb-5">
            <h1 class="display-5 fw-bold mb-3">Activity Types</h1>
            <p class="lead text-muted">Choose from 10 interactive and utility activities to engage your workshop participants</p>
        </div>

        <!-- Activity Types Grid -->
        <div class="mb-4">
            <h2 class="h4 fw-semibold mb-3">Interactive Activities</h2>
            <p class="text-muted mb-4">Collect real-time responses and feedback from participants</p>
        </div>

        <!-- Polls -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-poll fs-2 text-primary"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">Polls</h2>
                        <p class="text-muted mb-0">Single or multiple choice voting with real-time results</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Quick consensus gathering and decision making</li>
                    <li>Team preferences and priority voting</li>
                    <li>Anonymous opinions on sensitive topics</li>
                    <li>Gauging group sentiment or understanding</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Single or Multiple Choice</strong>
                                <small class="text-muted">Allow one or many selections per participant</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Real-Time Bar Charts</strong>
                                <small class="text-muted">Live vote counts and percentages</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Custom Option Descriptions</strong>
                                <small class="text-muted">Add context to each choice</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Export Results</strong>
                                <small class="text-muted">Download vote data for analysis</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-user me-2"></i><strong>Participant View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="small text-muted mb-2">Select your choice:</div>
                                <div class="border rounded p-2 mb-1 bg-primary bg-opacity-10 border-primary">✓ Option A</div>
                                <div class="border rounded p-2 mb-1">Option B</div>
                                <div class="border rounded p-2 mb-1">Option C</div>
                                <button class="btn btn-sm btn-primary w-100 mt-2">Submit Response</button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-chalkboard-teacher me-2"></i><strong>Facilitator View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="small fw-semibold mb-2">Results (12 votes)</div>
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between align-items-center small mb-1">
                                        <span>Option A</span><span class="text-primary fw-semibold">58.3%</span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar" style="width: 58.3%"></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between align-items-center small mb-1">
                                        <span>Option B</span><span class="text-muted">25.0%</span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-secondary" style="width: 25%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Word Clouds -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-cloud fs-2 text-info"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">Word Clouds</h2>
                        <p class="text-muted mb-0">Collect and visualize keywords or short phrases</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Brainstorming sessions and idea generation</li>
                    <li>Identifying common themes across responses</li>
                    <li>Quick feedback rounds ("What's one word to describe...")</li>
                    <li>Energizing workshops with visual impact</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Dynamic Visualization</strong>
                                <small class="text-muted">Words scale by frequency automatically</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Live Updates</strong>
                                <small class="text-muted">Cloud grows as participants submit</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Multi-Word Support</strong>
                                <small class="text-muted">Configure max words per submission (1-10)</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Multiple Submissions</strong>
                                <small class="text-muted">Optional: allow participants to submit more than once</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-user me-2"></i><strong>Participant View:</strong></div>
                            <div class="border rounded p-3 bg-white">
                                <div class="small text-muted mb-2">Enter up to 3 words:</div>
                                <input type="text" class="form-control form-control-sm mb-2" placeholder="innovation" disabled />
                                <button class="btn btn-sm btn-primary w-100">Submit Words</button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-chalkboard-teacher me-2"></i><strong>Facilitator View:</strong></div>
                            <div class="border rounded p-3 bg-gradient" style="background: linear-gradient(135deg, #f8f9fa 0%, #e0f2fe 100%);">
                                <div class="text-center">
                                    <span class="badge bg-primary me-1" style="font-size: 1.4em;">Innovation</span>
                                    <span class="badge bg-success" style="font-size: 1.1em;">Collaboration</span>
                                    <span class="badge bg-info me-1" style="font-size: 0.9em;">Agile</span>
                                    <span class="badge bg-warning" style="font-size: 0.8em;">Speed</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quadrant Matrix -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-chart-scatter fs-2 text-success"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">Quadrant Matrix (Item Scoring)</h2>
                        <p class="text-muted mb-0">Score items on two dimensions with bubble chart visualization</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Priority mapping (e.g., Impact vs Effort analysis)</li>
                    <li>Risk vs. Reward assessment</li>
                    <li>Complexity vs. Business Value evaluation</li>
                    <li>Any 2-dimensional item evaluation</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Custom Axis Labels</strong>
                                <small class="text-muted">Define your own scoring dimensions</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Flexible Scoring Options</strong>
                                <small class="text-muted">Use numeric (1-10), Fibonacci, or custom scales</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Bubble Chart Visualization</strong>
                                <small class="text-muted">See aggregated positions with size by response count</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">CSV Import</strong>
                                <small class="text-muted">Bulk import up to 200 items</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Optional Notes</strong>
                                <small class="text-muted">Let participants add context to their scores</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Dropdown Selection</strong>
                                <small class="text-muted">Easy-to-use dropdowns for both axes</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-user me-2"></i><strong>Participant View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="small fw-semibold mb-2">Score: Deploy Automation</div>
                                <div class="mb-2">
                                    <label class="form-label small mb-1">Complexity</label>
                                    <select class="form-select form-select-sm">
                                        <option>Select score...</option>
                                        <option selected>8 - High</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small mb-1">Effort</label>
                                    <select class="form-select form-select-sm">
                                        <option selected>5 - Medium</option>
                                    </select>
                                </div>
                                <button class="btn btn-sm btn-success w-100">Submit Score</button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-chalkboard-teacher me-2"></i><strong>Facilitator View:</strong></div>
                            <div class="border rounded p-2 bg-white position-relative" style="height: 180px;">
                                <div class="position-absolute" style="top: 10px; right: 10px; font-size: 0.65rem; color: #94a3b8;">High Effort</div>
                                <div class="position-absolute" style="bottom: 10px; right: 10px; font-size: 0.65rem; color: #94a3b8;">High Complexity →</div>
                                <svg width="100%" height="100%">
                                    <line x1="50%" y1="0" x2="50%" y2="100%" stroke="#e5e7eb" stroke-width="1" />
                                    <line x1="0" y1="50%" x2="100%" y2="50%" stroke="#e5e7eb" stroke-width="1" />
                                    <circle cx="70%" cy="35%" r="16" fill="#3b82f6" opacity="0.6" />
                                    <circle cx="35%" cy="65%" r="12" fill="#10b981" opacity="0.6" />
                                    <circle cx="60%" cy="60%" r="20" fill="#f59e0b" opacity="0.6" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Q&A -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-lightbulb fs-2 text-warning"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">Q&A (Questions & Answers)</h2>
                        <p class="text-muted mb-0">Live question submission with upvoting and facilitator responses</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Open Q&A sessions and panel discussions</li>
                    <li>Collecting questions during presentations</li>
                    <li>Prioritizing which questions to answer first</li>
                    <li>Capturing anonymous concerns or inquiries</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Upvoting System</strong>
                                <small class="text-muted">Participants upvote most important questions</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Anonymous Submissions</strong>
                                <small class="text-muted">Optional anonymous mode for sensitive topics</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Mark as Answered</strong>
                                <small class="text-muted">Facilitator can track which questions are addressed</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Question Limits</strong>
                                <small class="text-muted">Control max questions per participant</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-user me-2"></i><strong>Participant View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <textarea class="form-control form-control-sm mb-2" rows="2" placeholder="Type your question here..." disabled></textarea>
                                <div class="form-check form-check-sm mb-2">
                                    <input class="form-check-input" type="checkbox" id="anonCheck" />
                                    <label class="form-check-label small" for="anonCheck">Submit anonymously</label>
                                </div>
                                <button class="btn btn-sm btn-primary w-100">Submit Question</button>
                                <hr class="my-2" />
                                <div class="small">
                                    <div class="d-flex justify-content-between align-items-center p-1 border-start border-primary border-3 ps-2 mb-1">
                                        <span>How do we reduce tech debt?</span>
                                        <span class="badge bg-primary">↑ 12</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-chalkboard-teacher me-2"></i><strong>Facilitator View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="small fw-semibold mb-2">Questions (23 total)</div>
                                <div class="border-start border-primary border-3 p-2 mb-1 bg-primary bg-opacity-10">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="small flex-grow-1">How do we reduce tech debt?</span>
                                        <span class="badge bg-primary ms-2">↑ 12</span>
                                    </div>
                                </div>
                                <div class="border-start border-3 p-2 mb-1 text-muted" style="border-color: #e5e7eb !important; text-decoration: line-through;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="small flex-grow-1">What's the release timeline?</span>
                                        <span class="badge bg-success-subtle text-success ms-2">✓ 8</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5 Whys -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-search fs-2 text-danger"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">5 Whys Analysis</h2>
                        <p class="text-muted mb-0">AI-driven root cause analysis with structured questioning</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Root cause analysis and problem-solving</li>
                    <li>Post-mortems and incident retrospectives</li>
                    <li>Deep-dive investigations into recurring issues</li>
                    <li>Collaborative discovery of underlying causes</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">AI-Powered Follow-Ups</strong>
                                <small class="text-muted">Personalized "Why?" questions based on each answer</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Configurable Depth</strong>
                                <small class="text-muted">3-7 levels of "Why?" questioning</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Root Cause Identification</strong>
                                <small class="text-muted">AI extracts and highlights discovered root causes</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Contextual Questions</strong>
                                <small class="text-muted">Provide background context to guide AI questioning</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-light border mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-user me-2"></i><strong>Participant View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="badge bg-danger-subtle text-danger mb-2">Question 3 of 5</div>
                                <div class="small fw-semibold mb-2">Why was the deployment process not tested?</div>
                                <textarea class="form-control form-control-sm mb-2" rows="2" placeholder="Type your answer..." disabled></textarea>
                                <button class="btn btn-sm btn-primary w-100">Submit Answer</button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mb-2"><i class="fas fa-chalkboard-teacher me-2"></i><strong>Facilitator View:</strong></div>
                            <div class="border rounded p-2 bg-white">
                                <div class="small fw-semibold mb-2">Root Causes Found (8 participants)</div>
                                <div class="border-start border-danger border-3 p-2 mb-1 bg-danger bg-opacity-10">
                                    <div class="small fw-semibold">Lack of staging environment</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Found by 5 participants</div>
                                </div>
                                <div class="border-start border-danger border-3 p-2 mb-1 bg-danger bg-opacity-10">
                                    <div class="small fw-semibold">Insufficient testing resources</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Found by 3 participants</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Rating -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="fas fa-star fs-2 text-warning"></i>
                    </div>
                    <div>
                        <h2 class="h3 mb-1">Rating Activities</h2>
                        <p class="text-muted mb-0">Star or numeric ratings with distribution analysis</p>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">Best For:</h6>
                <ul class="text-muted mb-3">
                    <li>Satisfaction surveys and feedback collection</li>
                    <li>Likelihood-to-recommend (NPS) measurements</li>
                    <li>Agreement scales and confidence ratings</li>
                    <li>Evaluating multiple items or statements</li>
                </ul>

                <h6 class="fw-semibold mb-2">Features:</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
