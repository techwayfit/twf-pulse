@{
    ViewData["Title"] = "Support — TechWayFit Pulse";
}

<main class="py-5">
    <div class="container">
        <!-- Header -->
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold mb-3">Support Center</h1>
            <p class="text-muted">Get help with TechWayFit Pulse</p>
        </div>

        <div class="row g-4 mb-5">
            <!-- Getting Started (Facilitators) -->
            <div class="col-md-6">
                <a href="/home/gettingstarted" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-rocket ic-md"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">Getting Started</h3>
                            </div>
                            <p class="text-muted mb-3">For facilitators: Learn the basics of creating and running workshops.</p>
                            <ul class="text-muted small">
                                <li>Create your first session</li>
                                <li>Add activities and configure settings</li>
                                <li>Invite participants with session codes</li>
                                <li>View real-time results</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Participant Guide -->
            <div class="col-md-6">
                <a href="/home/participantguide" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-people ic-md"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">How to Join a Workshop</h3>
                            </div>
                            <p class="text-muted mb-3">For participants: Step-by-step guide to joining and participating in sessions.</p>
                            <ul class="text-muted small">
                                <li>Enter a session code and join</li>
                                <li>Participate in polls, word clouds, and more</li>
                                <li>Privacy and anonymity options</li>
                                <li>Troubleshooting common issues</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Managing Sessions -->
            <div class="col-md-6">
                <a href="/home/managingsessions" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-settings ic-md"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">Managing Sessions</h3>
                            </div>
                            <p class="text-muted mb-3">Organize and control your workshop sessions effectively.</p>
                            <ul class="text-muted small">
                                <li>Use session groups with hierarchy for organisation</li>
                                <li>Control activity visibility and timing</li>
                                <li>Bulk upload activities via CSV</li>
                                <li>Copy sessions or start from system templates</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Activity Types -->
            <div class="col-md-6">
                <a href="/home/activitytypes" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-info bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-target ic-md"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">Activity Types</h3>
                            </div>
                            <p class="text-muted mb-3">Choose the right activity for your workshop goals.</p>
                            <ul class="text-muted small">
                                <li><strong>Polls &amp; Q&amp;A:</strong> Gather quick votes and open questions</li>
                                <li><strong>Word Clouds &amp; Rating:</strong> Visualise sentiment and priorities</li>
                                <li><strong>Quadrant &amp; 5 Whys:</strong> Positioning and root cause analysis</li>
                                <li><strong>AI Summary &amp; Break:</strong> Session recap and scheduled pauses</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- AI Features -->
            <div class="col-md-6">
                <a href="/home/aifeatures" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-robot ic-md"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">AI-Powered Sessions</h3>
                            </div>
                            <p class="text-muted mb-3">Let AI help you design effective workshops.</p>
                            <ul class="text-muted small">
                                <li>Generate a sequenced activity set from your session title and context</li>
                                <li>AI-guided 5 Whys root cause analysis per participant</li>
                                <li>AI Summary activity streams a live session recap</li>
                                <li>Bring your own OpenAI API key for unlimited use</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Create Session from Template -->
            <div class="col-md-6">
                <a href="/home/createfromtemplate" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-info bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="ics ics-copy ic-md text-info"></i>
                                </div>
                                <h3 class="h5 fw-semibold mb-0">Create from Template</h3>
                            </div>
                            <p class="text-muted mb-3">Reuse and clone existing session templates for faster setup.</p>
                            <ul class="text-muted small">
                                <li>Browse saved session templates</li>
                                <li>Clone templates with one click</li>
                                <li>Preserve activities and settings</li>
                                <li>Customize before launching</li>
                            </ul>
                            <span class="text-primary small fw-medium">View Guide <i class="fas fa-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="h4 fw-semibold mb-4">Frequently Asked Questions</h2>

                <div class="mb-4">
                    <h3 class="h6 fw-semibold mb-2">How long do sessions last?</h3>
                    <p class="text-muted mb-0">
                        Session lifetime is configurable per session via the TTL (time-to-live) setting when creating or editing a session.
                        System templates default to 120 minutes, but you can set any duration. Once the TTL expires, the session and its data are automatically removed.
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="h6 fw-semibold mb-2">Can participants respond anonymously?</h3>
                    <p class="text-muted mb-0">
                        Yes! Participants can choose to provide their name or remain anonymous when joining a session.
                        Anonymous responses are not linked to any personal information.
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="h6 fw-semibold mb-2">How do I share a session with participants?</h3>
                    <p class="text-muted mb-0">
                        Each session has a unique 6-character code. Share this code with participants, and they can join
                        by entering it at <code>/participant/join</code>. You can also share a QR code or direct link.
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="h6 fw-semibold mb-2">Can I reuse session templates?</h3>
                    <p class="text-muted mb-0">
                        Yes! There are two ways to reuse content. Use the <strong>Copy</strong> button on any session in your dashboard to duplicate it with all its activities into a new draft. Or go to the <strong>Templates</strong> page to browse 22 pre-built system templates and launch one instantly.
                    </p>
                </div>

                <div class="mb-4">
                    <h3 class="h6 fw-semibold mb-2">Can I add multiple activities at once?</h3>
                    <p class="text-muted mb-0">
                        Yes! On the <strong>Add Activities</strong> page, download the CSV template, fill in your activities (Order, Type, Title, Prompt, ConfigJson, DurationInMin), and upload the file. All valid rows are imported in one go.
                    </p>
                </div>

                <div class="mb-0">
                    <h3 class="h6 fw-semibold mb-2">Is there a participant limit?</h3>
                    <p class="text-muted mb-0">
                        There is no hard limit on participants, but performance may vary depending on your server resources.
                        The platform is optimized for workshops of up to 100 concurrent participants.
                    </p>
                </div>
            </div>
        </div>

        <!-- Contact Card -->
        <div class="card border-0 shadow-sm bg-primary bg-opacity-10">
            <div class="card-body p-4 text-center">
                <h2 class="h5 fw-semibold mb-3">Still Need Help?</h2>
                <p class="text-muted mb-4">
                    Can't find what you're looking for? We're here to help!
                </p>
                <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                    <a href="mailto:support@techwayfit.com" class="btn btn-primary">
                        <i class="ics ics-email ic-xs ic-mr"></i>Email Support
                    </a>
                    <a href="https://github.com/techwayfit/twf-pulse/issues" target="_blank" class="btn btn-dark">
                        <i class="fab fa-github me-2"></i>GitHub Issues
                    </a>
                </div>
            </div>
        </div>

        <!-- Back to Home -->
        <div class="text-center mt-4">
            <a href="/" class="btn btn-lg btn-primary d-inline-flex align-items-center gap-2">
                <i class="fas fa-home"></i>
                <span>Back to Home</span>
            </a>
        </div>
    </div>
</main>
