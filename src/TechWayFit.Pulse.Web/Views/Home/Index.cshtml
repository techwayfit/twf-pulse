@using TechWayFit.Pulse.Web.Models.PromotionalComponents
@{
    ViewData["Title"] = "TechWayFit Pulse — Home";
}

@* ═══════════════════════════════════════════════════════════════════════
   PERSONALIZED HEADER SECTION (NOT Cached)
   User-specific dashboard widget shown only for logged-in users
   ═══════════════════════════════════════════════════════════════════════ *@
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}
@section HeroHeader {
    <!-- Hero Section -->
    <section class="py-5">
        <div class="container container-wide">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <!-- Badge -->
                    <div class="mb-4">
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">
                            <i class="ics ics-bolt ic-xs" aria-hidden="true"></i>
                            Workshop Engagement Engine
                        </span>
                    </div>

                    <!-- Title -->
                    <h1 class="display-4 fw-bold mb-4 lh-sm">
                        Run engaging workshops—<span class="hero-title-accent">without losing the data</span>.
                    </h1>

                    <!-- Description -->
                    <p class="lead text-muted mb-4">
                        Polls, word clouds, 4-quadrant matrices, and guided 5-Whys—designed to help people open up,
                        and help you leave with measurable outcomes.
                    </p>

                    <!-- Action Buttons -->
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <a class="btn btn-primary btn-lg px-4 py-3" href="/facilitator/dashboard">
                            <i class="fas fa-chart-bar me-2"></i>Manage Your Session
                        </a>
                        <a class="btn btn-outline-primary btn-lg px-4 py-3" href="/participant/join">
                            <i class="fas fa-users me-2"></i>Join as Participant
                        </a>
                    </div>

                    <!-- Feature Pills -->
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-white text-dark border px-3 py-2">
                            <i class="ics ics-check-mark ic-xs ic-mr"></i>Anonymous optional
                        </span>
                        <span class="badge bg-white text-dark border px-3 py-2">
                            <i class="ics ics-chart ic-xs ic-mr"></i>Real-time dashboards
                        </span>
                        <span class="badge bg-white text-dark border px-3 py-2">
                            <i class="ics ics-target ic-xs ic-mr"></i>"5 Whys" output
                        </span>
                        <span class="badge bg-white text-dark border px-3 py-2">
                            <i class="ics ics-bolt ic-xs ic-mr"></i>AI-powered sessions
                        </span>
                    </div>
                </div>

                <!-- Hero Visual -->
                <div class="col-lg-5 d-none d-lg-flex justify-content-center align-items-center">
                    <div class="hero-visual-wrap">
                        <div class="gradient-orb">
                            <svg class="pulse-overlay" viewBox="0 0 200 80" width="200" height="80">
                                <polyline points="0,40 30,40 40,20 50,60 60,30 70,50 80,40 200,40"
                                          fill="none"
                                          stroke="white"
                                          stroke-width="3"
                                          class="animated-pulse-line" />
                            </svg>
                        </div>
                        <div class="hero-float-stat s1">
                            <div class="hero-float-n">94%</div>
                            Engagement
                        </div>
                        <div class="hero-float-stat s2">
                            <div class="hero-float-n">Live</div>
                            Real-time sync
                        </div>
                        <div class="hero-float-stat s3">
                            <div class="hero-float-n">2.4k</div>
                            Sessions Run
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@section PersonalizedHeader {
    @if (isAuthenticated)
    {
        @* ❌ NOT cached - user-specific, always fresh *@
        @await Component.InvokeAsync("PersonalizedDashboard")
    }
}

<!-- AI Capability Promotion Banner -->
<section class="py-5">
    <div class="container container-wide">
        <div class="card border-0 shadow-sm overflow-hidden bg-white">
            <div class="row g-0 align-items-stretch">
                <div class="col-lg-7 order-lg-2">
                    <!-- Mockup UI Preview -->
                    <div class="ai-mockup-area">
                        <!-- Poll mockup card (left, spans full height) -->
                        <div class="mockup-card mockup-poll">
                            <div class="mc-label">Poll</div>
                            <div class="mc-title">What is your top priority?</div>
                            <div class="mc-bar-row"><span>Option A</span><span class="mc-pct teal">82%</span></div>
                            <div class="mc-bar" style="width:82%"></div>
                            <div class="mc-bar-row"><span>Option B</span><span class="mc-pct blue">65%</span></div>
                            <div class="mc-bar mc-bar-blue" style="width:65%"></div>
                            <div class="mc-bar-row"><span>Option C</span><span class="mc-pct amber">40%</span></div>
                            <div class="mc-bar mc-bar-amber" style="width:40%"></div>
                        </div>
                        <!-- SWOT mockup (top right) -->
                        <div class="mockup-card mockup-swot">
                            <div class="mc-label">SWOT Analysis</div>
                            <div class="mc-swot">
                                <div class="mc-swot-cell s">Strengths</div>
                                <div class="mc-swot-cell w">Weaknesses</div>
                                <div class="mc-swot-cell o">Opportunities</div>
                                <div class="mc-swot-cell t">Threats</div>
                            </div>
                        </div>
                        <!-- Word cloud mockup (bottom right) -->
                        <div class="mockup-card mockup-cloud">
                            <div class="mc-label">Word Cloud</div>
                            <div class="mc-words">
                                <span style="font-size:22px;font-weight:800;color:#0e9e9a;">Innovation</span>
                                <span style="font-size:14px;font-weight:800;color:#3b82f6;">Strategy</span>
                                <span style="font-size:18px;font-weight:800;color:#10b981;">Teamwork</span>
                                <span style="font-size:12px;font-weight:800;color:#f59e0b;">Ideas</span>
                                <span style="font-size:20px;font-weight:800;color:#0e9e9a;">Growth</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 order-lg-1">
                    <div class="p-4 p-lg-5 h-100 d-flex flex-column justify-content-center">
                        <div class="mb-3">
                            <span class="badge rounded-pill bg-info bg-opacity-10 text-info fw-semibold">
                                <i class="fas fa-brain"></i> AI-Powered
                            </span>
                        </div>
                        <h3 class="fw-bold mb-3 text-dark lh-sm">
                            Generate Complete Workshop Sessions in Seconds
                        </h3>
                        <p class="mb-4 text-muted lh-base">
                            Describe your workshop goal, and our AI will create a complete session with tailored activities
                            and thoughtful questions—ready to go live instantly.
                        </p>
                        <div class="d-flex flex-column gap-2 mb-4">
                            <div class="d-flex align-items-center text-muted">
                                <i class="fas fa-check-circle me-2 text-success"></i>
                                <span>Smart activity selection</span>
                            </div>
                            <div class="d-flex align-items-center text-muted">
                                <i class="fas fa-check-circle me-2 text-success"></i>
                                <span>Custom questions</span>
                            </div>
                            <div class="d-flex align-items-center text-muted">
                                <i class="fas fa-check-circle me-2 text-success"></i>
                                <span>Template-based or free-form</span>
                            </div>
                        </div>
                        <a href="/facilitator/create-session" class="btn btn-primary">
                            <i class="fas fa-plus-circle me-2"></i>Create Session
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Templates Section -->
<section class="py-5">
    <div class="container container-wide">
        <div class="bg-white bg-opacity-75 rounded-4 p-5">
            <!-- Section Header -->
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold mb-3">Starter templates</h2>
                <p class="text-muted">Pick one and customize in 60 seconds.</p>
            </div>

            <!-- Templates Grid -->
            <div class="row g-3 g-lg-4">
                <div class="col-6 col-lg-3">
                    <a href="/facilitator/templates?category=Retrospective" class="template-item">
                        <div class="template-emoji">&#x1F680;</div>
                        <h5 class="template-name">Retro Sprint Review</h5>
                        <p class="template-desc">Quick pulse + themes + actions</p>
                    </a>
                </div>

                <div class="col-6 col-lg-3">
                    <a href="/facilitator/templates?category=IncidentReview" class="template-item">
                        <div class="template-emoji">&#x2699;&#xFE0F;</div>
                        <h5 class="template-name">Ops Pain Points</h5>
                        <p class="template-desc">Impact/Effort + 5-Whys</p>
                    </a>
                </div>

                <div class="col-6 col-lg-3">
                    <a href="/facilitator/templates?category=ProductDiscovery" class="template-item">
                        <div class="template-emoji">&#x1F4A1;</div>
                        <h5 class="template-name">Product Discovery</h5>
                        <p class="template-desc">Idea cloud + prioritization</p>
                    </a>
                </div>

                <div class="col-6 col-lg-3">
                    <a href="/facilitator/templates?category=TeamBuilding" class="template-item">
                        <div class="template-emoji">&#x1F91D;</div>
                        <h5 class="template-name">Team Building</h5>
                        <p class="template-desc">Icebreakers + team activities</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
