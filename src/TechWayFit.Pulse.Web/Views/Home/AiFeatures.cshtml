@{
    ViewData["Title"] = "AI-Powered Sessions — TechWayFit Pulse";
}

<main class="py-5">
    <div class="container container-medium">
        <!-- Header -->
        <div class="mb-5">
            <a href="/home/support" class="text-muted small text-decoration-none d-inline-flex align-items-center gap-1 mb-3">
                <i class="fas fa-arrow-left"></i> Back to Support
            </a>
            <h1 class="display-5 fw-bold mb-3">AI-Powered Sessions</h1>
            <p class="lead text-muted">Let AI help you design effective workshops in seconds</p>
        </div>

        <!-- Two-step overview -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-robot ic-md text-warning"></i>
                    </div>
                    <h2 class="h4 mb-0">How AI Activity Generation Works</h2>
                </div>

                <p class="text-muted mb-3">
                    AI lives on the <strong>Add Activities</strong> page, not on the Create Session page.
                    You first create the session (giving it a title and context), then on the next step you choose how you
                    want to populate it with activities — manually, from a template, or with AI.
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100 text-center">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-2 icon-circle icon-circle-50">
                                <span class="fw-bold text-primary">1</span>
                            </div>
                            <h6 class="fw-semibold mb-1">Create Session</h6>
                            <p class="text-muted small mb-0">Set session title, description, join form, and group — no AI here</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border border-warning rounded p-3 h-100 text-center">
                            <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-2 icon-circle icon-circle-50">
                                <span class="fw-bold text-warning">2</span>
                            </div>
                            <h6 class="fw-semibold mb-1">AI Create tab</h6>
                            <p class="text-muted small mb-0">On the Add Activities page, switch to <strong>AI Create</strong> and configure your generation options</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100 text-center">
                            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-2 icon-circle icon-circle-50">
                                <span class="fw-bold text-success">3</span>
                            </div>
                            <h6 class="fw-semibold mb-1">Save Session</h6>
                            <p class="text-muted small mb-0">Review and edit the generated activities, then save and go live</p>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info border-0 mb-0">
                    <i class="fas fa-image me-2"></i>
                    <small><strong>Screenshot:</strong> Add Activities page with Manual / Template / AI Create tabs (to be added)</small>
                </div>
            </div>
        </div>

        <!-- Add Activities page - three modes -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-list ic-md text-primary"></i>
                    </div>
                    <h2 class="h4 mb-0">Three Ways to Add Activities</h2>
                </div>

                <p class="text-muted mb-3">
                    After creating a session you land on the <strong>Add Activities</strong> page. Three tabs let you choose your approach — and you can combine them freely on the same session.
                </p>

                <div class="row g-3 mb-0">
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <h6 class="fw-semibold mb-2"><i class="ics ics-pencil ic-sm ic-mr text-secondary"></i>Manual</h6>
                            <p class="text-muted small mb-0">Add activities one by one — Poll, Word Cloud, Q&amp;A, Rating, Quadrant, 5 Whys, General Feedback, AI Summary, or Break — filling in each form yourself</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <h6 class="fw-semibold mb-2"><i class="ics ics-clipboard ic-sm ic-mr text-primary"></i>Template</h6>
                            <p class="text-muted small mb-0">Pick a system or saved template and import its full activity set into your session in one click</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border border-warning rounded p-3 h-100">
                            <h6 class="fw-semibold mb-2"><i class="ics ics-robot ic-sm ic-mr text-warning"></i>AI Create</h6>
                            <p class="text-muted small mb-0">AI reads your session title and any extra context you provide, then generates a sequenced set of activities automatically</p>
                        </div>
                    </div>
                </div>

                <div class="alert alert-success border-0 mt-3 mb-0">
                    <i class="fas fa-lightbulb me-2"></i>
                    <small><strong>Tip:</strong> You can run AI Create, then switch to Manual to tweak or add extra activities. All three modes accumulate onto the same activity list.</small>
                </div>
            </div>
        </div>

        <!-- AI Create inputs -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-settings ic-md text-warning"></i>
                    </div>
                    <h2 class="h4 mb-0">AI Create — Generation Options</h2>
                </div>

                <p class="text-muted mb-3">
                    The AI Create tab reads your session title automatically. You then provide a few optional hints to tighten the output:
                </p>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Workshop Type</strong>
                                <small class="text-muted">Retrospective, Ops/Process Improvement, Discovery, Incident Review, Feedback, Planning, Brainstorming — or leave on <em>Auto-detect</em></small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Session Duration</strong>
                                <small class="text-muted">15 min (2–3 activities) up to 75 min (10–15 activities). Max 15 per AI call; you can generate multiple times</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Number of Participants</strong>
                                <small class="text-muted">Small team (3–5), Medium (6–10), Large (11–20), or Large group (20+)</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Participant Types</strong>
                                <small class="text-muted">Filter by industry, then search and select multiple participant types to tailor activity language</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Additional Context</strong>
                                <small class="text-muted">Free-text field for extra hints — specific challenges, recent events, constraints, etc.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-light p-4 rounded mb-0">
                    <h6 class="fw-semibold mb-2">What the AI generates:</h6>
                    <ul class="text-muted mb-0">
                        <li>A sequenced list of activities — typically Polls, Word Clouds, Ratings, Quadrant matrices, General Feedback, and Q&amp;A, chosen to suit the workshop type and duration</li>
                        <li>Each activity comes with a question/prompt, description, and pre-filled options where applicable</li>
                        <li>Activities are ordered for a natural workshop flow</li>
                        <li>You can edit, reorder, or delete any generated activity before saving</li>
                        <li>You can run AI Create multiple times in the same session — generated activities accumulate (max 30 per session)</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- AI Summary Activity -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-sparkles ic-md text-success"></i>
                    </div>
                    <h2 class="h4 mb-0">AI Summary Activity</h2>
                </div>

                <p class="text-muted mb-3">
                    The <strong>AI Summary</strong> is a dedicated activity type you can add at the end of any session.
                    When the facilitator opens it in the live console, the AI reads all completed (closed) activities and streams
                    a markdown-formatted summary in real time — giving participants an instant structured recap of everything the session covered.
                </p>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Real-time Streaming</strong>
                                <small class="text-muted">Summary text streams token-by-token as the AI generates it — no waiting for the full result</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Contextual Recap</strong>
                                <small class="text-muted">Only closed activities with participant responses feed into the summary — Break and other AI Summary activities are excluded</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Custom Prompt Addition</strong>
                                <small class="text-muted">Optionally supply extra instructions when adding the AI Summary activity (e.g., &ldquo;Focus on action items&rdquo;)</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                            <div>
                                <strong class="d-block">Shown on Presentation Screen</strong>
                                <small class="text-muted">The streamed summary appears in the facilitator's Presentation view so the whole room can see it</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-success border-0 mb-0">
                    <i class="fas fa-lightbulb me-2"></i>
                    <small><strong>Tip:</strong> Add the AI Summary activity last in your session agenda. Open all other activities, collect responses, then open AI Summary as the final step to give participants an AI-generated recap they can reflect on.</small>
                </div>
            </div>
        </div>

        <!-- 5 Whys AI -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-search ic-md text-danger"></i>
                    </div>
                    <h2 class="h4 mb-0">5 Whys — AI-Guided Root Cause Analysis</h2>
                </div>

                <p class="text-muted mb-3">
                    The <strong>5 Whys</strong> activity uses AI to guide each participant through a personal root-cause analysis chain.
                    After a participant answers the initial question, the AI evaluates their response and either asks a targeted follow-up
                    &ldquo;Why&rdquo; question or — if the root cause has been identified — surfaces it with a brief insight and recommended actions.
                </p>

                <div class="bg-light p-4 rounded mb-3">
                    <h6 class="fw-semibold mb-2">How it works per participant:</h6>
                    <ol class="mb-0 text-muted">
                        <li>Facilitator sets the root question (e.g., &ldquo;Why is our deployment pipeline failing?&rdquo;) when creating the activity</li>
                        <li>Participant submits their first answer in the join view</li>
                        <li>AI analyses the full conversation chain and asks the next contextual &ldquo;Why&rdquo;</li>
                        <li>This continues until the AI determines the root cause (typically 3–5 steps)</li>
                        <li>The AI surfaces the identified root cause and a short insight/recommendation</li>
                    </ol>
                </div>

                <div class="alert alert-info border-0 mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <small>Each participant has their own independent AI conversation chain — the AI adapts its follow-up questions based on each person&apos;s individual answers, so ten participants may reach ten different root causes.</small>
                </div>
            </div>
        </div>

        <!-- Quota and API Key -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="ics ics-key ic-md text-danger"></i>
                    </div>
                    <h2 class="h4 mb-0">Quota and Bring Your Own Key (BYOK)</h2>
                </div>

                <p class="text-muted mb-3">
                    Every facilitator account includes <strong>5 free AI-generated sessions per month</strong>.
                    Once the free quota is used, you can continue generating sessions by supplying your own OpenAI API key
                    (BYOK — Bring Your Own Key).
                </p>

                <div class="bg-light p-4 rounded mb-3">
                    <h6 class="fw-semibold mb-2">How to add your own API key:</h6>
                    <ol class="mb-0 text-muted">
                        <li>Sign in to your facilitator account</li>
                        <li>Click your name in the top navigation and go to <strong>Profile</strong></li>
                        <li>Scroll to the <strong>AI Configuration</strong> section</li>
                        <li>Paste your OpenAI API key into the <strong>OpenAI API Key</strong> field</li>
                        <li>Optionally set a custom <strong>OpenAI Base URL</strong> if you use Azure OpenAI or another OpenAI-compatible endpoint</li>
                        <li>Save — your key is stored encrypted using ASP.NET Core Data Protection and used only for your sessions</li>
                    </ol>
                </div>

                <div class="alert alert-warning border-0 mb-0">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <small><strong>Privacy:</strong> Your API key is encrypted at rest and never shared with other accounts. The Profile page also shows your current quota usage and reset date.</small>
                </div>
            </div>
        </div>

        <!-- Back to Support -->
        <div class="text-center mt-4">
            <a href="/home/support" class="btn btn-lg btn-outline-secondary d-inline-flex align-items-center gap-2">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Support</span>
            </a>
        </div>
    </div>
</main>
