@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Domain.Models.ResponsePayloads
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using System.Text.Json
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IResponseService ResponseService
@inject NavigationManager Navigation
@inject ILogger<FiveWhysDashboard> Logger
@implements IAsyncDisposable

<div class="five-whys-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-2 small text-muted">Loading root cause analyses...</div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="text-center p-3 bg-white border rounded-3">
                    <div class="fw-bold fs-4 text-primary">@completedChains.Count</div>
                    <div class="small text-muted">Completed</div>
                </div>
            </div>
            <div class="col-4">
                <div class="text-center p-3 bg-white border rounded-3">
                    <div class="fw-bold fs-4 text-warning">@inProgressCount</div>
                    <div class="small text-muted">In Progress</div>
                </div>
            </div>
            <div class="col-4">
                <div class="text-center p-3 bg-white border rounded-3">
                    <div class="fw-bold fs-4 text-success">@avgDepth</div>
                    <div class="small text-muted">Avg Depth</div>
                </div>
            </div>
        </div>

        @if (completedChains.Count == 0 && inProgressCount == 0)
        {
            <div class="text-center py-4 text-muted">
                <i class="fas fa-search fa-2x mb-3 d-block opacity-50"></i>
                <p class="mb-0">No analyses submitted yet. Participants are digging for root causes...</p>
            </div>
        }
        else
        {
            <!-- Tab toggle -->
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-sm @(showCompleted ? "btn-danger" : "btn-outline-secondary")"
                        @onclick="() => showCompleted = true">
                    <i class="fas fa-bullseye me-1"></i>Root Causes (@completedChains.Count)
                </button>
                <button class="btn btn-sm @(!showCompleted ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => showCompleted = false">
                    <i class="fas fa-hourglass-half me-1"></i>In Progress (@inProgressCount)
                </button>
            </div>

            @if (showCompleted)
            {
                <!-- Completed Root Cause Chains -->
                @if (completedChains.Count == 0)
                {
                    <p class="text-muted small text-center py-3">No completed analyses yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @{int ci = 0;}
                        @foreach (var entry in completedChains)
                        {
                            ci++;
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:32px;height:32px;font-size:.8rem;">@string.Format("P{0}", ci)</div>
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">
                                                <i class="fas fa-bullseye me-1"></i>Root Cause Found
                                            </span>
                                        </div>
                                        <span class="badge bg-light text-muted border">@entry.Chain.Count @(entry.Chain.Count == 1 ? "Why" : "Whys") deep</span>
                                    </div>

                                    <!-- Mini chain -->
                                    <div class="five-whys-mini-chain mb-3">
                                        @foreach (var exchange in entry.Chain)
                                        {
                                            <div class="mini-exchange">
                                                <div class="mini-q text-muted small">
                                                    <i class="fas fa-chevron-right me-1 text-primary" style="font-size:.7rem;"></i>
                                                    @TruncateText(exchange.Question, 80)
                                                </div>
                                                <div class="mini-a fw-medium small ps-3">
                                                    @TruncateText(exchange.Answer, 100)
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <!-- Root cause highlight -->
                                    <div class="p-2 bg-danger bg-opacity-10 rounded-2 border-start border-danger border-3 ps-3 mb-2">
                                        <div class="small text-muted fw-semibold mb-1">ROOT CAUSE</div>
                                        <p class="mb-0 small fw-semibold">@entry.RootCause</p>
                                    </div>

                                    @if (!string.IsNullOrEmpty(entry.Insight))
                                    {
                                        <div class="p-2 bg-light rounded-2 mt-2">
                                            <div class="small text-muted fw-semibold mb-1">
                                                <i class="fas fa-lightbulb text-warning me-1"></i>INSIGHT
                                            </div>
                                            <p class="mb-0 small text-muted">@entry.Insight</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- In-Progress Chains -->
                @if (inProgressChains.Count == 0)
                {
                    <p class="text-muted small text-center py-3">No analyses in progress.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @{int pi = 0;}
                        @foreach (var entry in inProgressChains)
                        {
                            pi++;
                            <div class="card border-0 shadow-sm opacity-75">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-warning text-white d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:32px;height:32px;font-size:.8rem;">P@pi</div>
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                                                <i class="fas fa-spinner fa-spin me-1"></i>Exploring
                                            </span>
                                        </div>
                                        <span class="badge bg-light text-muted border">@entry.Chain.Count @(entry.Chain.Count == 1 ? "Why" : "Whys") so far</span>
                                    </div>
                                    <div class="small text-muted">
                                        Last answer: <span class="fw-medium text-dark">@TruncateText(entry.Chain.LastOrDefault()?.Answer ?? "—", 80)</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }
    }
</div>

<style>
    .five-whys-mini-chain {
        border-left: 2px solid var(--bs-border-color);
        padding-left: .75rem;
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .mini-exchange {
        display: flex;
        flex-direction: column;
        gap: .15rem;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public required string SessionCode { get; set; }

    [Parameter, EditorRequired]
    public required Guid ActivityId { get; set; }

    private bool isLoading = true;
    private bool showCompleted = true;

    private List<FiveWhysResponsePayload> completedChains = new();
    private List<FiveWhysResponsePayload> inProgressChains = new();
    private int inProgressCount = 0;
    private string avgDepth = "—";

    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await SetupSignalR();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var responses = await ResponseService.GetByActivityAsync(ActivityId);
            completedChains = new();
            inProgressChains = new();

            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            foreach (var resp in responses)
            {
                try
                {
                    var payload = JsonSerializer.Deserialize<FiveWhysResponsePayload>(resp.Payload, opts);
                    if (payload == null) continue;

                    if (payload.IsComplete)
                        completedChains.Add(payload);
                    else if (payload.Chain.Count > 0)
                        inProgressChains.Add(payload);
                }
                catch (JsonException ex)
                {
                    Logger.LogWarning(ex, "Failed to deserialize 5 Whys payload");
                }
            }

            inProgressCount = inProgressChains.Count;
            avgDepth = completedChains.Count > 0
                ? Math.Round(completedChains.Average(c => c.Chain.Count), 1).ToString("F1")
                : "—";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load 5 Whys dashboard");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<object>("ResponseReceived", async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "SignalR setup failed for 5 Whys dashboard");
        }
    }

    private static string TruncateText(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "…";

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            try
            {
                await hubConnection.InvokeAsync("Unsubscribe", SessionCode);
                await hubConnection.DisposeAsync();
            }
            catch { /* ignore on dispose */ }
        }
    }
}
