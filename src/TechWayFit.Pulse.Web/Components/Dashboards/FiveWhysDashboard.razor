@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Domain.Models.ResponsePayloads
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using System.Text.Json
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IResponseService ResponseService
@inject NavigationManager Navigation
@inject ILogger<FiveWhysDashboard> Logger
@implements IAsyncDisposable

<div class="five-whys-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading root cause analyses...</div>
        </div>
    }
    else
    {
        var totalAnalyses = completedChains.Count + inProgressCount;
        var completionRate = totalAnalyses > 0
            ? (int)Math.Round((double)completedChains.Count / totalAnalyses * 100)
            : 0;
        var deepestDepth = completedChains
            .Concat(inProgressChains)
            .Select(c => c.Chain.Count)
            .DefaultIfEmpty(0)
            .Max();
        var leadCompletedChain = completedChains
            .OrderByDescending(c => c.Chain.Count)
            .FirstOrDefault();

        <div class="five-whys-layout">
            <section class="five-whys-hero-card">
                <div class="five-whys-hero-copy">
                    <div class="five-whys-hero-kicker">
                        <i class="fas fa-search"></i>
                        <span>Root Cause Analysis</span>
                    </div>
                    <h4 class="five-whys-hero-title">5 Whys Dashboard</h4>
                    <div class="five-whys-chip-row">
                        <span class="five-whys-chip">
                            <i class="fas fa-diagram-project"></i>
                            @totalAnalyses analyses
                        </span>
                        <span class="five-whys-chip">
                            <i class="fas fa-bullseye"></i>
                            @completedChains.Count completed
                        </span>
                        <span class="five-whys-chip">
                            <i class="fas fa-hourglass-half"></i>
                            @inProgressCount in progress
                        </span>
                        <span class="five-whys-chip">
                            <i class="fas fa-arrows-down-to-line"></i>
                            Avg depth @avgDepth
                        </span>
                    </div>
                </div>

                <div class="five-whys-hero-pane">
                    <div class="five-whys-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="five-whys-updated-at">Real-time updates are active for new responses.</div>


                    <div class="five-whys-highlight">
                        <span class="label">Progress snapshot</span>
                        <span class="value">@completionRate% completed</span>
                        <span class="meta">Deepest chain so far: @deepestDepth @(deepestDepth == 1 ? "why" : "whys")</span>
                    </div>
                </div>
            </section>

            <section class="five-whys-chains-card">
                <div class="five-whys-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-stream me-2"></i>Analysis Chains
                    </h6>
                    <div class="five-whys-toggle-switch" role="group" aria-label="Toggle chain type">
                        <button class="five-whys-toggle-btn @(showCompleted ? "is-active" : "")"
                                @onclick="() => showCompleted = true">
                            <i class="fas fa-bullseye"></i>
                            Root Causes (@completedChains.Count)
                        </button>
                        <button class="five-whys-toggle-btn @(!showCompleted ? "is-active" : "")"
                                @onclick="() => showCompleted = false">
                            <i class="fas fa-hourglass-half"></i>
                            In Progress (@inProgressCount)
                        </button>
                    </div>
                </div>

                @if (totalAnalyses == 0)
                {
                    <div class="five-whys-empty-state">
                        <i class="fas fa-search"></i>
                        <div>
                            <div class="fw-semibold">No analyses submitted yet</div>
                            <div class="small text-muted">Participants are still digging for root causes.</div>
                        </div>
                    </div>
                }
                else if (showCompleted)
                {
                    @if (completedChains.Count == 0)
                    {
                        <div class="five-whys-empty-state">
                            <i class="fas fa-bullseye"></i>
                            <span>No completed analyses yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="five-whys-entry-list">
                            @{ int completedIndex = 0; }
                            @foreach (var entry in completedChains)
                            {
                                completedIndex++;
                                <article class="five-whys-entry-card is-complete">
                                    <div class="five-whys-entry-head">
                                        <div class="five-whys-entry-meta">
                                            <span class="five-whys-avatar">
                                                @string.Format("P{0}", completedIndex)</span>
                                            <span class="five-whys-entry-badge is-complete">
                                                <i class="fas fa-bullseye"></i>
                                                Root Cause Found
                                            </span>
                                        </div>
                                        <span class="five-whys-depth-badge">@entry.Chain.Count @(entry.Chain.Count == 1 ? "why" : "whys") deep</span>
                                    </div>

                                    <div class="five-whys-mini-chain">
                                        @foreach (var exchange in entry.Chain)
                                        {
                                            <div class="mini-exchange">
                                                <div class="mini-q">
                                                    <i class="fas fa-chevron-right"></i>
                                                    @TruncateText(exchange.Question, 80)
                                                </div>
                                                <div class="mini-a">@TruncateText(exchange.Answer, 100)</div>
                                            </div>
                                        }
                                    </div>

                                    <div class="five-whys-root-cause">
                                        <div class="label">Root Cause</div>
                                        <p>@(entry.RootCause ?? "Root cause submitted")</p>
                                    </div>

                                    @if (!string.IsNullOrEmpty(entry.Insight))
                                    {
                                        <div class="five-whys-insight">
                                            <div class="label">
                                                <i class="fas fa-lightbulb"></i>
                                                Insight
                                            </div>
                                            <p>@entry.Insight</p>
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                }
                else
                {
                    @if (inProgressChains.Count == 0)
                    {
                        <div class="five-whys-empty-state">
                            <i class="fas fa-hourglass-half"></i>
                            <span>No analyses in progress right now.</span>
                        </div>
                    }
                    else
                    {
                        <div class="five-whys-entry-list">
                            @{ int progressIndex = 0; }
                            @foreach (var entry in inProgressChains)
                            {
                                progressIndex++;
                                <article class="five-whys-entry-card is-progress">
                                    <div class="five-whys-entry-head">
                                        <div class="five-whys-entry-meta">
                                            <span class="five-whys-avatar is-progress">P@progressIndex</span>
                                            <span class="five-whys-entry-badge is-progress">
                                                <i class="fas fa-spinner fa-spin"></i>
                                                Exploring
                                            </span>
                                        </div>
                                        <span class="five-whys-depth-badge">@entry.Chain.Count @(entry.Chain.Count == 1 ? "why" : "whys") so far</span>
                                    </div>

                                    <div class="five-whys-last-answer">
                                        <span class="label">Latest answer</span>
                                        <p>@TruncateText(entry.Chain.LastOrDefault()?.Answer ?? "No answer yet", 120)</p>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                }
            </section>
        </div>
    }
</div>

