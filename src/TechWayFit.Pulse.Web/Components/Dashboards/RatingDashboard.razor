@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IRatingDashboardService RatingDashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<RatingDashboard> Logger
@implements IAsyncDisposable

<div class="rating-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading rating results...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    }
    else if (dashboard != null)
    {
        var topBucket = dashboard.Distribution?
            .OrderByDescending(d => d.Count)
            .ThenByDescending(d => d.Rating)
            .FirstOrDefault();

        <div class="rating-layout">
            <section class="rating-hero-card">
                <div class="rating-hero-copy">
                    <div class="rating-hero-kicker">
                        <i class="ics ics-star ic-sm"></i>
                        <span>Live Rating</span>
                    </div>
                    <h4 class="rating-hero-title">Rating Results</h4>
                    <div class="rating-chip-row">
                        <span class="rating-chip">
                            <i class="fas fa-star"></i>
                            Avg @GetAverageRating()
                        </span>
                        <span class="rating-chip">
                            <i class="fas fa-sliders"></i>
                            Median @GetMedianRating()
                        </span>
                        <span class="rating-chip">
                            <i class="fas fa-reply"></i>
                            @dashboard.TotalResponses ratings
                        </span>
                        <span class="rating-chip">
                            <i class="fas fa-users"></i>
                            @dashboard.ParticipantCount participants
                        </span>
                    </div>
                </div>

                <div class="rating-hero-pane">
                    <div class="rating-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="rating-updated-at">
                        @if (recentActivities.Any())
                        {
                            <span>Last response: @recentActivities.First().ToString("HH:mm:ss")</span>
                        }
                        else
                        {
                            <span>No recent responses yet</span>
                        }
                    </div>

                    @if (topBucket is not null && topBucket.Count > 0)
                    {
                        <div class="rating-top-bucket">
                            <span class="label">Most selected rating</span>
                            <span class="value">@topBucket.Rating / 5</span>
                            <span class="meta">@topBucket.Count responses (@topBucket.Percentage.ToString("F1")%)</span>
                        </div>
                    }
                    else
                    {
                        <div class="rating-pane-muted">
                            <i class="fas fa-hourglass-half"></i>
                            <span>Waiting for participant ratings.</span>
                        </div>
                    }
                </div>
            </section>

            <section class="rating-distribution-card">
                <div class="rating-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-bar me-2"></i>Rating Distribution
                    </h6>
                </div>

                @if (dashboard.TotalResponses > 0)
                {
                    <div class="rating-distribution">
                        @foreach (var rating in GetRatingDistribution())
                        {
                            <div class="rating-bar-row rating-bar-row--@rating.Value @(rating.Count == 0 ? "rating-bar-row--zero" : "")" aria-label="@rating.Value star rating">
                                <div class="rating-bar-label-col">
                                    <i class="fas fa-star rating-bar-star"></i>
                                    <span class="rating-bar-score">@rating.Value<span class="rating-bar-max">/5</span></span>
                                </div>
                                <div class="rating-bar-track">
                                    <div class="rating-bar-fill" style="width: @rating.Percentage%"></div>
                                </div>
                                <div class="rating-bar-meta">
                                    <span class="rating-bar-pct">@rating.Percentage.ToString("F1")%</span>
                                    <span class="rating-bar-cnt" title="@rating.Count vote(s)">@rating.Count</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="rating-empty-state">
                        <i class="ics ics-star ic-lg"></i>
                        <div>
                            <div class="fw-semibold">No ratings yet</div>
                            <div class="small text-muted">Results will appear once participants start rating.</div>
                        </div>
                    </div>
                }
            </section>

            @if (dashboard.Comments?.Any() == true)
            {
                <section class="rating-comments-card">
                    <div class="rating-section-head">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-comments me-2"></i>Comments (@dashboard.Comments.Count)
                        </h6>
                    </div>
                    <div class="rating-comments-list">
                        @foreach (var comment in dashboard.Comments.Take(10))
                        {
                            <article class="rating-comment-item">
                                <div class="rating-comment-head">
                                    <div>
                                        @for (int i = 0; i < comment.Rating; i++)
                                        {
                                            <i class="ics ics-star ic-sm text-warning"></i>
                                        }
                                    </div>
                                    <small class="text-muted">@comment.CreatedAt.ToString("HH:mm:ss")</small>
                                </div>
                                <p class="mb-0 text-muted">@comment.Comment</p>
                            </article>
                        }
                    </div>
                </section>
            }

        </div>
    }
    else
    {
        <div class="alert alert-warning mb-0">
            <i class="fas fa-exclamation-circle me-2"></i>
            Rating dashboard data is unavailable right now.
        </div>
    }
</div>

