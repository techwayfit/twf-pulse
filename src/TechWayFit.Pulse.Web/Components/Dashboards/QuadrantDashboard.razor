@code {
    [Parameter] public string SessionCode { get; set; } = string.Empty;
    [Parameter] public Guid ActivityId { get; set; }
    [Parameter] public string? ActivityConfig { get; set; }

    private readonly string canvasId = $"quadrantChart_{Guid.NewGuid().ToString("N")[..8]}";
    private QuadrantDashboardResponse? dashboard;
    private QuadrantConfig? config;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private HubConnection? hubConnection;
    private int currentItemIndex = 0;
    private string currentItemName = string.Empty;
    private bool isNavigating = false;
    private QuadrantBubbleSizeMode bubbleSizeMode = QuadrantBubbleSizeMode.Proportional;
    private Guid? sessionId;
    private bool firstRenderComplete = false;

    private double ParticipationRate =>
        dashboard is null || dashboard.ParticipantCount == 0 ? 0
        : dashboard.RespondedParticipants * 100.0 / dashboard.ParticipantCount;

    protected override async Task OnInitializedAsync()
    {
        LoadConfig();
        await LoadDashboard();
        if (sessionId.HasValue)
        {
            try
            {
                var saved = await MetadataService.GetValueAsync(
                    sessionId.Value, ActivityId,
                    TechWayFit.Pulse.Domain.Models.ActivityMetadataKeys.QuadrantCurrentItemIndex);
                if (saved is not null && int.TryParse(saved, out var savedIdx))
                {
                    currentItemIndex = savedIdx;
                    UpdateCurrentItemName();
                }
            }
            catch { /* fail silently */ }
        }
        await SetupSignalR();
    }

    protected override async Task OnParametersSetAsync()
    {
        LoadConfig();
        if (!isLoading) await LoadDashboard();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) firstRenderComplete = true;

        if (firstRenderComplete && dashboard?.Items.Any() == true)
        {
            try { await RenderChart(); }
            catch (Exception ex) { Logger.LogError(ex, "Failed to render quadrant bubble chart"); }
        }
    }

    private void LoadConfig()
    {
        if (string.IsNullOrWhiteSpace(ActivityConfig)) return;
        try
        {
            config = JsonSerializer.Deserialize<QuadrantConfig>(ActivityConfig,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (config is not null)
            {
                bubbleSizeMode = config.BubbleSizeMode;
                UpdateCurrentItemName();
            }
        }
        catch { /* keep defaults */ }
    }

    private void UpdateCurrentItemName()
    {
        if (config?.Items == null || config.Items.Count == 0)
        {
            currentItemName = string.Empty;
            return;
        }
        var idx = Math.Clamp(currentItemIndex, 0, config.Items.Count - 1);
        currentItemIndex = idx;
        currentItemName = config.Items[idx];
    }

    private async Task LoadDashboard()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

            if (!sessionId.HasValue)
            {
                var session = await SessionService.GetByCodeAsync(SessionCode);
                if (session is null) { errorMessage = "Session not found."; return; }
                sessionId = session.Id;
            }

            dashboard = await QuadrantDashboardService.GetQuadrantDashboardAsync(
                sessionId.Value, ActivityId, new Dictionary<string, string?>());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load quadrant dashboard for {SessionCode}/{ActivityId}", SessionCode, ActivityId);
            errorMessage = $"Failed to load dashboard: {ex.Message}";
            dashboard = null;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RenderChart()
    {
        if (dashboard is null || !dashboard.Items.Any()) return;

        await Task.Delay(80); // let DOM render canvas

        var exists = await JS.InvokeAsync<bool>("eval", $"!!document.getElementById('{canvasId}')");
        if (!exists) return;

        var xOptions = config?.XScoreOptions ?? new List<ScoreOption>();
        var yOptions = config?.ResolvedYScoreOptions ?? new List<ScoreOption>();

        double xMin = xOptions.Count > 0
            ? xOptions.Min(o => o.NumericValue)
            : dashboard.Items.Min(i => i.AverageX);
        double xMax = xOptions.Count > 0
            ? xOptions.Max(o => o.NumericValue)
            : dashboard.Items.Max(i => i.AverageX);

        var chartItems = dashboard.Items.Select(i => new
        {
            label = i.ItemLabel,
            avgX = i.AverageX,
            avgY = i.AverageY,
            count = i.ResponseCount,
            isCurrent = i.ItemIndex == currentItemIndex
        }).ToList();

        await JS.InvokeVoidAsync("renderQuadrantBubbleChart",
            canvasId,
            dashboard.XAxisLabel,
            dashboard.YAxisLabel,
            chartItems,
            bubbleSizeMode == QuadrantBubbleSizeMode.Uniform,
            xMin,
            xMax,
            config?.Q1Label,
            config?.Q2Label,
            config?.Q3Label,
            config?.Q4Label);
    }

    private async Task PrevItem()
    {
        if (currentItemIndex <= 0 || isNavigating) return;
        await AdvanceToItem(currentItemIndex - 1);
    }

    private async Task NextItem()
    {
        if (config is null || currentItemIndex >= config.Items.Count - 1 || isNavigating) return;
        await AdvanceToItem(currentItemIndex + 1);
    }

    private async Task AdvanceToItem(int newIndex)
    {
        isNavigating = true;
        StateHasChanged();
        try
        {
            await HubNotificationService.PublishQuadrantItemAdvancedAsync(SessionCode, ActivityId, newIndex);
            currentItemIndex = newIndex;
            UpdateCurrentItemName();
            if (sessionId.HasValue)
            {
                try
                {
                    await MetadataService.SetValueAsync(
                        sessionId.Value, ActivityId,
                        TechWayFit.Pulse.Domain.Models.ActivityMetadataKeys.QuadrantCurrentItemIndex,
                        newIndex.ToString());
                }
                catch (Exception ex) { Logger.LogWarning(ex, "Failed to persist quadrant item index"); }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to advance quadrant item to {Index}", newIndex);
        }
        finally
        {
            isNavigating = false;
            StateHasChanged();
        }
    }

    private async Task OnBubbleSizeModeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            bubbleSizeMode = (QuadrantBubbleSizeMode)v;
            StateHasChanged();
            if (dashboard?.Items.Any() == true)
            {
                try { await RenderChart(); }
                catch (Exception ex) { Logger.LogError(ex, "Failed to re-render after bubble size change"); }
            }
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.Reconnected += async _ =>
            {
                try
                {
                    await hubConnection.InvokeAsync("Subscribe", SessionCode);
                    await InvokeAsync(async () => { await LoadDashboard(); StateHasChanged(); });
                }
                catch (Exception ex) { Logger.LogError(ex, "Reconnect re-subscribe failed"); }
            };

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async evt =>
            {
                if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    await InvokeAsync(async () => { await LoadDashboard(); StateHasChanged(); });
            });

            hubConnection.On<DashboardUpdatedEvent>("DashboardUpdated", async evt =>
            {
                if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    await InvokeAsync(async () => { await LoadDashboard(); StateHasChanged(); });
            });

            hubConnection.On<QuadrantItemAdvancedEvent>("QuadrantItemAdvanced", async evt =>
            {
                if (evt.ActivityId == ActivityId)
                {
                    await InvokeAsync(() =>
                    {
                        currentItemIndex = evt.ItemIndex;
                        UpdateCurrentItemName();
                        StateHasChanged();
                        return Task.CompletedTask;
                    });
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to setup SignalR for quadrant dashboard");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(canvasId))
                await JS.InvokeVoidAsync("destroyQuadrantBubbleChart", canvasId);
        }
        catch { }

        if (hubConnection is not null)
        {
            try { await hubConnection.DisposeAsync(); } catch { }
        }
    }
}
