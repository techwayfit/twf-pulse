@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Contracts.Responses
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using TechWayFit.Pulse.Web.Services
@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using TechWayFit.Pulse.Domain.Enums
@using System.Text.Json
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IQuadrantDashboardService QuadrantDashboardService
@inject ISessionService SessionService
@inject IHubNotificationService HubNotificationService
@inject ISessionActivityMetadataService MetadataService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ILogger<QuadrantDashboard> Logger
@implements IAsyncDisposable

<div class="quadrant-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-2 text-muted">Loading item scoring data…</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-0">@errorMessage</div>
    }
    else if (dashboard is not null)
    {
        var currentItem = dashboard.Items.FirstOrDefault(i => i.ItemIndex == currentItemIndex);
        var configuredItemCount = config?.Items?.Count ?? dashboard.Items.Count;
        var heroTitle = !string.IsNullOrWhiteSpace(currentItemName)
            ? currentItemName
            : currentItem?.ItemLabel ?? "Quadrant Mapping";

        <div class="quadrant-layout">
            <section class="quadrant-hero-card">
                <div class="quadrant-hero-copy">
                    <div class="quadrant-hero-kicker">
                        <i class="fas fa-chart-line"></i>
                        <span>Quadrant Mapping</span>
                    </div>
                    <h4 class="quadrant-hero-title">@heroTitle</h4>
                    <div class="quadrant-chip-row">
                        <span class="quadrant-chip">
                            <i class="fas fa-arrows-left-right"></i>
                            @dashboard.XAxisLabel
                        </span>
                        <span class="quadrant-chip">
                            <i class="fas fa-arrows-up-down"></i>
                            @dashboard.YAxisLabel
                        </span>
                        <span class="quadrant-chip">
                            <i class="fas fa-list-check"></i>
                            @dashboard.Items.Count items
                        </span>
                        <span class="quadrant-chip">
                            <i class="fas fa-users"></i>
                            @ParticipationRate.ToString("F0")% participation
                        </span>
                    </div>
                </div>

                <div class="quadrant-hero-pane">
                    @if (configuredItemCount > 0)
                    {
                        <div class="quadrant-current-item">
                            <span class="quadrant-current-item-label">Current Item</span>
                            <span class="quadrant-current-item-value">@(currentItemIndex + 1) / @configuredItemCount</span>
                        </div>
                        <div class="quadrant-current-stats">
                            <div class="quadrant-current-stat">
                                <span class="label">Responses</span>
                                <span class="value">@(currentItem?.ResponseCount ?? 0)</span>
                            </div>
                            <div class="quadrant-current-stat">
                                <span class="label">Avg @dashboard.XAxisLabel</span>
                                <span class="value">@(currentItem?.AverageX.ToString("F1") ?? "-")</span>
                            </div>
                            <div class="quadrant-current-stat">
                                <span class="label">Avg @dashboard.YAxisLabel</span>
                                <span class="value">@(currentItem?.AverageY.ToString("F1") ?? "-")</span>
                            </div>
                        </div>
                        <div class="quadrant-nav-row">
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="PrevItem"
                                    disabled="@(currentItemIndex <= 0 || isNavigating)">
                                <i class="fas fa-chevron-left"></i> Prev
                            </button>
                            <button class="btn btn-sm btn-primary"
                                    @onclick="NextItem"
                                    disabled="@(config == null || currentItemIndex >= config.Items.Count - 1 || isNavigating)">
                                Next <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="quadrant-pane-muted">
                            <i class="fas fa-info-circle"></i>
                            <span>Add items to start quadrant scoring.</span>
                        </div>
                    }
                </div>
            </section>



            <section class="quadrant-chart-card">
                <div class="quadrant-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-bubble me-2"></i>Bubble Chart
                    </h6>
                    <div class="quadrant-select-wrap">
                        <label class="form-label mb-0">Bubble size</label>
                        <select class="form-select form-select-sm quadrant-select" @onchange="OnBubbleSizeModeChanged">
                            <option value="0" selected="@(bubbleSizeMode == QuadrantBubbleSizeMode.Proportional)">Proportional to responses</option>
                            <option value="1" selected="@(bubbleSizeMode == QuadrantBubbleSizeMode.Uniform)">Uniform</option>
                        </select>
                    </div>
                </div>

                <div class="quadrant-chart-canvas">
                    @if (dashboard.Items.Any())
                    {
                        <canvas id="@canvasId"></canvas>
                    }
                    else
                    {
                        <div class="quadrant-empty-state">
                            <i class="fas fa-chart-bubble"></i>
                            <span>No responses yet — chart will appear as participants score items.</span>
                        </div>
                    }
                </div>
            </section>

            @if (dashboard.Items.Any())
            {
                <section class="quadrant-table-card">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Item</th>
                                    <th>Avg @dashboard.XAxisLabel</th>
                                    <th>Avg @dashboard.YAxisLabel</th>
                                    <th>Responses</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in dashboard.Items)
                                {
                                    <tr class="@(item.ItemIndex == currentItemIndex ? "quadrant-table-row--active" : string.Empty)">
                                        <td class="text-muted">@(item.ItemIndex + 1)</td>
                                        <td>@item.ItemLabel</td>
                                        <td>@item.AverageX.ToString("F1")</td>
                                        <td>@item.AverageY.ToString("F1")</td>
                                        <td><span class="badge bg-secondary">@item.ResponseCount</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        </div>
    }
</div>

