@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IPollDashboardService PollDashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<PollDashboard> Logger
@implements IAsyncDisposable

<div class="poll-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading poll results...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    }
    else if (dashboard != null)
    {
        var participationRate = GetParticipationRate();
        var topResult = dashboard.Results
            .OrderByDescending(r => r.Count)
            .ThenBy(r => r.Label)
            .FirstOrDefault();

        <div class="poll-layout">
            <section class="poll-hero-card">
                <div class="poll-hero-copy">
                    <div class="poll-hero-kicker">
                        <i class="fas fa-list-ul"></i>
                        <span>Live Poll</span>
                    </div>
                    <h4 class="poll-hero-title">@dashboard.ActivityTitle</h4>
                    <div class="poll-chip-row">
                        <span class="poll-chip">
                            <i class="fas fa-list-check"></i>
                            @dashboard.Results.Count options
                        </span>
                        <span class="poll-chip">
                            <i class="fas fa-reply"></i>
                            @dashboard.TotalResponses responses
                        </span>
                        <span class="poll-chip">
                            <i class="fas fa-users"></i>
                            @dashboard.RespondedParticipants participants
                        </span>
                        <span class="poll-chip">
                            <i class="fas fa-chart-line"></i>
                            @participationRate% participation
                        </span>
                    </div>
                </div>

                <div class="poll-hero-pane">
                    <div class="poll-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="poll-updated-at">
                        @if (dashboard.LastResponseAt.HasValue)
                        {
                            <span>Last updated: @dashboard.LastResponseAt.Value.ToString("HH:mm:ss")</span>
                        }
                        else
                        {
                            <span>No responses yet</span>
                        }
                    </div>

                    @if (topResult is not null && topResult.Count > 0)
                    {
                        <div class="poll-top-answer">
                            <span class="label">Leading option</span>
                            <span class="value">@topResult.Label</span>
                            <span class="meta">@topResult.Count votes (@topResult.Percentage.ToString("F1")%)</span>
                        </div>
                    }
                    else
                    {
                        <div class="poll-pane-muted">
                            <i class="fas fa-hourglass-half"></i>
                            <span>Waiting for participants to vote.</span>
                        </div>
                    }
                </div>
            </section>
           

            <section class="poll-distribution-card">
                <div class="poll-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-bar me-2"></i>Vote Distribution
                    </h6>
                </div>

                @if (dashboard.Results.Any())
                {
                    <div class="poll-results">
                        @foreach (var result in dashboard.Results)
                        {
                            <article class="poll-result-row">
                                <div class="poll-result-head">
                                    <div class="option-label">@result.Label</div>
                                    <div class="poll-result-values">
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@result.Count votes</span>
                                        <span class="percentage">@result.Percentage.ToString("F1")%</span>
                                    </div>
                                </div>
                                <div class="progress poll-progress">
                                    <div class="progress-bar"
                                         role="progressbar"
                                         style="width: @result.Percentage%"
                                         aria-valuenow="@result.Percentage"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="poll-empty-state">
                        <i class="fas fa-chart-bar"></i>
                        <div>
                            <div class="fw-semibold">No responses yet</div>
                            <div class="small text-muted">Results will appear here once participants start voting.</div>
                        </div>
                    </div>
                }
            </section>

            <section class="poll-chart-card">
                <div class="poll-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-pie me-2"></i>Visual Chart
                    </h6>
                </div>
                <div class="poll-chart-canvas">
                    @if (dashboard.Results.Any())
                    {
                        <canvas id="@canvasId"></canvas>
                    }
                    else
                    {
                        <div class="poll-empty-state">
                            <i class="fas fa-chart-pie"></i>
                            <span>Chart will appear once options receive votes.</span>
                        </div>
                    }
                </div>
            </section>

        </div>
    }
</div>

