@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using TechWayFit.Pulse.Web.Services
@using System.Text.Json
@using Markdig
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject ISessionService SessionService
@inject IActivityService ActivityService
@inject ISessionAIService SessionAIService
@inject IHubNotificationService HubNotifications
@inject NavigationManager Navigation
@inject ILogger<AiSummaryDashboard> Logger
@implements IAsyncDisposable

<div class="ai-summary-dashboard">
    @if (isLoading)
    {
        <div class="ai-summary-state-card text-center py-4">
            <div class="spinner-border text-primary mb-2" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="text-muted">Loading summary data...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-0">
            <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else if (isStreaming || (!string.IsNullOrEmpty(streamingContent) && string.IsNullOrEmpty(config?.GeneratedSummary)))
    {
        <div class="ai-summary-shell">
            <section class="ai-summary-hero">
                <div class="ai-summary-hero-copy">
                    <div class="ai-summary-kicker"><i class="fas fa-robot"></i> AI Summary</div>
                    <h5 class="ai-summary-title mb-0">Generating Live Summary</h5>
                    <div class="ai-summary-sub">Streaming response from AI...</div>

                    <div class="ai-summary-chip-row">
                        <span class="ai-summary-chip">
                            <i class="fas fa-wave-square"></i>Live stream
                        </span>
                        <span class="ai-summary-chip">
                            <i class="fas fa-font"></i>@StreamingWordCount words
                        </span>
                        <span class="ai-summary-chip">
                            <i class="fas fa-list-ul"></i>@StreamingBulletCount bullets
                        </span>
                    </div>
                </div>

                <div class="ai-summary-hero-side">
                    <div class="ai-summary-hero-side-label">Status</div>
                    <div class="ai-summary-hero-side-value">
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>Streaming</span>
                    </div>
                </div>
            </section>

            <div class="ai-summary-metrics">
                <article class="ai-metric-card">
                    <div class="label">Words</div>
                    <div class="value">@StreamingWordCount</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">Read Time</div>
                    <div class="value">@StreamingReadMinutes min</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">Bullets</div>
                    <div class="value">@StreamingBulletCount</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">State</div>
                    <div class="value">Draft</div>
                </article>
            </div>

            <div class="summary-preview ai-summary-content">
                <div class="prose summary-prose">
                    @((MarkupString)RenderMarkdown(streamingContent))
                </div>
            </div>
        </div>
    }
    else if (config?.IsGenerating == true)
    {
        <div class="ai-summary-state-card text-center py-4">
            <div class="ai-generating-icon mb-3">
                <i class="fas fa-sparkles"></i>
            </div>
            <p class="fw-semibold mb-1">AI is generating the session summary...</p>
            <p class="text-muted small mb-0">The summary will appear automatically when ready.</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(config?.GeneratedSummary))
    {
        <div class="ai-summary-shell">
            <section class="ai-summary-hero">
                <div class="ai-summary-hero-copy">
                    <div class="ai-summary-kicker"><i class="fas fa-robot"></i> AI Summary</div>
                    <h5 class="ai-summary-title mb-0">Generated Summary</h5>
                    @if (config.GeneratedAt.HasValue)
                    {
                        <div class="ai-summary-sub">Generated at @config.GeneratedAt.Value.ToLocalTime().ToString("HH:mm")</div>
                    }

                    <div class="ai-summary-chip-row">
                        <span class="ai-summary-chip">
                            <i class="fas fa-font"></i>@SummaryWordCount words
                        </span>
                        <span class="ai-summary-chip">
                            <i class="fas fa-book-open"></i>@SummaryReadMinutes min read
                        </span>
                        <span class="ai-summary-chip">
                            <i class="fas fa-list-ul"></i>@SummaryBulletCount bullets
                        </span>
                    </div>
                </div>

                <div class="ai-summary-hero-side">
                    <div class="ai-summary-hero-side-label">Last Generated</div>
                    <div class="ai-summary-hero-side-time">@GeneratedTimeLabel</div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="TriggerGenerationAsync" disabled="@isGenerating">
                        @if (isGenerating)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <text>Regenerating...</text>
                        }
                        else
                        {
                            <i class="fas fa-rotate-right me-1"></i>
                            <text>Regenerate</text>
                        }
                    </button>
                </div>
            </section>

            <div class="ai-summary-metrics">
                <article class="ai-metric-card">
                    <div class="label">Words</div>
                    <div class="value">@SummaryWordCount</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">Read Time</div>
                    <div class="value">@SummaryReadMinutes min</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">Bullets</div>
                    <div class="value">@SummaryBulletCount</div>
                </article>
                <article class="ai-metric-card">
                    <div class="label">Breakdown</div>
                    <div class="value">@((config?.ShowActivityBreakdown ?? true) ? "On" : "Off")</div>
                </article>
            </div>

            <div class="summary-preview ai-summary-content">
                <div class="prose summary-prose">
                    @((MarkupString)RenderMarkdown(config?.GeneratedSummary ?? string.Empty))
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="ai-summary-state-card text-center py-4">
            <i class="fas fa-robot ic-xl text-muted mb-3 d-block"></i>
            <p class="fw-semibold mb-1">No summary generated yet</p>
            <p class="text-muted small mb-3">Generate an AI summary of completed activities.</p>
            <button class="btn btn-primary" @onclick="TriggerGenerationAsync" disabled="@isGenerating">
                @if (isGenerating)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <text>Generating...</text>
                }
                else
                {
                    <i class="fas fa-robot  ic-sm ic-mr"></i>
                    <text>Generate AI Summary</text>
                }
            </button>
        </div>
    }
</div>

