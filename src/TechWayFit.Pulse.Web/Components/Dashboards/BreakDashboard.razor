</style>

@code {
    [Parameter] public string SessionCode { get; set; } = string.Empty;
    [Parameter] public Guid ActivityId { get; set; }

    private BreakConfig? config;
    private int readyCount = 0;
    private int totalParticipants = 0;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private HubConnection? hubConnection;
    private Guid? sessionId;
    private int remainingSeconds = 0;

    private int ReadyPercent => totalParticipants > 0
        ? Math.Clamp((int)Math.Round(readyCount * 100.0 / totalParticipants, 0), 0, 100)
        : 0;

    private int ParticipantsRemaining => Math.Max(0, totalParticipants - readyCount);
    private bool IsEveryoneBack => totalParticipants > 0 && readyCount >= totalParticipants;
    private string BreakMessage => string.IsNullOrWhiteSpace(config?.Message)
        ? "Take a short break. We'll resume shortly!"
        : config!.Message!;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await SetupSignalRAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && config?.ShowCountdown == true && remainingSeconds > 0)
        {
            try
            {
                await JS.InvokeVoidAsync("window.startBreakCountdown",
                    $"break-facilitator-countdown-{ActivityId}",
                    remainingSeconds);
            }
            catch
            {
                // Ignore JS interop errors during prerender
            }
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var session = await SessionService.GetByCodeAsync(SessionCode);
            if (session is null)
            {
                errorMessage = "Session not found.";
                return;
            }
            sessionId = session.Id;

            // Load config
            var agenda = await ActivityService.GetAgendaAsync(session.Id);
            var activity = agenda.FirstOrDefault(a => a.Id == ActivityId);
            if (activity is not null && !string.IsNullOrEmpty(activity.Config))
            {
                try
                {
                    config = JsonSerializer.Deserialize<BreakConfig>(activity.Config,
                        new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }
                catch
                {
                    config = new BreakConfig();
                }
            }
            else
            {
                config = new BreakConfig();
            }

            // Compute remaining seconds from persisted start time
            if (config?.ShowCountdown == true && config.DurationMinutes > 0)
            {
                var totalSecs = config.DurationMinutes * 60;
                var storedAt = await MetadataService.GetValueAsync(session.Id, ActivityId, ActivityMetadataKeys.BreakStartedAt);
                if (!string.IsNullOrEmpty(storedAt) && DateTimeOffset.TryParse(storedAt, out var startedAt))
                {
                    var elapsed = (int)(DateTimeOffset.UtcNow - startedAt).TotalSeconds;
                    remainingSeconds = Math.Max(0, totalSecs - elapsed);
                }
                else
                {
                    remainingSeconds = totalSecs;
                }
            }

            // Load ready count
            var responses = await ResponseService.GetByActivityAsync(ActivityId);
            readyCount = responses.Count;

            // Load total participant count
            var participants = await ParticipantService.GetBySessionAsync(session.Id);
            totalParticipants = participants.Count;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load break data: {ex.Message}";
            Logger.LogError(ex, "Failed to load BreakDashboard for {SessionCode}/{ActivityId}", SessionCode, ActivityId);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SetupSignalRAsync()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.Reconnected += async _ =>
            {
                try
                {
                    await hubConnection.InvokeAsync("Subscribe", SessionCode);
                    await InvokeAsync(async () =>
                    {
                        await LoadDataAsync();
                        StateHasChanged();
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to re-subscribe BreakDashboard after reconnect");
                }
            };

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async (e) =>
            {
                if (e.SessionCode == SessionCode && e.ActivityId == ActivityId)
                {
                    await InvokeAsync(() =>
                    {
                        readyCount++;
                        StateHasChanged();
                        return Task.CompletedTask;
                    });
                }
            });

            hubConnection.On<ParticipantJoinedEvent>("ParticipantJoined", async (e) =>
            {
                if (e.SessionCode == SessionCode)
                {
                    await InvokeAsync(() =>
                    {
                        totalParticipants = e.TotalParticipantCount;
                        StateHasChanged();
                        return Task.CompletedTask;
                    });
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to setup SignalR for BreakDashboard");
        }
    }

    private string GetReadyRingStyle()
        => $"background: conic-gradient(var(--pulse-success) 0% {ReadyPercent}%, #d9e7ea {ReadyPercent}% 100%);";

    private static string FormatDurationFromSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try { await hubConnection.DisposeAsync(); }
            catch { }
        }
    }
}
