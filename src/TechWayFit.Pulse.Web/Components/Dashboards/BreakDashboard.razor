    }

    .break-dashboard .break-hero-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        width: fit-content;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #9a5f00;
        padding: 0.25rem 0.55rem;
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.16);
    }

    .break-dashboard .break-hero-title {
        margin: 0;
        font-size: 1.65rem;
        line-height: 1.2;
