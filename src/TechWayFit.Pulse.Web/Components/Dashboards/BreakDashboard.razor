@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Domain.Models
@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using System.Text.Json
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject ISessionService SessionService
@inject IActivityService ActivityService
@inject IResponseService ResponseService
@inject IParticipantService ParticipantService
@inject ISessionActivityMetadataService MetadataService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<BreakDashboard> Logger
@implements IAsyncDisposable

<div class="break-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-0">
            <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else
    {
        <div class="break-layout">
            <section class="break-hero-card">
                <div class="break-hero-copy">
                    <div class="break-hero-kicker">
                        <i class="fas fa-mug-hot"></i>
                        <span>Break Time</span>
                    </div>
                    <h4 class="break-hero-title">@BreakMessage</h4>
                    <div class="break-chip-row">
                        <span class="break-chip">
                            <i class="far fa-clock"></i>
                            @(config?.DurationMinutes ?? 0) min
                        </span>
                        @if (config?.AllowReadySignal == true)
                        {
                            <span class="break-chip">
                                <i class="fas fa-hand-paper"></i>
                                Ready signal on
                            </span>
                        }
                        @if (config?.ShowCountdown == true)
                        {
                            <span class="break-chip">
                                <i class="fas fa-hourglass-half"></i>
                                Countdown visible
                            </span>
                        }
                    </div>
                </div>

                <div class="break-hero-timer-pane">
                    @if (config?.ShowCountdown == true && config.DurationMinutes > 0)
                    {
                        <div class="break-facilitator-timer" id="break-facilitator-countdown-@ActivityId">
                            <span class="timer-label">Time Remaining</span>
                            <span class="timer-value">@FormatDurationFromSeconds(remainingSeconds)</span>
                        </div>
                    }
                    else
                    {
                        <div class="break-timer-muted">
                            <i class="fas fa-eye-slash"></i>
                            <span>Countdown hidden for participants</span>
                        </div>
                    }
                </div>
            </section>

            @if (config?.AllowReadySignal == true)
            {
                <section class="break-status-grid">
                    <article class="break-ready-card">
                        <div class="break-ready-head">
                            <h6 class="mb-0 fw-semibold">
                                <i class="fas fa-users me-2"></i>Participants Ready
                            </h6>
                            <span class="badge bg-success fs-6 px-3">@readyCount / @totalParticipants</span>
                        </div>

                        <div class="break-ready-content">
                            <div class="break-ready-ring" style="@GetReadyRingStyle()">
                                <div class="break-ready-ring-inner">@ReadyPercent%</div>
                            </div>

                            <div class="break-ready-metrics">
                                <div class="break-ready-metric">
                                    <div class="label">Back now</div>
                                    <div class="value">@readyCount</div>
                                </div>
                                <div class="break-ready-metric">
                                    <div class="label">Pending</div>
                                    <div class="value">@ParticipantsRemaining</div>
                                </div>
                                <div class="break-ready-metric">
                                    <div class="label">Total</div>
                                    <div class="value">@totalParticipants</div>
                                </div>
                            </div>
                        </div>

                        @if (totalParticipants > 0)
                        {
                            <div class="progress break-ready-progress">
                                <div class="progress-bar bg-success"
                                     role="progressbar"
                                     style="width: @ReadyPercent%;"
                                     aria-valuenow="@readyCount"
                                     aria-valuemin="0"
                                     aria-valuemax="@totalParticipants">
                                </div>
                            </div>
                            <div class="text-muted small">@ReadyPercent% back from break</div>
                        }
                        @if (readyCount == 0)
                        {
                            <div class="text-muted small mt-2">
                                <i class="fas fa-hourglass-half me-1"></i>Waiting for participants to signal they're back...
                            </div>
                        }
                        else if (IsEveryoneBack)
                        {
                            <div class="alert alert-success mb-0 mt-2 py-2">
                                <i class="fas fa-check-circle me-2"></i>All participants are back. You can resume the session.
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small mt-2">
                                <i class="fas fa-user-clock me-1"></i>@ParticipantsRemaining participant(s) still returning.
                            </div>
                        }
                    </article>
                </section>
            }
            else
            {
                <section class="break-guidance-card break-guidance-card--full">
                    <div class="break-guidance-title">
                        <i class="fas fa-info-circle me-2"></i>Ready signal is disabled
                    </div>
                    <p class="mb-0 text-muted">Participants are on break. Resume whenever you're ready.</p>
                </section>
            }
        </div>
    }
</div>

