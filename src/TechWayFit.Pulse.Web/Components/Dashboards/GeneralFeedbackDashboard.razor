@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IGeneralFeedbackDashboardService GeneralFeedbackDashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<GeneralFeedbackDashboard> Logger
@implements IAsyncDisposable

<div class="feedback-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading feedback responses...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    }
    else if (dashboard != null)
    {
        var participationRate = GetParticipationRate();
        var sortedResponses = GetSortedResponses().ToList();
        var keywordStats = GetTopKeywords();
        var topKeyword = keywordStats.FirstOrDefault();
        var trendingWords = keywordStats.Take(10).ToList();
        var latestFeedback = dashboard.Feedbacks
            .OrderByDescending(f => f.CreatedAt)
            .FirstOrDefault();

        <div class="feedback-layout">
            <section class="feedback-hero-card">
                <div class="feedback-hero-copy">
                    <div class="feedback-hero-kicker">
                        <i class="fas fa-comments"></i>
                        <span>Live Feedback</span>
                    </div>
                    <h4 class="feedback-hero-title">@dashboard.ActivityTitle</h4>
                    <div class="feedback-chip-row">
                        <span class="feedback-chip">
                            <i class="fas fa-reply"></i>
                            @dashboard.TotalResponses responses
                        </span>
                        <span class="feedback-chip">
                            <i class="fas fa-users"></i>
                            @dashboard.RespondedParticipants/@dashboard.ParticipantCount participants
                        </span>
                        <span class="feedback-chip">
                            <i class="fas fa-chart-line"></i>
                            @participationRate% participation
                        </span>
                        <span class="feedback-chip">
                            <i class="fas fa-font"></i>
                            Avg @GetAverageWordCount() words
                        </span>
                    </div>
                </div>

                <div class="feedback-hero-pane">
                    <div class="feedback-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="feedback-updated-at">
                        @if (dashboard.LastResponseAt.HasValue)
                        {
                            <span>Last updated: @dashboard.LastResponseAt.Value.ToString("HH:mm:ss")</span>
                        }
                        else
                        {
                            <span>No responses yet</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(topKeyword.Word) && topKeyword.Count > 0)
                    {
                        <div class="feedback-highlight">
                            <span class="label">Top keyword</span>
                            <span class="value">#@topKeyword.Word</span>
                            <span class="meta">@topKeyword.Count mentions</span>
                        </div>
                    }
                </div>
            </section>

            <section class="feedback-responses-card">
                <div class="feedback-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-message me-2"></i>All Responses
                    </h6>
                    <div class="feedback-sort-switch" role="group" aria-label="Sort feedback responses">
                        <button class="feedback-sort-btn @(sortOrder == "recent" ? "is-active" : "")"
                                @onclick='() => sortOrder = "recent"'>
                            <i class="fas fa-clock"></i>
                            Most Recent
                        </button>
                        <button class="feedback-sort-btn @(sortOrder == "longest" ? "is-active" : "")"
                                @onclick='() => sortOrder = "longest"'>
                            <i class="fas fa-sort-amount-down"></i>
                            Longest First
                        </button>
                    </div>
                </div>

                @if (dashboard.TotalResponses > 0)
                {
                    <div class="feedback-list">
                        @{
                            var responseIndex = 0;
                        }
                        @foreach (var feedback in sortedResponses)
                        {
                            responseIndex++;
                            var sentiment = GetSentimentFromCategory(feedback.Category);
                            var keywords = ExtractKeywords(feedback.Content);

                            <article class="feedback-card">
                                <div class="feedback-card-header">
                                    <div class="participant-avatar">P@(responseIndex)</div>
                                    <div class="feedback-card-meta">
                                        <div class="feedback-card-title-row">
                                            <span class="participant-label">Participant</span>
                                            <span class="feedback-timestamp">@GetRelativeTime(feedback.CreatedAt) · @feedback.WordCount words</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(sentiment))
                                        {
                                            <span class="feedback-sentiment @GetSentimentCssClass(sentiment)">@sentiment</span>
                                        }
                                    </div>
                                </div>

                                <p class="feedback-text">@feedback.Content</p>

                                @if (keywords.Any())
                                {
                                    <div class="feedback-tags">
                                        @foreach (var keyword in keywords.Take(5))
                                        {
                                            <span class="feedback-tag">#@keyword</span>
                                        }
                                    </div>
                                }
                            </article>
                        }
                    </div>

                    @if (displayCount < dashboard.Feedbacks.Count)
                    {
                        <div class="feedback-load-more">
                            <button class="feedback-load-more-btn" @onclick="LoadMore">
                                Load More (@(dashboard.Feedbacks.Count - displayCount) remaining)
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="feedback-empty-state">
                        <i class="fas fa-inbox"></i>
                        <div>
                            <div class="fw-semibold">No feedback yet</div>
                            <div class="small text-muted">Responses will appear here once participants start sharing.</div>
                        </div>
                    </div>
                }
            </section>

            @if (dashboard.TotalResponses > 0)
            {
                <section class="feedback-trending-card">
                    <div class="feedback-section-head">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-fire me-2"></i>Trending Keywords
                        </h6>
                        <span class="feedback-section-note">Top @trendingWords.Count</span>
                    </div>

                    @if (trendingWords.Any())
                    {
                        <div class="trending-keywords">
                            @foreach (var keyword in trendingWords)
                            {
                                <span class="trending-badge">#@keyword.Word <small>@keyword.Count</small></span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="feedback-empty-state">
                            <i class="fas fa-tags"></i>
                            <span>Keywords will appear once responses are available.</span>
                        </div>
                    }
                </section>
            }
        </div>
    }
</div>

