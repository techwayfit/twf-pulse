@code {
    [Parameter] public string SessionCode { get; set; } = string.Empty;
    [Parameter] public Guid ActivityId { get; set; }

    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private WordCloudDashboardResponse? dashboard;
    private HubConnection? hubConnection;
    private string viewType = "cloud";
    private bool shouldRenderVisualization;
    private string? lastLoadedSessionCode;
    private Guid lastLoadedActivityId;

    private class WordData
    {
        public string Text { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    private class ChartData
    {
        public string Label { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        await InitializeSignalR();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ActivityId == Guid.Empty || string.IsNullOrWhiteSpace(SessionCode))
        {
            return;
        }

        if (!string.Equals(lastLoadedSessionCode, SessionCode, StringComparison.OrdinalIgnoreCase)
            || lastLoadedActivityId != ActivityId)
        {
            await LoadDashboard();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldRenderVisualization)
        {
            return;
        }

        shouldRenderVisualization = false;

        if (dashboard?.WordFrequencies?.Any() == true && (viewType == "cloud" || viewType == "chart"))
        {
            // Wait longer for canvas to be fully rendered in DOM (especially on slow connections)
            await Task.Delay(500);
            await RenderVisualization();
        }
    }

    private async Task LoadDashboard()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            // Get session by code
            var session = await SessionService.GetByCodeAsync(SessionCode);
            if (session is null)
            {
                errorMessage = "Session not found.";
                return;
            }

            var filters = new Dictionary<string, string?>();
            dashboard = await WordCloudDashboardService.GetWordCloudDashboardAsync(session.Id, ActivityId, filters);
            lastLoadedSessionCode = SessionCode;
            lastLoadedActivityId = ActivityId;
            shouldRenderVisualization = true;
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error loading word cloud dashboard for activity {ActivityId}: {StatusCode}", ActivityId, ex.Message);
            errorMessage = $"Failed to load dashboard: {ex.Message}";
            dashboard = null;
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogError(ex, "Invalid operation loading word cloud dashboard for activity {ActivityId}", ActivityId);
            errorMessage = ex.Message;
            dashboard = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error loading word cloud dashboard for activity {ActivityId}", ActivityId);
            errorMessage = $"Failed to load dashboard: {ex.Message}";
            dashboard = null;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.Reconnected += async _ =>
            {
                try
                {
                    await hubConnection.InvokeAsync("Subscribe", SessionCode);
                    await InvokeAsync(async () =>
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to re-subscribe WordCloud dashboard after reconnect");
                }
            };

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async (responseEvent) =>
            {
                Logger.LogInformation("WordCloud received ResponseReceived event: SessionCode={SessionCode}, ActivityId={ActivityId}", 
                    responseEvent.SessionCode, responseEvent.ActivityId);
                    
                if (string.Equals(responseEvent.SessionCode, SessionCode, StringComparison.OrdinalIgnoreCase) 
                    && responseEvent.ActivityId == ActivityId)
                {
                    Logger.LogInformation("WordCloud updating for matching activity {ActivityId}", ActivityId);
                    await InvokeAsync(async () =>
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    });
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize SignalR connection");
        }
    }

    private async Task SetViewType(string type)
    {
        Logger.LogInformation("Switching view type to: {ViewType}", type);
        viewType = type;
        shouldRenderVisualization = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task RenderVisualization()
    {
        Logger.LogInformation("RenderVisualization called for viewType: {ViewType}, HasData: {HasData}", 
            viewType, dashboard?.WordFrequencies?.Any() ?? false);
            
        if (dashboard?.WordFrequencies?.Any() != true)
            return;

        try
        {
            if (viewType == "cloud")
            {
                await RenderWordCloud();
            }
            else if (viewType == "chart")
            {
                await RenderChart();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render visualization");
        }
    }

    private async Task RenderWordCloud()
    {
        var canvasId = $"wordcloud-{ActivityId}";
 
        Logger.LogInformation("RenderWordCloud called for canvas {CanvasId}", canvasId);
    
      // Verify canvas exists in DOM before attempting render
        var canvasExists = await JS.InvokeAsync<bool>("eval", $"!!document.getElementById('{canvasId}')");
        if (!canvasExists)
    {
    Logger.LogWarning("Canvas {CanvasId} not found in DOM", canvasId);
     return;
        }

        var words = dashboard?.WordFrequencies?
     .Select(w => new { text = w.Text, count = w.Count }) // Use lowercase properties for JS
         .ToArray();
        
        if (words?.Any() != true)
        {
            Logger.LogWarning("No word data to render for canvas {CanvasId}", canvasId);
    return;
      }

        Logger.LogInformation("Calling renderWordCloud with {Count} words", words.Length);
      
        try
        {
            await JS.InvokeVoidAsync("renderWordCloud", canvasId, words);
  Logger.LogInformation("Successfully called renderWordCloud");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to call renderWordCloud JavaScript function");
     }
    }

    private async Task RenderChart()
    {
        var chartId = $"wordcloud-chart-{ActivityId}";
  
        Logger.LogInformation("RenderChart called for {ChartId}", chartId);
        
        // Verify canvas exists
        var canvasExists = await JS.InvokeAsync<bool>("eval", $"!!document.getElementById('{chartId}')");
        if (!canvasExists)
   {
            Logger.LogWarning("Chart canvas {ChartId} not found in DOM", chartId);
 return;
  }

        var data = dashboard?.WordFrequencies?
    .Take(10)
      .Select(w => new { label = w.Text, count = w.Count }) // Use lowercase for JS
   .ToArray();
    
        if (data?.Any() != true)
      {
     Logger.LogWarning("No chart data for {ChartId}", chartId);
       return;
 }

        Logger.LogInformation("Calling renderWordCloudChart with {Count} items", data.Length);
        
        try
 {
      await JS.InvokeVoidAsync("renderWordCloudChart", chartId, data);
     Logger.LogInformation("Successfully called renderWordCloudChart");
        }
        catch (Exception ex)
        {
Logger.LogError(ex, "Failed to call renderWordCloudChart JavaScript function");
   }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            try
            {
                await hubConnection.InvokeAsync("Unsubscribe", SessionCode);
            }
            catch
            {
                // Ignore errors during cleanup
            }
            await hubConnection.DisposeAsync();
        }
    }
}
