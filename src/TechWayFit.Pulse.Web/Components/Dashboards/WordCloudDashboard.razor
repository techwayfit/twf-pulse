@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Contracts.Models
@using TechWayFit.Pulse.Application.Abstractions.Services
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IWordCloudDashboardService WordCloudDashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<WordCloudDashboard> Logger
@implements IAsyncDisposable

<div class="wordcloud-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading word cloud results...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    }
    else if (dashboard != null)
    {
        var participationRate = dashboard.ParticipantCount > 0
            ? (int)Math.Round(dashboard.RespondedParticipants * 100.0 / dashboard.ParticipantCount)
            : 0;
        var topWord = dashboard.WordFrequencies
            .OrderByDescending(w => w.Count)
            .ThenBy(w => w.Text)
            .FirstOrDefault();

        <div class="wordcloud-layout">
            <section class="wordcloud-hero-card">
                <div class="wordcloud-hero-copy">
                    <div class="wordcloud-hero-kicker">
                        <i class="fas fa-cloud"></i>
                        <span>Word Cloud</span>
                    </div>
                    <h4 class="wordcloud-hero-title">@dashboard.ActivityTitle</h4>
                    <div class="wordcloud-chip-row">
                        <span class="wordcloud-chip">
                            <i class="fas fa-reply"></i>
                            @dashboard.TotalResponses responses
                        </span>
                        <span class="wordcloud-chip">
                            <i class="fas fa-users"></i>
                            @dashboard.RespondedParticipants participants
                        </span>
                        <span class="wordcloud-chip">
                            <i class="fas fa-font"></i>
                            @dashboard.TotalWords words
                        </span>
                        <span class="wordcloud-chip">
                            <i class="fas fa-fingerprint"></i>
                            @dashboard.UniqueWords unique
                        </span>
                    </div>
                </div>

                <div class="wordcloud-hero-pane">
                    <div class="wordcloud-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="wordcloud-updated-at">
                        @if (dashboard.LastResponseAt.HasValue)
                        {
                            <span>Last updated: @dashboard.LastResponseAt.Value.ToString("HH:mm:ss")</span>
                        }
                        else
                        {
                            <span>No responses yet</span>
                        }
                    </div>

                    @if (topWord is not null)
                    {
                        <div class="wordcloud-top-word">
                            <span class="label">Top word</span>
                            <span class="value">@topWord.Text</span>
                            <span class="meta">@topWord.Count mentions</span>
                        </div>
                    }
                    else
                    {
                        <div class="wordcloud-pane-muted">
                            <i class="fas fa-hourglass-half"></i>
                            <span>Waiting for participant responses.</span>
                        </div>
                    }
                </div>
            </section>


            <section class="wordcloud-visualization-card">
                <div class="wordcloud-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-area me-2"></i>Word Frequencies
                    </h6>
                    <div class="wordcloud-view-toggle">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary @(viewType == "cloud" ? "active" : string.Empty)"
                                @onclick="@(async () => await SetViewType("cloud"))">
                            <i class="fas fa-cloud me-1"></i>Cloud
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary @(viewType == "chart" ? "active" : string.Empty)"
                                @onclick="@(async () => await SetViewType("chart"))">
                            <i class="fas fa-chart-bar me-1"></i>Chart
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary @(viewType == "list" ? "active" : string.Empty)"
                                @onclick="@(async () => await SetViewType("list"))">
                            <i class="fas fa-list me-1"></i>List
                        </button>
                    </div>
                </div>

                @if (dashboard.WordFrequencies.Any())
                {
                    @if (viewType == "cloud")
                    {
                        <div class="wordcloud-canvas-shell">
                            <canvas id="wordcloud-@ActivityId"></canvas>
                        </div>
                    }
                    else if (viewType == "chart")
                    {
                        <div class="wordcloud-canvas-shell">
                            <canvas id="wordcloud-chart-@ActivityId"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="wordcloud-list-grid">
                            @foreach (var word in dashboard.WordFrequencies.Take(20))
                            {
                                <article class="wordcloud-list-item">
                                    <span class="word">@word.Text</span>
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@word.Count</span>
                                </article>
                            }
                        </div>

                        @if (dashboard.WordFrequencies.Count > 20)
                        {
                            <div class="text-center mt-3">
                                <small class="text-muted">Showing top 20 words out of @dashboard.WordFrequencies.Count unique words</small>
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="wordcloud-empty-state">
                        <i class="fas fa-cloud"></i>
                        <div>
                            <div class="fw-semibold">No words to display yet</div>
                            <div class="small text-muted">Word cloud will appear as participants submit their responses.</div>
                        </div>
                    </div>
                }
            </section>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="fas fa-cloud fa-3x text-muted"></i>
            </div>
            <h6 class="text-muted">No data available</h6>
        </div>
    }
</div>

