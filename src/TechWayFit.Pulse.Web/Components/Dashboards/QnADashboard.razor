@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@namespace TechWayFit.Pulse.Web.Components.Dashboards
@inject IQnADashboardService QnADashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@inject ILogger<QnADashboard> Logger
@implements IAsyncDisposable

<div class="qna-dashboard">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3">Loading questions...</div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger py-2">
            <i class="fas fa-exclamation-triangle me-1"></i>@errorMessage
        </div>
    }
    else if (dashboard != null)
    {
        var sortedQuestions = GetSortedQuestions().ToList();
        var participationRate = GetParticipationRate();
        var unansweredCount = dashboard.Questions.Count(q => !q.IsAnswered);
        var answeredCount = dashboard.TotalQuestions - unansweredCount;
        var avgVotesPerQuestion = dashboard.TotalQuestions > 0
            ? ((double)dashboard.TotalVotes / dashboard.TotalQuestions).ToString("F1")
            : "0.0";
        var topQuestion = dashboard.Questions
            .OrderBy(q => q.IsAnswered ? 1 : 0)
            .ThenByDescending(q => q.UpvoteCount)
            .ThenBy(q => q.SubmittedAt)
            .FirstOrDefault();

        <div class="qna-layout">
            <section class="qna-hero-card">
                <div class="qna-hero-copy">
                    <div class="qna-hero-kicker">
                        <i class="fas fa-question-circle"></i>
                        <span>Live Q&A</span>
                    </div>
                    <h4 class="qna-hero-title">@dashboard.ActivityTitle</h4>
                    <div class="qna-chip-row">
                        <span class="qna-chip">
                            <i class="fas fa-comments"></i>
                            @dashboard.TotalQuestions questions
                        </span>
                        <span class="qna-chip">
                            <i class="fas fa-thumbs-up"></i>
                            @dashboard.TotalVotes upvotes
                        </span>
                        <span class="qna-chip">
                            <i class="fas fa-users"></i>
                            @dashboard.RespondedParticipants/@dashboard.ParticipantCount participants
                        </span>
                        <span class="qna-chip">
                            <i class="fas fa-chart-line"></i>
                            @participationRate% participation
                        </span>
                    </div>
                </div>

                <div class="qna-hero-pane">
                    <div class="qna-live-badge">
                        <i class="fas fa-circle"></i>
                        <span>Live Results</span>
                    </div>
                    <div class="qna-updated-at">
                        @if (dashboard.LastResponseAt.HasValue)
                        {
                            <span>Last updated: @dashboard.LastResponseAt.Value.ToString("HH:mm:ss")</span>
                        }
                        else
                        {
                            <span>No responses yet</span>
                        }
                    </div>

                    @if (topQuestion is not null)
                    {
                        <div class="qna-top-question">
                            <span class="label">Most relevant question</span>
                            <span class="value">@GetPreviewText(topQuestion.Text, 110)</span>
                            <span class="meta">@topQuestion.UpvoteCount upvotes @(topQuestion.IsAnswered ? "· answered" : "· unanswered")</span>
                        </div>
                    }
                    else
                    {
                        <div class="qna-pane-muted">
                            <i class="fas fa-hourglass-half"></i>
                            <span>Waiting for participants to ask questions.</span>
                        </div>
                    }
                </div>
            </section>

            <section class="qna-questions-card">
                <div class="qna-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-comments me-2"></i>Questions
                    </h6>
                    <div class="qna-sort-switch" role="group" aria-label="Sort questions">
                        <button class="qna-sort-btn @(sortBy == "votes" ? "is-active" : "")"
                                @onclick='() => sortBy = "votes"'>
                            <i class="fas fa-fire"></i>
                            Top
                        </button>
                        <button class="qna-sort-btn @(sortBy == "recent" ? "is-active" : "")"
                                @onclick='() => sortBy = "recent"'>
                            <i class="fas fa-clock"></i>
                            Recent
                        </button>
                    </div>
                </div>

                @if (dashboard.Questions.Count > 0)
                {
                    <div class="qna-list">
                        @{
                            var qIndex = 0;
                        }
                        @foreach (var q in sortedQuestions)
                        {
                            qIndex++;
                            var isAnswered = q.IsAnswered;

                            <article class="qna-item @(isAnswered ? "is-answered" : "")">
                                <div class="qna-vote">
                                    <span class="value">@q.UpvoteCount</span>
                                    <i class="fas fa-thumbs-up"></i>
                                </div>

                                <div class="qna-body">
                                    <div class="qna-meta">
                                        <span class="qna-index">#@qIndex</span>
                                        @if (q.IsAnonymous)
                                        {
                                            <span class="qna-meta-badge">Anonymous</span>
                                        }
                                        @if (isAnswered)
                                        {
                                            <span class="qna-meta-badge is-answered">
                                                <i class="fas fa-check"></i>
                                                Answered
                                            </span>
                                        }
                                    </div>
                                    <p class="qna-text">@q.Text</p>
                                    <span class="qna-time">@GetRelativeTime(q.SubmittedAt)</span>
                                </div>

                                <div class="qna-actions">
                                    <button class="qna-toggle-btn @(isAnswered ? "is-reopen" : "is-answer")"
                                            @onclick="() => ToggleAnsweredAsync(q.ResponseId, !q.IsAnswered)"
                                            title="@(isAnswered ? "Mark as unanswered" : "Mark as answered")">
                                        <i class="fas @(isAnswered ? "fa-rotate-left" : "fa-check")"></i>
                                        @(isAnswered ? "Reopen" : "Answered")
                                    </button>
                                </div>
                            </article>
                        }
                    </div>

                    @if (displayCount < dashboard.Questions.Count)
                    {
                        <div class="qna-load-more">
                            <button class="qna-load-more-btn" @onclick="LoadMore">
                                Show @(dashboard.Questions.Count - displayCount) more
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="qna-empty-state">
                        <i class="fas fa-lightbulb"></i>
                        <div>
                            <div class="fw-semibold">No questions yet</div>
                            <div class="small text-muted">Participants can submit questions using the session code.</div>
                        </div>
                    </div>
                }
            </section>

            <section class="qna-summary-card">
                <div class="qna-section-head">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-column me-2"></i>Session Snapshot
                    </h6>
                </div>
                <div class="qna-metric-grid">
                    <div class="qna-metric">
                        <div class="value">@unansweredCount</div>
                        <div class="label">Unanswered</div>
                    </div>
                    <div class="qna-metric">
                        <div class="value">@answeredCount</div>
                        <div class="label">Answered</div>
                    </div>
                    <div class="qna-metric">
                        <div class="value">@avgVotesPerQuestion</div>
                        <div class="label">Avg Votes / Q</div>
                    </div>
                </div>
            </section>
        </div>
    }
</div>

