@code {
    [Parameter] public string SessionCode { get; set; } = string.Empty;
    [Parameter] public Guid ActivityId { get; set; }

    private QnADashboardResponse? dashboard;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string sortBy = "votes";
    private int displayCount = 25;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        await SetupSignalR();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!isLoading)
            await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

            var session = await SessionService.GetByCodeAsync(SessionCode);
            if (session is null)
            {
                errorMessage = "Session not found.";
                return;
            }

            dashboard = await QnADashboardService.GetQnADashboardAsync(session.Id, ActivityId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load Q&A dashboard: {ex.Message}";
            Logger.LogError(ex, "Failed to load QnA dashboard for session {SessionCode}, activity {ActivityId}", SessionCode, ActivityId);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.Reconnected += async _ =>
            {
                try
                {
                    await hubConnection.InvokeAsync("Subscribe", SessionCode);
                    await InvokeAsync(async () =>
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to re-subscribe QnA dashboard after reconnect");
                }
            };

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async (evt) =>
            {
                await InvokeAsync(async () =>
                {
                    if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    }
                });
            });

            hubConnection.On<DashboardUpdatedEvent>("DashboardUpdated", async (evt) =>
            {
                await InvokeAsync(async () =>
                {
                    if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    }
                });
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to set up SignalR for QnA dashboard");
        }
    }

    private IEnumerable<QnAQuestionItem> GetSortedQuestions()
    {
        if (dashboard?.Questions == null) return Enumerable.Empty<QnAQuestionItem>();

        // Unanswered first, then sort within groups
        var sorted = sortBy switch
        {
            "recent" => dashboard.Questions
                .OrderBy(q => q.IsAnswered ? 1 : 0)
                .ThenByDescending(q => q.SubmittedAt),
            _ => dashboard.Questions
                .OrderBy(q => q.IsAnswered ? 1 : 0)
                .ThenByDescending(q => q.UpvoteCount)
                .ThenBy(q => q.SubmittedAt)
        };

        return sorted.Take(displayCount);
    }

    private async Task ToggleAnsweredAsync(Guid questionId, bool isAnswered)
    {
        try
        {
            await QnADashboardService.ToggleAnsweredAsync(questionId, isAnswered);
            await LoadDashboard();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle answered state for question {QuestionId}", questionId);
        }
    }

    private int GetParticipationRate()
    {
        if (dashboard == null || dashboard.ParticipantCount == 0)
            return 0;

        return (int)Math.Round((double)dashboard.RespondedParticipants / dashboard.ParticipantCount * 100);
    }

    private static string GetPreviewText(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        return text.Length <= maxLength
            ? text
            : $"{text[..maxLength].TrimEnd()}...";
    }

    private void LoadMore() => displayCount += 25;

    private static string GetRelativeTime(DateTimeOffset ts)
    {
        var diff = DateTimeOffset.UtcNow - ts;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return ts.ToString("MMM d");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("Unsubscribe", SessionCode);
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error disposing SignalR for QnA dashboard");
            }
        }
    }
}
