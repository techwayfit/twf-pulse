@using System.Text.Json
@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject ISessionService SessionService
@inject ISessionActivityMetadataService MetadataService
@implements IAsyncDisposable

<div class="quadrant-activity">
    @if (config is null)
    {
        <div class="alert alert-warning">Activity configuration is missing.</div>
    }
    else if (config.Items.Count == 0)
    {
        <div class="alert alert-warning">No items configured for this activity.</div>
    }
    else
    {
        <!-- Progress bar -->
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-muted fw-semibold">Item @(currentItemIndex + 1) of @config.Items.Count</small>
                <small class="text-muted">@submittedItems.Count submitted</small>
            </div>
            <div class="progress" style="height: 6px;">
                <div class="progress-bar bg-success" style="width: @(submittedItems.Count * 100 / config.Items.Count)%"></div>
            </div>
        </div>

        <!-- Current item -->
        <div class="card border-primary border-2 mb-4">
            <div class="card-body py-3">
                <div class="text-muted small mb-1">Current item</div>
                <div class="fw-semibold fs-5">@currentItemName</div>
            </div>
        </div>

        @if (submittedItems.Contains(currentItemIndex))
        {
            <div class="alert alert-success d-flex align-items-center gap-2">
                <i class="fas fa-check-circle fs-5"></i>
                <div>
                    <strong>Scored!</strong>
                    <span class="ms-2 text-muted small">
                        @config.XAxisLabel: @submittedScores[currentItemIndex].x &nbsp;&nbsp;
                        @config.YAxisLabel: @submittedScores[currentItemIndex].y
                    </span>
                </div>
            </div>
        }
        else
        {
            <!-- Scoring form -->
            <div class="row g-4 mb-3">
                <!-- X axis -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">@config.XAxisLabel <span class="text-danger">*</span></label>
                    <select class="form-select" @onchange="OnXChanged" value="@selectedXValue">
                        <option value="">— select —</option>
                        @foreach (var opt in xOptions)
                        {
                            <option value="@opt.Value">@opt.DisplayText</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(selectedXDesc))
                    {
                        <div class="form-text text-info">@selectedXDesc</div>
                    }
                </div>

                <!-- Y axis -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">@config.YAxisLabel <span class="text-danger">*</span></label>
                    <select class="form-select" @onchange="OnYChanged" value="@selectedYValue">
                        <option value="">— select —</option>
                        @foreach (var opt in yOptions)
                        {
                            <option value="@opt.Value">@opt.DisplayText</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(selectedYDesc))
                    {
                        <div class="form-text text-info">@selectedYDesc</div>
                    }
                </div>
            </div>

            @if (config.AllowNotes)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Note <span class="text-muted fw-normal">(optional)</span></label>
                    <input type="text" class="form-control" @bind="noteText" placeholder="Add a quick note about this item..." maxlength="200" />
                </div>
            }

            @if (showValidationError)
            {
                <div class="alert alert-warning py-2 mb-3">Please select a score for both axes.</div>
            }
        }

        <button class="btn @(submittedItems.Contains(currentItemIndex) ? "btn-outline-success" : "btn-primary") btn-lg w-100 py-3"
                @onclick="HandleSubmit"
                disabled="@(Parameters.IsSubmitting || submittedItems.Contains(currentItemIndex))">
            @if (Parameters.IsSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2"></span><text>Submitting…</text>
            }
            else if (submittedItems.Contains(currentItemIndex))
            {
                <i class="fas fa-check-circle me-2"></i><text>Scored — waiting for next item</text>
            }
            else
            {
                <text>Submit Score</text>
            }
        </button>

        @if (!string.IsNullOrEmpty(Parameters.SubmitMessage) && !Parameters.SubmitSuccess)
        {
            <div class="alert alert-danger mt-3 mb-0">@Parameters.SubmitMessage</div>
        }

        <!-- Item overview chips -->
        @if (config.Items.Count > 1)
        {
            <div class="mt-4">
                <div class="small text-muted fw-semibold mb-2">All items</div>
                <div class="d-flex flex-wrap gap-1">
                    @for (int i = 0; i < config.Items.Count; i++)
                    {
                        var idx = i;
                        var isCurrent = idx == currentItemIndex;
                        var isDone = submittedItems.Contains(idx);
                        <span class="badge @(isCurrent ? "bg-primary" : isDone ? "bg-success" : "bg-light text-dark border") rounded-pill"
                              style="font-size: 0.7rem;"
                              title="@config.Items[idx]">
                            @(idx + 1)
                        </span>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required ParticipantActivityParameters Parameters { get; set; }

    private QuadrantConfig? config;
    private int currentItemIndex = 0;
    private string currentItemName = string.Empty;
    private string selectedXValue = string.Empty;
    private string selectedYValue = string.Empty;
    private string selectedXDesc = string.Empty;
    private string selectedYDesc = string.Empty;
    private string noteText = string.Empty;
    private bool showValidationError = false;
    private HashSet<int> submittedItems = new();
    private Dictionary<int, (string x, string y)> submittedScores = new();
    private List<ScoreOption> xOptions = new();
    private List<ScoreOption> yOptions = new();
    private HubConnection? hubConnection;
    private bool _indexRestored = false;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Parameters.Config))
        {
            try
            {
                config = JsonSerializer.Deserialize<QuadrantConfig>(Parameters.Config,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (config is not null)
                {
                    xOptions = config.XScoreOptions ?? new();
                    yOptions = config.ResolvedYScoreOptions ?? new();
                    UpdateCurrentItem();
                }
            }
            catch { /* use defaults */ }
        }

        if (!_indexRestored && !string.IsNullOrEmpty(Parameters.SessionCode))
        {
            try
            {
                var session = await SessionService.GetByCodeAsync(Parameters.SessionCode);
                if (session is not null)
                {
                    var saved = await MetadataService.GetValueAsync(
                        session.Id, Parameters.ActivityId,
                        TechWayFit.Pulse.Domain.Models.ActivityMetadataKeys.QuadrantCurrentItemIndex);
                    if (saved is not null && int.TryParse(saved, out var savedIdx))
                    {
                        currentItemIndex = savedIdx;
                        UpdateCurrentItem();
                    }
                }
            }
            catch { /* fail silently */ }
            _indexRestored = true;
        }

        if (hubConnection is null)
            await SetupSignalR();
    }

    private void UpdateCurrentItem()
    {
        if (config is null || config.Items.Count == 0) return;
        var idx = Math.Clamp(currentItemIndex, 0, config.Items.Count - 1);
        currentItemIndex = idx;
        currentItemName = config.Items[idx];
        // Only reset the form if this item hasn't been scored yet
        if (!submittedItems.Contains(currentItemIndex))
        {
            selectedXValue = string.Empty;
            selectedYValue = string.Empty;
            selectedXDesc = string.Empty;
            selectedYDesc = string.Empty;
            noteText = string.Empty;
            showValidationError = false;
        }
    }

    private void OnXChanged(ChangeEventArgs e)
    {
        selectedXValue = e.Value?.ToString() ?? string.Empty;
        var opt = xOptions.FirstOrDefault(o => o.Value == selectedXValue);
        selectedXDesc = opt?.Description ?? string.Empty;
        StateHasChanged();
    }

    private void OnYChanged(ChangeEventArgs e)
    {
        selectedYValue = e.Value?.ToString() ?? string.Empty;
        var opt = yOptions.FirstOrDefault(o => o.Value == selectedYValue);
        selectedYDesc = opt?.Description ?? string.Empty;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        if (submittedItems.Contains(currentItemIndex)) return;

        if (string.IsNullOrEmpty(selectedXValue) || string.IsNullOrEmpty(selectedYValue))
        {
            showValidationError = true;
            StateHasChanged();
            return;
        }

        showValidationError = false;

        var payload = new
        {
            itemIndex = currentItemIndex,
            xValue = selectedXValue,
            yValue = selectedYValue,
            note = string.IsNullOrWhiteSpace(noteText) ? null : noteText.Trim()
        };

        await Parameters.OnSubmit(JsonSerializer.Serialize(payload));

        submittedItems.Add(currentItemIndex);
        submittedScores[currentItemIndex] = (selectedXValue, selectedYValue);

        StateHasChanged();
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<TechWayFit.Pulse.Web.Hubs.QuadrantItemAdvancedEvent>("QuadrantItemAdvanced", async (evt) =>
            {
                if (evt.ActivityId == Parameters.ActivityId)
                {
                    await InvokeAsync(() =>
                    {
                        currentItemIndex = evt.ItemIndex;
                        UpdateCurrentItem();
                        StateHasChanged();
                    });
                }
            });

            await hubConnection.StartAsync();
            if (!string.IsNullOrEmpty(Parameters.SessionCode))
                await hubConnection.InvokeAsync("Subscribe", Parameters.SessionCode);
        }
        catch { /* hub unavailable — item advancement requires facilitator SignalR */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try { await hubConnection.DisposeAsync(); } catch { }
        }
    }
}
