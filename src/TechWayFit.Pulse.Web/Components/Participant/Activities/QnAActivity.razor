@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Contracts.Responses
@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Web.Hubs
@using System.Text.Json
@namespace TechWayFit.Pulse.Web.Components.Participant.Activities
@inject IQnADashboardService QnADashboardService
@inject ISessionService SessionService
@inject IResponseService ResponseService
@inject NavigationManager Navigation
@inject ILogger<QnAActivity> Logger
@implements IAsyncDisposable

<div class="qna-activity">
    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @* Question Submission Form *@
        @if (!hasSubmittedQuestion)
        {
            <div class="card border-0 bg-light mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-semibold mb-2">
                        <i class="fas fa-lightbulb me-1 text-warning"></i>Ask a Question
                    </h6>
                    <textarea class="form-control mb-2"
                              rows="3"
                              placeholder="@(config?.MaxQuestionLength > 0 ? $"Type your question... (max {config.MaxQuestionLength} characters)" : "Type your question...")"
                              maxlength="@(config?.MaxQuestionLength ?? 300)"
                              @bind="questionText"
                              @bind:event="oninput"
                              disabled="@isSubmittingQuestion"></textarea>
                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                        @if (config?.AllowAnonymous == true)
                        {
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="qnaAnonymous" @bind="isAnonymous" />
                                <label class="form-check-label small text-muted" for="qnaAnonymous">Submit anonymously</label>
                            </div>
                        }
                        else
                        {
                            <span></span>
                        }
                        <button class="btn btn-primary btn-sm px-4"
                                @onclick="SubmitQuestion"
                                disabled="@(isSubmittingQuestion || string.IsNullOrWhiteSpace(questionText))">
                            @if (isSubmittingQuestion)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <text>Submitting...</text>
                            }
                            else
                            {
                                <i class="fas fa-paper-plane me-1"></i>
                                <text>Submit Question</text>
                            }
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(submitErrorMessage))
                    {
                        <div class="alert alert-danger mt-2 mb-0 py-2 small">@submitErrorMessage</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4 py-2">
                <i class="fas fa-check-circle"></i>
                <span class="small"><strong>Question submitted!</strong> You can still upvote others below.</span>
            </div>
        }

        @* Questions List *@
        <div class="mb-2 d-flex justify-content-between align-items-center">
            <h6 class="fw-semibold mb-0">
                <i class="fas fa-comments me-1 text-primary"></i>Questions
                @if (dashboard?.TotalQuestions > 0)
                {
                    <span class="badge bg-primary ms-1">@dashboard.TotalQuestions</span>
                }
            </h6>
            @if (isRefreshing)
            {
                <div class="spinner-border spinner-border-sm text-secondary" role="status" style="width:1rem;height:1rem;">
                    <span class="visually-hidden">Updating...</span>
                </div>
            }
        </div>

        @if (dashboard?.Questions.Count > 0)
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var q in dashboard.Questions)
                {
                    var alreadyVoted = votedQuestionIds.Contains(q.ResponseId);
                    var isOwnQuestion = q.SubmittedByParticipantId == Parameters.ParticipantId;
                    var canVote = config?.AllowUpvoting == true && !alreadyVoted && !isOwnQuestion;

                    <div class="d-flex gap-3 align-items-start p-3 bg-white border rounded-3 @(alreadyVoted ? "border-primary border-opacity-50" : "")">
                        @* Upvote button *@
                        @if (config?.AllowUpvoting == true)
                        {
                            <div class="d-flex flex-column align-items-center gap-1" style="min-width: 44px;">
                                <button class="btn btn-sm @(alreadyVoted ? "btn-primary" : (isOwnQuestion ? "btn-light text-muted" : "btn-outline-primary")) p-1 rounded-2"
                                        style="width:40px;height:40px;font-size:1.1rem;"
                                        @onclick="() => ToggleVote(q)"
                                        disabled="@(isOwnQuestion || alreadyVoted || isSubmittingVote == q.ResponseId)"
                                        title="@(isOwnQuestion ? "Your own question" : alreadyVoted ? "Already upvoted" : "Upvote this question")">
                                    @if (isSubmittingVote == q.ResponseId)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-thumbs-up"></i>
                                    }
                                </button>
                                <span class="fw-bold small @(alreadyVoted ? "text-primary" : "text-muted")">
                                    @q.UpvoteCount
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-items-center" style="min-width: 44px;">
                                <span class="badge bg-light text-dark border fw-semibold">@q.UpvoteCount</span>
                            </div>
                        }

                        @* Question content *@
                        <div class="flex-grow-1">
                            <p class="mb-1">@q.Text</p>
                            <div class="d-flex gap-2 align-items-center">
                                <span class="text-muted small">@GetRelativeTime(q.SubmittedAt)</span>
                                @if (isOwnQuestion)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary small">You</span>
                                }
                                @if (q.IsAnonymous)
                                {
                                    <span class="badge bg-light text-muted border small">Anonymous</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-comments fa-2x mb-3 d-block opacity-25"></i>
                <p class="mb-0 small">No questions yet. Be the first to ask!</p>
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required ParticipantActivityParameters Parameters { get; set; }

    private QnAConfig? config;
    private QnADashboardResponse? dashboard;
    private HashSet<Guid> votedQuestionIds = new();
    private bool hasSubmittedQuestion;
    private bool isLoading = true;
    private bool isRefreshing;
    private string questionText = string.Empty;
    private bool isAnonymous;
    private bool isSubmittingQuestion;
    private Guid? isSubmittingVote;
    private string submitErrorMessage = string.Empty;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        ParseConfig();
        isAnonymous = false;

        await LoadDashboard(initial: true);
        await LoadParticipantVotes();
        await SetupSignalR();

        isLoading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!isLoading)
        {
            ParseConfig();
        }
    }

    private void ParseConfig()
    {
        if (!string.IsNullOrEmpty(Parameters.Config))
        {
            try
            {
                config = JsonSerializer.Deserialize<QnAConfig>(
                    Parameters.Config,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch (JsonException ex)
            {
                Logger.LogWarning(ex, "Failed to parse QnA config");
            }
        }
        config ??= new QnAConfig();
    }

    private async Task LoadDashboard(bool initial = false)
    {
        try
        {
            if (!initial) isRefreshing = true;

            var session = await SessionService.GetByCodeAsync(Parameters.SessionCode);
            if (session == null) return;

            dashboard = await QnADashboardService.GetQnADashboardAsync(session.Id, Parameters.ActivityId);

            // Determine if this participant already submitted a question
            if (initial && dashboard != null)
            {
                hasSubmittedQuestion = dashboard.Questions.Any(q =>
                    q.SubmittedByParticipantId == Parameters.ParticipantId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load QnA dashboard");
        }
        finally
        {
            if (!initial) isRefreshing = false;
        }
    }

    private async Task LoadParticipantVotes()
    {
        try
        {
            var session = await SessionService.GetByCodeAsync(Parameters.SessionCode);
            if (session == null) return;

            var participantResponses = await ResponseService.GetByParticipantAsync(
                session.Id, Parameters.ParticipantId);

            var jsonOpts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            foreach (var r in participantResponses.Where(r => r.ActivityId == Parameters.ActivityId))
            {
                try
                {
                    using var doc = JsonDocument.Parse(r.Payload);
                    var typeEl = doc.RootElement.TryGetProperty("type", out var t) ? t.GetString() : null;

                    if (string.Equals(typeEl, "vote", StringComparison.OrdinalIgnoreCase))
                    {
                        var qIdStr = doc.RootElement.TryGetProperty("questionResponseId", out var qid)
                            ? qid.GetString()
                            : null;
                        if (!string.IsNullOrEmpty(qIdStr) && Guid.TryParse(qIdStr, out var qGuid))
                        {
                            votedQuestionIds.Add(qGuid);
                        }
                    }
                }
                catch { }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load participant vote history");
        }
    }

    private async Task SubmitQuestion()
    {
        if (string.IsNullOrWhiteSpace(questionText)) return;

        var maxLen = config?.MaxQuestionLength ?? 300;
        if (questionText.Length > maxLen)
        {
            submitErrorMessage = $"Question must be {maxLen} characters or less.";
            return;
        }

        submitErrorMessage = string.Empty;
        isSubmittingQuestion = true;

        try
        {
            var payload = JsonSerializer.Serialize(new
            {
                type = "question",
                text = questionText.Trim(),
                isAnonymous
            });

            await Parameters.OnSubmit(payload);
            hasSubmittedQuestion = true;
            questionText = string.Empty;

            await LoadDashboard();
        }
        catch (Exception ex)
        {
            submitErrorMessage = "Failed to submit question. Please try again.";
            Logger.LogError(ex, "Failed to submit QnA question");
        }
        finally
        {
            isSubmittingQuestion = false;
            StateHasChanged();
        }
    }

    private async Task ToggleVote(QnAQuestionItem question)
    {
        if (isSubmittingVote.HasValue) return;

        // Un-voting is not supported — button is disabled when already voted
        if (votedQuestionIds.Contains(question.ResponseId)) return;

        isSubmittingVote = question.ResponseId;

        try
        {
            var payload = JsonSerializer.Serialize(new
            {
                type = "vote",
                questionResponseId = question.ResponseId.ToString(),
                isAnonymous = false
            });

            await Parameters.OnSubmit(payload);
            votedQuestionIds.Add(question.ResponseId);
            await LoadDashboard();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit QnA vote");
        }
        finally
        {
            isSubmittingVote = null;
            StateHasChanged();
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async (evt) =>
            {
                await InvokeAsync(async () =>
                {
                    if (evt.SessionCode == Parameters.SessionCode && evt.ActivityId == Parameters.ActivityId)
                    {
                        await LoadDashboard();
                        StateHasChanged();
                    }
                });
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", Parameters.SessionCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to set up SignalR for QnA participant");
        }
    }

    private static string GetRelativeTime(DateTimeOffset ts)
    {
        var diff = DateTimeOffset.UtcNow - ts;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return ts.ToString("MMM d");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("Unsubscribe", Parameters.SessionCode);
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error disposing SignalR for QnA participant");
            }
        }
    }
}
