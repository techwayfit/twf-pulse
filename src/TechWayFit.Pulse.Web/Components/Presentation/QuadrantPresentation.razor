@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@using TechWayFit.Pulse.Domain.Models.ActivityConfigs
@using TechWayFit.Pulse.Domain.Enums
@using TechWayFit.Pulse.Web.Hubs
@using TechWayFit.Pulse.Web.Services
@using System.Text.Json
@inject IQuadrantDashboardService QuadrantDashboardService
@inject ISessionService SessionService
@inject ISessionActivityMetadataService MetadataService
@inject IHubNotificationService HubNotificationService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="activity-display">
    <div class="activity-header">
        <div class="activity-title-section">
            <span class="activity-badge badge-quadrant">Item Scoring</span>
            <h2>@ActivityTitle</h2>
            @if (!string.IsNullOrEmpty(ActivityPrompt))
            {
                <p class="activity-description">@ActivityPrompt</p>
            }
        </div>
        <div class="d-flex align-items-center gap-4 ms-auto">
            @if (dashboard is not null)
            {
                <div class="d-flex align-items-center gap-1">
                    <i class="fas fa-comment-dots text-primary fs-5"></i>
                    <span class="fw-bold fs-5 text-primary">@dashboard.TotalResponses</span>
                    <span class="text-muted small">Responses</span>
                </div>
                <div class="d-flex align-items-center gap-1">
                    <i class="fas fa-users text-success fs-5"></i>
                    <span class="fw-bold fs-5 text-success">@dashboard.RespondedParticipants</span>
                    <span class="text-muted small">Participants</span>
                </div>
            }
            @if (DurationMinutes.HasValue && OpenedAt.HasValue)
            {
                <div class="activity-timer">
                    <div class="timer-label">Time Remaining</div>
                    <div class="timer-value" id="timer-display">@timeRemaining</div>
                </div>
            }
        </div>
    </div>

    <div class="activity-content">
        @if (dashboard is null && isLoading)
        {
            <div class="waiting-state">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <p>Loading scores…</p>
            </div>
        }
        else if (dashboard is not null)
        {
            <div class="row g-0 flex-fill overflow-hidden">
                <!-- Left col 3: item info + navigation -->
                <div class="col-3 d-flex flex-column px-3 pt-3 border-end">
                    <div class="text-muted" style="font-size:0.7rem;">Item @(currentItemIndex + 1) of @(config?.Items.Count ?? 0)</div>
                    <div class="fw-semibold mt-1" style="font-size:0.85rem; line-height:1.4;">@currentItemName</div>

                    <div class="d-flex gap-2 mt-auto pb-3">
                        <button class="btn btn-outline-secondary btn-sm flex-fill"
                                @onclick="PrevItem"
                                disabled="@(currentItemIndex <= 0 || _isNavigating)">
                            <i class="fas fa-chevron-left me-1"></i> Prev
                        </button>
                        <button class="btn btn-outline-secondary btn-sm flex-fill"
                                @onclick="NextItem"
                                disabled="@(config == null || currentItemIndex >= config.Items.Count - 1 || _isNavigating)">
                            Next <i class="fas fa-chevron-right ms-1"></i>
                        </button>
                    </div>

                </div>

                <!-- Right col 9: bubble chart fills remaining height -->
                <div class="col-9 position-relative">
                    <canvas id="@canvasId" style="position: absolute; inset: 0; width: 100% !important; height: 100% !important;"></canvas>
                    @if (!dashboard.Items.Any())
                    {
                        <div class="position-absolute top-50 start-50 translate-middle text-center">
                            <i class="fas fa-chart-scatter fs-1 text-muted mb-2 d-block"></i>
                            <div class="text-muted">Waiting for scores</div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="waiting-state">
                <i class="fas fa-chart-scatter waiting-icon"></i>
                <h3>No data yet</h3>
                <p>Scores will appear here as participants respond</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required string SessionCode { get; set; }

    [Parameter, EditorRequired]
    public required Guid ActivityId { get; set; }

    [Parameter]
    public string ActivityTitle { get; set; } = "Item Scoring";

    [Parameter]
    public string? ActivityPrompt { get; set; }

    [Parameter]
    public int? DurationMinutes { get; set; }

    [Parameter]
    public DateTimeOffset? OpenedAt { get; set; }

    [Parameter]
    public string? ActivityConfig { get; set; }

    private readonly string canvasId = $"quadrantPresChart_{Guid.NewGuid().ToString("N")[..8]}";
    private QuadrantDashboardResponse? dashboard;
    private QuadrantConfig? config;
    private HubConnection? hubConnection;
    private string timeRemaining = "--:--";
    private System.Threading.Timer? clockTimer;
    private int currentItemIndex = 0;
    private string currentItemName = string.Empty;
    private Guid? sessionId;
    private bool isLoading = true;
    private bool firstRenderComplete = false;
    private bool _chartNeedsRender = false;

    protected override async Task OnInitializedAsync()
    {
        LoadConfig();
        await LoadData();
        if (sessionId.HasValue)
        {
            try
            {
                var saved = await MetadataService.GetValueAsync(
                    sessionId.Value, ActivityId,
                    TechWayFit.Pulse.Domain.Models.ActivityMetadataKeys.QuadrantCurrentItemIndex);
                if (saved is not null && int.TryParse(saved, out var savedIdx))
                {
                    currentItemIndex = savedIdx;
                    UpdateCurrentItemName();
                }
            }
            catch { /* fail silently */ }
        }
        await SetupSignalR();
        StartClock();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) firstRenderComplete = true;
        if (firstRenderComplete && _chartNeedsRender && dashboard is not null)
        {
            _chartNeedsRender = false;
            try { await RenderChart(); } catch { }
        }
    }

    private void LoadConfig()
    {
        if (string.IsNullOrWhiteSpace(ActivityConfig)) return;
        try
        {
            config = JsonSerializer.Deserialize<QuadrantConfig>(ActivityConfig,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (config is not null) UpdateCurrentItemName();
        }
        catch { }
    }

    private void UpdateCurrentItemName()
    {
        if (config?.Items == null || config.Items.Count == 0) { currentItemName = string.Empty; return; }
        var idx = Math.Clamp(currentItemIndex, 0, config.Items.Count - 1);
        currentItemIndex = idx;
        currentItemName = config.Items[idx];
    }

    private bool _isNavigating = false;

    private void PrevItem() => _ = AdvanceToItem(currentItemIndex - 1);
    private void NextItem() => _ = AdvanceToItem(currentItemIndex + 1);

    private async Task AdvanceToItem(int newIndex)
    {
        if (config is null || newIndex < 0 || newIndex >= config.Items.Count || _isNavigating) return;
        _isNavigating = true;
        try
        {
            await HubNotificationService.PublishQuadrantItemAdvancedAsync(SessionCode, ActivityId, newIndex);
            currentItemIndex = newIndex;
            UpdateCurrentItemName();
            if (sessionId.HasValue)
            {
                try
                {
                    await MetadataService.SetValueAsync(
                        sessionId.Value, ActivityId,
                        TechWayFit.Pulse.Domain.Models.ActivityMetadataKeys.QuadrantCurrentItemIndex,
                        newIndex.ToString());
                }
                catch { /* fail silently */ }
            }
        }
        finally
        {
            _isNavigating = false;
            _chartNeedsRender = true;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            if (!sessionId.HasValue)
            {
                var session = await SessionService.GetByCodeAsync(SessionCode);
                if (session is null) return;
                sessionId = session.Id;
            }

            dashboard = await QuadrantDashboardService.GetQuadrantDashboardAsync(
                sessionId.Value, ActivityId, new Dictionary<string, string?>());
            _chartNeedsRender = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"QuadrantPresentation LoadData error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RenderChart()
    {
        if (dashboard is null) return;

        await Task.Delay(80);
        var exists = await JS.InvokeAsync<bool>("eval", $"!!document.getElementById('{canvasId}')");
        if (!exists) return;

        var xOptions = config?.XScoreOptions ?? new List<ScoreOption>();
        double xMin = xOptions.Count > 0 ? xOptions.Min(o => o.NumericValue) : 0;
        double xMax = xOptions.Count > 0 ? xOptions.Max(o => o.NumericValue) : 10;

        var chartItems = dashboard.Items.Select(i => new
        {
            label = i.ItemLabel,
            avgX = i.AverageX,
            avgY = i.AverageY,
            count = i.ResponseCount,
            isCurrent = i.ItemIndex == currentItemIndex
        }).ToList();

        await JS.InvokeVoidAsync("renderQuadrantBubbleChart",
            canvasId,
            dashboard.XAxisLabel,
            dashboard.YAxisLabel,
            chartItems,
            config?.BubbleSizeMode == QuadrantBubbleSizeMode.Uniform,
            xMin,
            xMax,
            config?.Q1Label ?? "Quick Wins",
            config?.Q2Label ?? "Major Projects",
            config?.Q3Label ?? "Fill-Ins",
            config?.Q4Label ?? "Thankless Tasks");
    }

    private async Task SetupSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<ResponseReceivedEvent>("ResponseReceived", async evt =>
            {
                if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
            });

            hubConnection.On<QuadrantItemAdvancedEvent>("QuadrantItemAdvanced", async evt =>
            {
                if (evt.ActivityId == ActivityId)
                {
                    await InvokeAsync(() =>
                    {
                        currentItemIndex = evt.ItemIndex;
                        UpdateCurrentItemName();
                        _chartNeedsRender = true;
                        StateHasChanged();
                        return Task.CompletedTask;
                    });
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"QuadrantPresentation SignalR error: {ex.Message}");
        }
    }

    private void StartClock()
    {
        if (!DurationMinutes.HasValue || !OpenedAt.HasValue) return;
        clockTimer = new System.Threading.Timer(_ =>
        {
            var end = OpenedAt.Value.AddMinutes(DurationMinutes.Value);
            var rem = end - DateTimeOffset.UtcNow;
            timeRemaining = rem.TotalSeconds > 0
                ? $"{(int)rem.TotalMinutes}:{rem.Seconds:D2}"
                : "0:00";
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    public async ValueTask DisposeAsync()
    {
        clockTimer?.Dispose();
        try { await JS.InvokeVoidAsync("destroyQuadrantBubbleChart", canvasId); } catch { }
        if (hubConnection is not null)
        {
            try { await hubConnection.DisposeAsync(); } catch { }
        }
    }
}
