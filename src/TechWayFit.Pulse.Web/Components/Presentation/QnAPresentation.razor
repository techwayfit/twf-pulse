@using Microsoft.AspNetCore.SignalR.Client
@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Application.Abstractions.Services
@inject IQnADashboardService DashboardService
@inject ISessionService SessionService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="activity-display">
    <div class="activity-header">
        <div class="activity-title-section">
            <span class="activity-badge badge-qna">Q&amp;A</span>
            <h2>@ActivityTitle</h2>
            @if (!string.IsNullOrEmpty(ActivityPrompt))
            {
                <p class="activity-description">@ActivityPrompt</p>
            }
        </div>
        @if (DurationMinutes.HasValue && OpenedAt.HasValue)
        {
            <div class="activity-timer">
                <div class="timer-label">Time Remaining</div>
                <div class="timer-value" id="timer-display">@TimeRemaining</div>
            </div>
        }
    </div>

    <div class="activity-content">
        @{
            var open = (Questions ?? new())
                .Where(q => !q.IsAnswered)
                .OrderByDescending(q => q.UpvoteCount)
                .ThenBy(q => q.SubmittedAt)
                .ToList();

            var answered = (Questions ?? new())
                .Where(q => q.IsAnswered)
                .OrderByDescending(q => q.SubmittedAt)
                .ToList();
        }

        @if (!open.Any() && !answered.Any())
        {
            <div class="waiting-state">
                <i class="fas fa-lightbulb waiting-icon"></i>
                <h3>Waiting for questions</h3>
                <p>Participants can submit and upvote questions</p>
            </div>
        }
        else
        {
            @* Open questions *@
            @if (open.Any())
            {
                <div class="qna-section-label">Questions</div>
                <div class="qna-presentation-list">
                    @foreach (var (q, idx) in open.Select((q, i) => (q, i + 1)))
                    {
                        <div class="qna-item @(idx == 1 ? "qna-item-top" : "")">
                            @* Rank badge *@
                            <div class="qna-rank">#@idx</div>

                            @* Vote pill *@
                            <div class="qna-vote-pill">
                                <span class="qna-vote-count">@q.UpvoteCount</span>
                                <i class="fas fa-thumbs-up qna-vote-icon"></i>
                            </div>

                            @* Text *@
                            <div class="qna-text">@q.Text</div>

                            @* Mark answered *@
                            <button class="qna-answered-btn" @onclick="() => ToggleAnswered(q.ResponseId)" title="Mark as answered">
                                <i class="fas fa-check"></i>
                            </button>
                        </div>
                    }
                </div>
            }

            @* Answered questions *@
            @if (answered.Any())
            {
                <div class="qna-section-label qna-section-answered-label mt-3">
                    <i class="fas fa-check-circle me-1"></i>Answered (@answered.Count)
                </div>
                <div class="qna-presentation-list qna-answered-list">
                    @foreach (var q in answered)
                    {
                        <div class="qna-item qna-item-answered">
                            <div class="qna-vote-pill qna-vote-pill-answered">
                                <span class="qna-vote-count">@q.UpvoteCount</span>
                                <i class="fas fa-thumbs-up qna-vote-icon"></i>
                            </div>
                            <div class="qna-text qna-text-answered">@q.Text</div>
                            <button class="qna-answered-btn qna-answered-btn-undo" @onclick="() => ToggleAnswered(q.ResponseId)" title="Reopen question">
                                <i class="fas fa-rotate-left"></i>
                            </button>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

<style>
    .badge-qna {
        background: #e0f2fe;
        color: var(--pulse-blue-dark);
        padding: 0.4em 1em;
        border-radius: var(--pulse-radius-full);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .qna-section-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--pulse-gray-400);
        margin-bottom: 0.5rem;
    }

    .qna-section-answered-label {
        color: var(--pulse-green-dark);
    }

    .qna-presentation-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow-y: auto;
        border-radius: var(--pulse-radius-lg);
        border: 1px solid var(--pulse-gray-200);
        overflow: hidden;
    }

    .qna-answered-list {
        max-height: 22vh;
        overflow-y: auto;
        border-color: #bbf7d0;
    }

    .qna-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: #fff;
        border-bottom: 1px solid var(--pulse-gray-100);
        transition: background 0.15s ease;
    }

    .qna-item:last-child {
        border-bottom: none;
    }

    .qna-item-top {
        background: #f0f9ff;
        border-left: 4px solid var(--pulse-blue);
    }

    .qna-item-answered {
        background: #f0fdf4;
        border-left: 4px solid #86efac;
    }

    .qna-rank {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--pulse-gray-400);
        min-width: 24px;
        text-align: right;
        flex-shrink: 0;
    }

    .qna-vote-pill {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: #eff8ff;
        border: 1px solid #bae6fd;
        border-radius: var(--pulse-radius-md);
        padding: 0.5rem 0.75rem;
        min-width: 60px;
        gap: 0.15rem;
        flex-shrink: 0;
    }

    .qna-vote-pill-answered {
        background: #f0fdf4;
        border-color: #bbf7d0;
    }

    .qna-vote-count {
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1;
        color: var(--pulse-blue-dark);
    }

    .qna-vote-icon {
        font-size: 0.8rem;
        color: var(--pulse-blue);
    }

    .qna-vote-pill-answered .qna-vote-count,
    .qna-vote-pill-answered .qna-vote-icon {
        color: var(--pulse-green-dark);
    }

    .qna-text {
        flex: 1;
        font-size: 1.15rem;
        line-height: 1.45;
        color: var(--pulse-gray-800);
        min-width: 0;
    }

    .qna-text-answered {
        text-decoration: line-through;
        color: var(--pulse-gray-400);
    }

    .qna-answered-btn {
        flex-shrink: 0;
        background: transparent;
        border: 1px solid var(--pulse-gray-200);
        border-radius: var(--pulse-radius-md);
        color: var(--pulse-gray-400);
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.15s;
        opacity: 0;
    }

    .qna-item:hover .qna-answered-btn {
        opacity: 1;
    }

    .qna-answered-btn:hover {
        background: #dcfce7;
        border-color: #86efac;
        color: var(--pulse-green-dark);
    }

    .qna-answered-btn-undo:hover {
        background: #fef3c7;
        border-color: #fcd34d;
        color: #92400e;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public required string SessionCode { get; set; }

    [Parameter, EditorRequired]
    public required Guid ActivityId { get; set; }

    [Parameter]
    public string ActivityTitle { get; set; } = "Q&A";

    [Parameter]
    public string? ActivityPrompt { get; set; }

    [Parameter]
    public int? DurationMinutes { get; set; }

    [Parameter]
    public DateTimeOffset? OpenedAt { get; set; }

    private HubConnection? hubConnection;
    private List<QnAQuestionItem> Questions { get; set; } = new();
    private string TimeRemaining { get; set; } = "--:--";
    private System.Threading.Timer? timer;
    private System.Threading.Timer? dataRefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await InitializeSignalR();
        StartTimer();
        StartDataRefresh();
    }

    private async Task LoadData()
    {
        try
        {
            var session = await SessionService.GetByCodeAsync(SessionCode);
            if (session == null) return;

            var result = await DashboardService.GetQnADashboardAsync(session.Id, ActivityId);
            Questions = result.Questions.ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/workshop"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<TechWayFit.Pulse.Web.Hubs.ResponseReceivedEvent>("ResponseReceived", async (evt) =>
            {
                if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    await LoadData();
            });

            hubConnection.On<TechWayFit.Pulse.Web.Hubs.DashboardUpdatedEvent>("DashboardUpdated", async (evt) =>
            {
                if (evt.SessionCode == SessionCode && evt.ActivityId == ActivityId)
                    await LoadData();
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("Subscribe", SessionCode);
        }
        catch { }
    }

    private void StartTimer()
    {
        if (!DurationMinutes.HasValue || !OpenedAt.HasValue) return;

        timer = new System.Threading.Timer(async _ =>
        {
            var elapsed = DateTimeOffset.UtcNow - OpenedAt.Value;
            var remaining = TimeSpan.FromMinutes(DurationMinutes.Value) - elapsed;

            if (remaining <= TimeSpan.Zero)
            {
                TimeRemaining = "00:00";
                timer?.Dispose();
            }
            else
            {
                TimeRemaining = $"{(int)remaining.TotalMinutes:D2}:{remaining.Seconds:D2}";
            }

            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private void StartDataRefresh()
    {
        dataRefreshTimer = new System.Threading.Timer(async _ =>
        {
            await LoadData();
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async void ToggleAnswered(Guid questionId)
    {
        var q = Questions.FirstOrDefault(x => x.ResponseId == questionId);
        if (q is null) return;
        try
        {
            await DashboardService.ToggleAnsweredAsync(questionId, !q.IsAnswered);
            await LoadData();
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        timer?.Dispose();
        dataRefreshTimer?.Dispose();

        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
