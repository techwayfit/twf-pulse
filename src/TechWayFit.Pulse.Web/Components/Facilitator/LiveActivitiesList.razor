@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Contracts.Enums
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web

<!-- Sidebar header -->
<div class="live-sidebar-header">
    <span class="live-sidebar-label">Activities</span>
    <span class="badge badge-gradient rounded-pill" style="font-size: 0.68rem;">@Activities.Count</span>
</div>

<!-- Scrollable activity queue -->
<div class="live-sidebar-queue">
    @if (Activities != null && Activities.Any())
    {
        @foreach (var (activity, index) in Activities.OrderBy(a => a.Order).Select((a, i) => (a, i)))
        {
            var statusClass = GetActivityStatusClass(activity.Status);
            var isSelected = SelectedActivityId.HasValue && SelectedActivityId.Value == activity.ActivityId;

            <div class="live-activity-item live-activity-item--@statusClass live-activity-item--clickable @(isSelected ? "live-activity-item--selected" : string.Empty)"
                 role="button"
                 tabindex="0"
                 @onclick="@(() => HandleActivityClick(activity.ActivityId))"
                 @onkeydown="@((KeyboardEventArgs e) => HandleActivityKeyDown(e, activity.ActivityId))">

                <!-- Status dot -->
                <div class="live-activity-item-status live-activity-item-status--@statusClass"></div>

                <!-- Order -->
                <span class="live-activity-item-order">@(index + 1)</span>

                <!-- Body -->
                <div class="live-activity-item-body">
                    <div class="d-flex align-items-center gap-1 mb-1 w-100">
                        <span class="badge" style="@GetActivityTypeBadgeStyle(activity.Type); padding: 0.2rem 0.45rem; font-size: 0.65rem;">
                            @GetActivityTypeIcon(activity.Type)
                            @activity.Type
                        </span>
                        @if (activity.DurationMinutes.HasValue)
                        {
                            <span class="text-muted ms-auto" style="font-size: 0.65rem;">
                                <i class="far fa-clock"></i> @activity.DurationMinutes&#8202;m
                            </span>
                        }
                    </div>
                    <div class="live-activity-item-title">@activity.Title</div>

                    @* Display options count right below description for Poll activities *@
                    @if (!string.IsNullOrEmpty(activity.Config) && activity.Type == ActivityType.Poll)
                    {
                        try
                        {
                            var pollConfig = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(activity.Config);
                            if (pollConfig.TryGetProperty("options", out var options) && options.ValueKind == System.Text.Json.JsonValueKind.Array)
                            {
                                <span class="live-activity-item-meta">
                                    <i class="far fa-list-alt text-primary"></i>
                                    @options.GetArrayLength() options
                                </span>
                            }
                        }
                        catch { }
                    }

                    <div class="live-activity-item-status-text live-activity-item-status-text--@statusClass">
                        @GetActivityStatusLabel(activity.Status)
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4 px-3">
            <i class="fas fa-clipboard-list fa-2x text-muted mb-2"></i>
            <p class="text-muted small mb-0">No activities yet.</p>
        </div>
    }
</div>

<!-- Add activity footer -->
@if (!IsSessionEnded)
{
<div class="live-sidebar-add">
    <div class="live-sidebar-add-label">Add Activity</div>
    <div class="live-add-activity-grid">
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#pollModal" @onclick='() => OnAddActivity.InvokeAsync("Poll")'>
            <i class="fas fa-chart-bar"></i>Poll
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#wordcloudModal" @onclick='() => OnAddActivity.InvokeAsync("WordCloud")'>
            <i class="fas fa-cloud"></i>Word Cloud
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#quadrantModal" @onclick='() => OnAddActivity.InvokeAsync("Quadrant")'>
            <i class="fas fa-chart-line"></i>Quadrant
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#fivewhysModal" @onclick='() => OnAddActivity.InvokeAsync("FiveWhys")'>
            <i class="fas fa-magnifying-glass"></i>5 Whys
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#ratingModal" @onclick='() => OnAddActivity.InvokeAsync("Rating")'>
            <i class="fas fa-star"></i>Rating
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#feedbackModal" @onclick='() => OnAddActivity.InvokeAsync("Feedback")'>
            <i class="fas fa-comment"></i>Feedback
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#qnaModal" @onclick='() => OnAddActivity.InvokeAsync("QnA")'>
            <i class="fas fa-lightbulb"></i>Q&amp;A
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#aisummaryModal" @onclick='() => OnAddActivity.InvokeAsync("AiSummary")'>
            <i class="fas fa-robot"></i>AI Summary
        </button>
        <button type="button" class="live-add-activity-btn" data-bs-toggle="modal"
                data-bs-target="#breakModal" @onclick='() => OnAddActivity.InvokeAsync("Break")'>
            <i class="fas fa-coffee"></i>Break
        </button>
    </div>
</div>
}

@code {
    [Parameter, EditorRequired]
    public List<AgendaActivityResponse> Activities { get; set; } = new();

    [Parameter]
    public Guid? SelectedActivityId { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<Guid> OnSelectActivity { get; set; }

    [Parameter]
    public bool IsSessionEnded { get; set; }

    [Parameter]
    public EventCallback<string> OnAddActivity { get; set; }

    private Task HandleActivityClick(Guid activityId) => OnSelectActivity.InvokeAsync(activityId);

    private async Task HandleActivityKeyDown(KeyboardEventArgs e, Guid activityId)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            await HandleActivityClick(activityId);
        }
    }

    private static string GetActivityStatusClass(ActivityStatus status) => status switch
    {
        ActivityStatus.Open => "live",
        ActivityStatus.Closed => "completed",
        _ => "pending"
    };

    private static string GetActivityStatusLabel(ActivityStatus status) => status switch
    {
        ActivityStatus.Open => "Active",
        ActivityStatus.Closed => "Completed",
        _ => "Pending"
    };

    private MarkupString GetActivityTypeIcon(ActivityType type) => type switch
    {
        ActivityType.Poll => (MarkupString)"<i class='fas fa-chart-bar'></i>",
        ActivityType.WordCloud => (MarkupString)"<i class='fas fa-cloud'></i>",
        ActivityType.Quadrant => (MarkupString)"<i class='fas fa-chart-line'></i>",
        ActivityType.FiveWhys => (MarkupString)"<i class='fas fa-magnifying-glass'></i>",
        ActivityType.Rating => (MarkupString)"<i class='fas fa-star'></i>",
        ActivityType.GeneralFeedback => (MarkupString)"<i class='fas fa-comment'></i>",
        ActivityType.Quiz => (MarkupString)"<i class='fas fa-circle-question'></i>",
        ActivityType.QnA => (MarkupString)"<i class='fas fa-lightbulb'></i>",
        ActivityType.AiSummary => (MarkupString)"<i class='fas fa-robot '></i>",
        ActivityType.Break => (MarkupString)"<i class='fas fa-coffee'></i>",
        _ => (MarkupString)"<i class='fas fa-clipboard-list'></i>"
    };

    private string GetActivityTypeBadgeStyle(ActivityType type) => type switch
    {
        ActivityType.Poll => "background: var(--pulse-gradient); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.WordCloud => "background: var(--pulse-blue); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.Quadrant => "background: var(--pulse-blue-dark); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.FiveWhys => "background: var(--pulse-warning); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.Rating => "background: var(--pulse-warning); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.GeneralFeedback => "background: var(--pulse-success); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.Quiz => "background: var(--pulse-danger); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.QnA => "background: var(--pulse-info); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.AiSummary => "background: #7c3aed; color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        ActivityType.Break => "background: var(--pulse-warning); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;",
        _ => "background: var(--pulse-gray-400); color: white; padding: 0.4rem 0.7rem; border-radius: var(--pulse-radius-md); font-size: 0.85rem; font-weight: 600;"
    };
}
