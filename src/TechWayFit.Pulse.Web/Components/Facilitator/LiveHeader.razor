@using TechWayFit.Pulse.Contracts.Enums
@using TechWayFit.Pulse.Contracts.Responses
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

<!-- Enhanced top bar with improved styling -->
<div class="live-top-bar">

  <!-- Logo with enhanced styling -->
    <a href="/" class="d-flex align-items-center text-decoration-none me-2" style="gap: 0.5rem;">
        <div class="pulse-logo-mark" style="width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; background: var(--pulse-gradient); border-radius: 9px; box-shadow: 0 2px 8px rgba(14, 158, 154, 0.35);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 12h4l2-5 4 10 2-5h6" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
        </div>
        <div class="lh-sm d-none d-md-block">
        <div class="fw-bold" style="font-size: 0.9rem; color: var(--pulse-text-dark);">Pulse</div>
   <span style="font-size: 0.65rem; color: var(--pulse-text-mid);">by TechWayFit</span>
  </div>
    </a>

 <div class="live-top-bar-divider d-none d-lg-block"></div>

    <!-- Sidebar toggle -->
    <button class="live-sidebar-toggle" @onclick="OnToggleSidebar" title="@(IsSidebarCollapsed ? "Show activities" : "Hide activities")">
        <i class="fas fa-bars"></i>
  </button>

    <!-- Session title with enhanced styling -->
  <div class="d-flex align-items-center gap-2 flex-shrink-1 min-width-0">
        <span class="live-top-bar-title">@Session.Title</span>
        <span class="session-id d-none d-md-inline-flex">
            <i class="fas fa-link" style="font-size: 0.65rem;"></i>
      @SessionCode
        </span>
    </div>

    @if (CurrentActivity != null)
    {
<div class="live-top-bar-current d-none d-xl-flex">
        <span class="badge flex-shrink-0" style="@GetActivityTypeBadgeStyle(CurrentActivity.Type); padding: 0.3rem 0.65rem; font-size: 0.7rem; border-radius: 6px;">
   @CurrentActivity.Type
</span>
     <span class="badge bg-light text-dark flex-shrink-0" style="font-size: 0.7rem; padding: 0.3rem 0.6rem; border-radius: 6px;">#@CurrentActivity.Order</span>
     <span class="live-top-bar-current-title">@CurrentActivity.Title</span>
        </div>
    }

    <!-- Action buttons with enhanced styling -->
    <div class="live-top-bar-actions">
        @if (CurrentActivity != null && !IsSessionEnded)
        {
            <button class="btn btn-sm btn-primary d-none d-lg-inline-flex align-items-center gap-1 shadow-sm" 
       @onclick="NavigateToPresenterMode"
             title="Present Activity Full-Screen"
       style="border-radius: 6px; font-weight: 600; transition: all 0.2s ease;">
     <i class="fas fa-tv"></i>
                <span class="d-none d-xl-inline">Presenter</span>
            </button>
        }

        @if (!IsSessionEnded)
        {
   <button class="btn btn-sm btn-outline-secondary d-none d-md-inline-flex align-items-center gap-1"
            @onclick="OnShowEditSession"
          style="border-radius: 6px; font-weight: 500; transition: all 0.2s ease;">
                <i class="fas fa-edit"></i>
     <span class="d-none d-lg-inline">Edit</span>
            </button>
      <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1 shadow-sm" 
   @onclick="OnShowQRModal"
          style="border-radius: 6px; font-weight: 600; transition: all 0.2s ease;">
       <i class="fas fa-qrcode"></i>
                <span class="d-none d-sm-inline">Join</span>
            </button>
        }
        else
        {
       <button class="btn btn-sm btn-outline-info d-none d-md-inline-flex align-items-center gap-1" 
         @onclick="NavigateToReport"
               style="border-radius: 6px; font-weight: 500; transition: all 0.2s ease;">
    <i class="fas fa-file-lines"></i>
          <span class="d-none d-lg-inline">Report</span>
       </button>
        }

        @if (Session.Status == SessionStatus.Live)
        {
    <button class="btn btn-sm btn-danger shadow-sm" 
         @onclick="OnEndSession" 
          disabled="@IsPerformingAction"
           style="border-radius: 6px; font-weight: 600; transition: all 0.2s ease;">
        <i class="fas fa-stop me-1 d-none d-sm-inline"></i>
    @(IsPerformingAction ? "Ending..." : "End")
        </button>
        }
        else if (Session.Status == SessionStatus.Draft)
      {
 <button class="btn btn-sm btn-success shadow-sm" 
          @onclick="OnStartSession" 
 disabled="@IsPerformingAction"
  style="border-radius: 6px; font-weight: 600; transition: all 0.2s ease;">
           <i class="fas fa-play me-1 d-none d-sm-inline"></i>
  @(IsPerformingAction ? "Starting..." : "Start")
            </button>
   }

        <!-- Enhanced User dropdown -->
        <div class="dropdown d-none d-md-block">
  <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-2" 
   type="button" 
  id="liveUserMenu" 
    data-bs-toggle="dropdown" 
             aria-expanded="false"
        style="padding: 0.4rem 0.75rem; border-radius: 6px; transition: all 0.2s ease;">
        @{
    var httpContext = HttpContextAccessor.HttpContext;
     var user = httpContext?.User;
           var displayName = user?.Identity?.Name ?? "User";
          var initials = string.Join("", displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0]));
        }
 <div class="user-initials-badge" 
         style="width: 28px; height: 28px; border-radius: 50%; background: var(--pulse-gradient); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; box-shadow: 0 2px 6px rgba(14, 158, 154, 0.25);">
     @initials.ToUpper()
   </div>
            <i class="fas fa-chevron-down" style="font-size: 0.65rem;"></i>
            </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" 
         aria-labelledby="liveUserMenu" 
        style="min-width: 200px; border-radius: 12px; margin-top: 0.5rem;">
     <li class="px-3 py-2 border-bottom">
 <div class="small text-muted mb-1">Signed in as</div>
          <div class="fw-semibold">@displayName</div>
     </li>
       <li>
    <a class="dropdown-item py-2" href="/account/profile" style="border-radius: 6px; margin: 0.25rem 0.5rem;">
      <i class="fas fa-user me-2 text-muted"></i>Profile
            </a>
       </li>
   <li>
         <a class="dropdown-item py-2" href="/facilitator/dashboard" style="border-radius: 6px; margin: 0.25rem 0.5rem;">
   <i class="fas fa-th-large me-2 text-muted"></i>My Sessions
         </a>
        </li>
            <li><hr class="dropdown-divider mx-2"></li>
     <li>
         <form method="post" action="/account/logout">
       @if (httpContext != null)
      {
        var tokenSet = Antiforgery.GetAndStoreTokens(httpContext);
          <input type="hidden" name="@tokenSet.FormFieldName" value="@tokenSet.RequestToken" />
                }
         <button type="submit" class="dropdown-item text-danger py-2" style="border-radius: 6px; margin: 0.25rem 0.5rem;">
            <i class="fas fa-sign-out-alt me-2"></i>Sign Out
            </button>
     </form>
    </li>
        </ul>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public SessionSummaryResponse Session { get; set; } = default!;

  [Parameter, EditorRequired]
    public string SessionCode { get; set; } = default!;

 [Parameter]
    public int ParticipantCount { get; set; }

    [Parameter]
    public AgendaActivityResponse? CurrentActivity { get; set; }

 [Parameter, EditorRequired]
    public List<AgendaActivityResponse> Activities { get; set; } = new();

    [Parameter]
    public bool IsSidebarCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    [Parameter]
    public bool IsPerformingAction { get; set; }

    [Parameter]
    public EventCallback OnShowQRModal { get; set; }

    [Parameter]
    public EventCallback OnShowEditSession { get; set; }

    [Parameter]
    public EventCallback OnStartSession { get; set; }

    [Parameter]
    public EventCallback OnEndSession { get; set; }

    private void NavigateToReport()
    {
        Navigation.NavigateTo($"/facilitator/report/{SessionCode}", forceLoad: true);
    }

    private void NavigateToPresenterMode()
    {
     Navigation.NavigateTo($"/facilitator/live/presentation?code={SessionCode}", true);
    }

    private string GetActivityTypeBadgeStyle(ActivityType type) => type switch
  {
        ActivityType.Poll => "background: var(--pulse-gradient); color: white;",
        ActivityType.WordCloud => "background: var(--pulse-blue); color: white;",
        ActivityType.Quadrant => "background: var(--pulse-blue-dark); color: white;",
        ActivityType.FiveWhys => "background: var(--pulse-warning); color: white;",
        ActivityType.Rating => "background: var(--pulse-warning); color: white;",
        ActivityType.GeneralFeedback => "background: var(--pulse-success); color: white;",
        ActivityType.Quiz => "background: var(--pulse-danger); color: white;",
        ActivityType.QnA => "background: var(--pulse-info); color: white;",
      ActivityType.AiSummary => "background: #7c3aed; color: white;",
   ActivityType.Break => "background: var(--pulse-warning); color: white;",
     _ => "background: var(--pulse-gray-400); color: white;"
    };

    private bool IsSessionEnded => Session.Status == SessionStatus.Ended;
}
