@using TechWayFit.Pulse.Contracts.Requests
@using TechWayFit.Pulse.Contracts.Enums
@using System.Text.Json

<!-- Poll Activity Modal -->
<div class="modal fade" id="pollModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-chart-bar me-1"></i>Create Poll Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="pollForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="pollTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Prompt</label>
                        <textarea class="form-control" id="pollPrompt" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Poll Options *</label>
                        <div id="pollOptionsContainer"></div>
                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addPollOption()">+ Add Option</button>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="pollDuration" value="5" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Responses Per Participant</label>
                            <input type="number" class="form-control" id="pollMaxResponses" value="1" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="pollAllowMultiple" />
                            <label class="form-check-label" for="pollAllowMultiple">Allow multiple selections</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="savePollActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- Word Cloud Activity Modal -->
<div class="modal fade" id="wordcloudModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-cloud me-1"></i>Create Word Cloud Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="wordcloudForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="wcTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Prompt</label>
                        <textarea class="form-control" id="wcPrompt" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Words Per Response</label>
                            <input type="number" class="form-control" id="wcMaxWords" value="3" min="1" max="10" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="wcDuration" value="5" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="wcAllowMultiple" />
                            <label class="form-check-label" for="wcAllowMultiple">Allow multiple submissions</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveWordCloudActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- Rating Activity Modal -->
<div class="modal fade" id="ratingModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ics ics-star ic-sm"></i> Create Rating Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="ratingForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="ratingTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Prompt</label>
                        <textarea class="form-control" id="ratingPrompt" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Scale Range</label>
                            <select class="form-select" id="ratingScale">
                                <option value="5">1-5</option>
                                <option value="10" selected>1-10</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="ratingDuration" value="5" min="1" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Max Responses</label>
                            <input type="number" class="form-control" id="ratingMaxResponses" value="1" min="1" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Low Label</label>
                            <input type="text" class="form-control" id="ratingLowLabel" placeholder="Not at all" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">High Label</label>
                            <input type="text" class="form-control" id="ratingHighLabel" placeholder="Extremely" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveRatingActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- Q&A Activity Modal -->
<div class="modal fade" id="qnaModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-lightbulb me-1"></i>Create Q&amp;A Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="qnaForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="qnaTitle" required placeholder="e.g., Open Q&amp;A" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Prompt</label>
                        <textarea class="form-control" id="qnaPrompt" rows="2" placeholder="What would you like to ask the group?"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="qnaDuration" value="10" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Questions Per Participant</label>
                            <input type="number" class="form-control" id="qnaMaxQuestions" value="3" min="1" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Question Length (chars)</label>
                            <input type="number" class="form-control" id="qnaMaxLength" value="300" min="50" max="1000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="qnaAllowAnonymous" checked />
                            <label class="form-check-label" for="qnaAllowAnonymous">Allow anonymous submissions</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="qnaAllowUpvoting" checked />
                            <label class="form-check-label" for="qnaAllowUpvoting">Allow participants to upvote questions</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveQnAActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- Feedback Activity Modal -->
<div class="modal fade" id="feedbackModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-comment me-1"></i>Create General Feedback Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="feedbackForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="feedbackTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Prompt</label>
                        <textarea class="form-control" id="feedbackPrompt" rows="3"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="feedbackDuration" value="5" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Responses Per Participant</label>
                            <input type="number" class="form-control" id="feedbackMaxResponses" value="3" min="1" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveFeedbackActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- AI Summary Activity Modal -->
<div class="modal fade" id="aisummaryModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-brain me-1"></i>Create AI Summary Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info d-flex align-items-start gap-2 mb-3">
                    <i class="fas fa-info-circle mt-1 flex-shrink-0"></i>
                    <div class="small">When this activity is opened, AI will read all completed activities and responses to generate a summary. Participants only read the summary — no input required. This activity is excluded from AI agenda generation.</div>
                </div>
                <form id="aisummaryForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="aisummaryTitle" value="Session Summary" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Subtitle / Prompt (shown to participants)</label>
                        <textarea class="form-control" id="aisummaryPrompt" rows="2" placeholder="Here's what we covered so far..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Additional AI Instructions <span class="text-muted">(optional)</span></label>
                        <textarea class="form-control" id="aisummaryCustomPrompt" rows="2"
                            placeholder="e.g. Focus on action items, use bullet points, highlight consensus..."></textarea>
                        <div class="form-text">This text is sent to the AI to refine the summary.</div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="aisummaryShowBreakdown" checked />
                            <label class="form-check-label" for="aisummaryShowBreakdown">Show activity-by-activity breakdown below the summary</label>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-medium">Display Duration (minutes)</label>
                        <input type="number" class="form-control" id="aisummaryDuration" value="5" min="1" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveAiSummaryActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- 5 Whys Activity Modal -->
<div class="modal fade" id="fivewhysModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-search-location me-1"></i>Create 5 Whys Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info d-flex align-items-start gap-2 mb-3">
                    <i class="fas fa-robot mt-1 flex-shrink-0"></i>
                    <div class="small">
                        <strong>AI-driven root cause analysis.</strong>
                        Each participant answers your initial question, then AI asks personalised follow-up
                        &ldquo;Why?&rdquo; questions, drilling deeper until the root cause is identified.
                    </div>
                </div>
                <form id="fivewhysForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="fivewhysTitle" value="Root Cause Analysis" required
                               placeholder="e.g., Why Did Our Sprint Fail?" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Initial Problem Question *</label>
                        <textarea class="form-control" id="fivewhysRootQuestion" rows="2" required
                                  placeholder="e.g., Why did our last deployment fail?"></textarea>
                        <div class="form-text">This is the first question every participant will answer. Start with &ldquo;Why&hellip;&rdquo; for best results.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Background Context <span class="text-muted">(optional)</span></label>
                        <textarea class="form-control" id="fivewhysContext" rows="2"
                                  placeholder="e.g., We had 3 failed deployments this sprint, causing a 2-hour production outage..."></textarea>
                        <div class="form-text">Helps AI generate more targeted follow-up questions. Not shown to participants.</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Depth (Whys)</label>
                            <select class="form-select" id="fivewhysMaxDepth">
                                <option value="3">3 Levels</option>
                                <option value="4">4 Levels</option>
                                <option value="5" selected>5 Levels (recommended)</option>
                                <option value="7">7 Levels (thorough)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="fivewhysDuration" value="15" min="5" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveFiveWhysActivity()">
                    <i class="fas fa-robot me-1"></i>Create Activity
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Break Activity Modal -->
<div class="modal fade" id="breakModal" tabindex="-1" data-bs-backdrop="static">    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-coffee me-1"></i>Create Break Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-flex align-items-start gap-2 mb-3">
                    <i class="fas fa-clock mt-1 flex-shrink-0"></i>
                    <div class="small">This activity pauses the session for a break. Participants see a countdown timer and can signal when they are back. This activity is excluded from AI agenda generation.</div>
                </div>
                <form id="breakForm">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Activity Title *</label>
                        <input type="text" class="form-control" id="breakTitle" value="Break Time" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Break Message</label>
                        <textarea class="form-control" id="breakMessage" rows="2"
                            placeholder="Take a short break. We'll resume shortly!"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Break Duration (minutes)</label>
                            <input type="number" class="form-control" id="breakDuration" value="15" min="1" max="120" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="breakShowCountdown" checked />
                            <label class="form-check-label" for="breakShowCountdown">Show countdown timer to participants</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="breakAllowReady" checked />
                            <label class="form-check-label" for="breakAllowReady">Allow participants to signal they are back</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveBreakActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<!-- Quadrant Item Scoring Activity Modal -->
<div class="modal fade" id="quadrantModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ics ics-chart-increasing ic-sm ic-mr"></i>Create Item Scoring Activity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body modal-body-scroll">
                <form id="quadrantForm">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label class="form-label fw-medium">Activity Title *</label>
                            <input type="text" class="form-control" id="quadrantTitle" required placeholder="e.g., Prioritise Tech Debt Items" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Duration (minutes)</label>
                            <input type="number" class="form-control" id="quadrantDuration" value="10" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Instructions / Prompt</label>
                        <textarea class="form-control" id="quadrantPrompt" rows="2" placeholder="e.g., Score each item on how complex and how much effort it requires"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">X-Axis Label</label>
                            <input type="text" class="form-control" id="quadrantXAxis" value="Complexity" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Y-Axis Label</label>
                            <input type="text" class="form-control" id="quadrantYAxis" value="Effort" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label fw-medium mb-0">X-Axis Score Options *</label>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','1-10')">1–10</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','1-5')">1–5</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','fibonacci')">Fibonacci</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('x','odd')">Odd</button>
                            </div>
                        </div>
                        <small class="text-muted d-block mb-2">Value is used for averaging. Label &amp; Description are shown to participants in the dropdown.</small>
                        <table class="table table-sm mb-1">
                            <thead><tr><th style="width:20%">Value *</th><th style="width:25%">Label</th><th>Description (optional)</th><th style="width:40px"></th></tr></thead>
                            <tbody id="quadrantXScoreBody"></tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="window.quadrantModal_addRow('x')"><i class="fas fa-plus me-1"></i>Add Option</button>
                    </div>
                    <div class="mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="quadrantYSharesX" checked onchange="window.quadrantModal_toggleYPanel(this.checked)" />
                            <label class="form-check-label" for="quadrantYSharesX">Y-axis uses the same score options as X-axis</label>
                        </div>
                    </div>
                    <div id="quadrantYScorePanel" style="display:none" class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label fw-medium mb-0">Y-Axis Score Options *</label>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','1-10')">1–10</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','1-5')">1–5</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','fibonacci')">Fibonacci</button>
                                <button type="button" class="btn btn-xs btn-outline-secondary" onclick="window.quadrantModal_applyPreset('y','odd')">Odd</button>
                            </div>
                        </div>
                        <table class="table table-sm mb-1">
                            <thead><tr><th style="width:20%">Value *</th><th style="width:25%">Label</th><th>Description (optional)</th><th style="width:40px"></th></tr></thead>
                            <tbody id="quadrantYScoreBody"></tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="window.quadrantModal_addRow('y')"><i class="fas fa-plus me-1"></i>Add Option</button>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-medium mb-0">Items to Score * <span class="text-muted fw-normal">(one per line, max 200)</span></label>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('quadrantCsvUpload').click()">
                                <i class="fas fa-file-import me-1"></i>Import CSV
                            </button>
                        </div>
                        <input type="file" id="quadrantCsvUpload" accept=".csv,.tsv,.txt" class="d-none" />
                        <div id="quadrantCsvColPicker" class="card card-body py-2 mb-2 d-none">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="text-muted small"><i class="fas fa-table-columns me-1"></i>Multiple columns detected. Pick the column to import:</span>
                                <select id="quadrantCsvColSelect" class="form-select form-select-sm" style="width:auto;max-width:220px;"></select>
                                <button type="button" class="btn btn-sm btn-primary" data-csv-apply>Apply</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-csv-cancel>Cancel</button>
                            </div>
                        </div>
                        <textarea class="form-control font-monospace" id="quadrantItems" rows="8" placeholder="Deploy frequency&#10;Incident response time&#10;Code review turnaround&#10;..."></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Bubble Size</label>
                            <select class="form-select" id="quadrantBubbleSize">
                                <option value="0">Proportional to response count</option>
                                <option value="1">Uniform (same size for all)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="quadrantAllowNotes" />
                                <label class="form-check-label" for="quadrantAllowNotes">Allow participants to add a note per item</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="window.saveQuadrantActivity()">Create Activity</button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const modalEl = document.getElementById('quadrantModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            if (!document.getElementById('quadrantXScoreBody').hasChildNodes()) {
                window.quadrantModal_renderScoreTable('x', QuadrantActivity.defaultNumeric(1, 10));
                window.quadrantModal_toggleYPanel(true);
            }
            CsvHelper.wireTextareaPaste('quadrantItems');
            CsvHelper.bindFileUpload({
                fileInputId: 'quadrantCsvUpload',
                textareaId: 'quadrantItems',
                columnPickerId: 'quadrantCsvColPicker',
                columnSelectId: 'quadrantCsvColSelect',
                maxRows: 200
            });
        });
    }
})();
</script>

@code {
    [Parameter]
    public string SessionCode { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback OnActivityCreated { get; set; }
}
