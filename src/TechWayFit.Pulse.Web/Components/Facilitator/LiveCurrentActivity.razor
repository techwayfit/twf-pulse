@using TechWayFit.Pulse.Contracts.Responses
@using TechWayFit.Pulse.Contracts.Enums
@using TechWayFit.Pulse.Web.Components.Dashboards

<div class="live-stage-active">

    <!-- Visualization area -->
    <div class="live-stage-viz">
        @if (Activity.Type == ActivityType.Poll)
        {
            <PollDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.WordCloud)
        {
            <WordCloudDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.Rating)
        {
            <RatingDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.GeneralFeedback)
        {
            <GeneralFeedbackDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.Quadrant)
        {
            <QuadrantDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" ActivityConfig="@Activity.Config" />
        }
        else if (Activity.Type == ActivityType.AiSummary)
        {
            <AiSummaryDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.Break)
        {
            <BreakDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.QnA)
        {
            <QnADashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else if (Activity.Type == ActivityType.FiveWhys)
        {
            <FiveWhysDashboard SessionCode="@SessionCode" ActivityId="@Activity.ActivityId" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                <div class="text-center">
                    <i class="fas fa-chart-bar fa-2x mb-2"></i>
                    <p class="mb-0">Live dashboard for @Activity.Type activities coming soon</p>
                </div>
            </div>
        }
    </div>

    <!-- Stage footer: navigation controls -->
    <div class="live-stage-footer">
        <span class="badge @GetStatusBadgeClass(Activity.Status)" style="font-size: 0.72rem;">@GetStatusLabel(Activity.Status)</span>

        @if (ShowCurrentControls)
        {
            @if (HasPrevious)
            {
                <button class="btn btn-sm btn-outline-secondary" @onclick="OnGoBack" disabled="@IsPerformingAction">
                    <i class="fas fa-arrow-left me-1"></i>
                    <span class="d-none d-sm-inline">@(IsPerformingAction ? "Moving..." : "Back")</span>
                </button>
            }

            <button class="btn btn-sm btn-warning" @onclick="OnClose" disabled="@IsPerformingAction">
                <i class="fas fa-stop me-1"></i>
                <span class="d-none d-sm-inline">@(IsPerformingAction ? "Closing..." : "Close")</span>
            </button>

            @if (HasNext)
            {
                <button class="btn btn-sm btn-primary" @onclick="OnMoveNext" disabled="@IsPerformingAction">
                    <span class="d-none d-sm-inline me-1">@(IsPerformingAction ? "Moving..." : "Next")</span>
                    <i class="fas fa-arrow-right"></i>
                </button>
            }
            else
            {
                <span class="badge bg-info" style="font-size: 0.72rem;">Last Activity</span>
            }
        }
        else if (Activity.Status == ActivityStatus.Closed)
        {
            <button class="btn btn-sm btn-success" @onclick="OnReopen" disabled="@IsPerformingAction">
                <i class="fas fa-redo me-1"></i>
                <span class="d-none d-sm-inline">@(IsPerformingAction ? "Reopening..." : "Reopen")</span>
            </button>
        }
        else if (Activity.Status == ActivityStatus.Pending && CanStart)
        {
            <button class="btn btn-sm btn-primary" @onclick="OnStart" disabled="@IsPerformingAction">
                <i class="fas fa-play me-1"></i>
                <span class="d-none d-sm-inline">@(IsPerformingAction ? "Starting..." : "Start")</span>
            </button>
        }

        <a class="btn btn-sm btn-outline-secondary ms-auto" href="/facilitator/dashboards">
            <i class="fas fa-chart-bar me-1"></i>
            <span class="d-none d-md-inline">All Dashboards</span>
        </a>
    </div>

</div>

<script>
    let timerInterval = null;

    function startActivityTimer() {
        const timerEl = document.getElementById('activity-timer');
        if (!timerEl) return;

        const durationMinutes = parseInt(timerEl.dataset.duration);
        const openedAt = new Date(timerEl.dataset.openedAt);
        const timerText = timerEl.querySelector('.timer-text');

        if (timerInterval) clearInterval(timerInterval);

        function updateTimer() {
            const now = new Date();
            const elapsedSeconds = Math.floor((now - openedAt) / 1000);
            const totalSeconds = durationMinutes * 60;
            const remainingSeconds = Math.max(0, totalSeconds - elapsedSeconds);
            const minutes = Math.floor(remainingSeconds / 60);
            const seconds = remainingSeconds % 60;

            timerText.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;

            if (remainingSeconds === 0) {
                timerEl.classList.add('timer-expired');
                timerEl.classList.remove('timer-warning');
                timerText.textContent = "Time's Up!";
            } else if (remainingSeconds <= 60) {
                timerEl.classList.add('timer-warning');
                timerEl.classList.remove('timer-expired');
            } else {
                timerEl.classList.remove('timer-warning', 'timer-expired');
            }
        }

        updateTimer();
        timerInterval = setInterval(updateTimer, 1000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startActivityTimer);
    } else {
        startActivityTimer();
    }

    let lastTimerElement = document.getElementById('activity-timer');
    const observer = new MutationObserver(() => {
        const current = document.getElementById('activity-timer');
        if (current && !lastTimerElement) startActivityTimer();
        else if (!current && lastTimerElement && timerInterval) {
            clearInterval(timerInterval);
            timerInterval = null;
        }
        lastTimerElement = current;
    });
    observer.observe(document.body, { childList: true, subtree: true });
</script>

@code {
    [Parameter, EditorRequired] public AgendaActivityResponse Activity { get; set; } = default!;
    [Parameter, EditorRequired] public string SessionCode { get; set; } = default!;
    [Parameter] public bool IsPerformingAction { get; set; }
    [Parameter] public bool HasPrevious { get; set; }
    [Parameter] public bool HasNext { get; set; }
    [Parameter] public bool ShowCurrentControls { get; set; }
    [Parameter] public bool CanStart { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnGoBack { get; set; }
    [Parameter] public EventCallback OnMoveNext { get; set; }
    [Parameter] public EventCallback OnStart { get; set; }
    [Parameter] public EventCallback OnReopen { get; set; }

    private static string GetStatusLabel(ActivityStatus status) => status switch
    {
        ActivityStatus.Open => "Active",
        ActivityStatus.Closed => "Completed",
        _ => "Pending"
    };

    private static string GetStatusBadgeClass(ActivityStatus status) => status switch
    {
        ActivityStatus.Open => "bg-success",
        ActivityStatus.Closed => "bg-secondary",
        _ => "bg-warning text-dark"
    };
}
