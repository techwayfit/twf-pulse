@inject IJSRuntime JS

<!-- Joining Information Modal -->
<div class="modal fade" id="qrModal" tabindex="-1" aria-labelledby="qrModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
      <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="qrModalLabel">Joining Information</h5>
  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
  </div>
         <div class="modal-body text-center px-4 pb-4">
  <!-- QR Code -->
         <div class="bg-white border rounded p-3 d-inline-block mb-3">
        <canvas id="qr-modal-@(SessionCode.Replace("-", ""))"
        width="200"
     height="200"></canvas>
       </div>

         <!-- Session Code -->
          <div class="rounded px-3 py-2 mb-3" style="background: linear-gradient(135deg, var(--pulse-teal-dark, #0d6b72), var(--pulse-teal-mid, #0e9e9a));">
    <div class="h4 mb-0 fw-bold text-white" style="font-family: var(--pulse-font-mono, 'DM Mono', monospace); letter-spacing: 0.08em;">@SessionCode</div>
   <small style="color: rgba(255,255,255,0.7);">Session Code</small>
</div>

  <!-- Divider -->
   <div class="text-muted small mb-2">or share this link</div>

        <!-- Join URL -->
          <div class="bg-light rounded p-3 text-break">
            <code class="text-primary user-select-all">@JoinUrl</code>
          </div>
          <small class="text-muted d-block mt-2">Click to select, then copy</small>
  </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string SessionCode { get; set; } = default!;

    [Parameter, EditorRequired]
    public string JoinUrl { get; set; } = default!;

    [Parameter]
    public EventCallback OnCopyUrl { get; set; }
}