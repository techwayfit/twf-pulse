@page
@namespace TechWayFit.Pulse.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var isPresentationRoute = HttpContext.Request.Path.StartsWithSegments("/facilitator/live/presentation");
    Layout = isPresentationRoute ? null : "_Layout";
}

@* Use Server mode without pre-rendering to fix QR code timing issues *@
<component type="typeof(App)" render-mode="Server" />

@if (isPresentationRoute)
{
    <script src="/_framework/blazor.server.js"></script>
    <script src="/js/blazor-reconnect.js" asp-append-version="true"></script>
}
else
{
    @section Scripts {
        <!-- Blazor Server - loads AFTER QR scripts from layout -->
        <script src="/_framework/blazor.server.js"></script>
        <script src="/js/blazor-reconnect.js" asp-append-version="true"></script>
    }
}
