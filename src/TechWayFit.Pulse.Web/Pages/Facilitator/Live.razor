@page "/facilitator/live"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using TechWayFit.Pulse.Contracts.Enums
@using TechWayFit.Pulse.Web.Components.Dashboards
@using TechWayFit.Pulse.Web.Components.Facilitator
@using TechWayFit.Pulse.Web.Components.Shared
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime

@if (isLoading)
{
    <div class="d-flex align-items-center justify-content-center" style="height: calc(100vh - 60px);">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted mb-0">Loading session...</p>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="container container-wide py-4">
        <div class="alert alert-danger">@errorMessage</div>
        <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
}
else if (session != null)
{
    <div class="live-page-shell">

        @* ── Slim top bar ── *@
        <LiveHeader Session="@session"
                    SessionCode="@sessionCode"
                    IsPerformingAction="@isPerformingAction"
                    ParticipantCount="@participantCount"
                    CurrentActivity="@currentActivity"
                    Activities="@activities"
                    IsSidebarCollapsed="@_sidebarCollapsed"
                    OnToggleSidebar="@(() => { _sidebarCollapsed = !_sidebarCollapsed; _sidebarMobileOpen = !_sidebarMobileOpen; })"
                    OnShowQRModal="@ShowQRModal"
                    OnShowEditSession="@ShowEditSessionModal"
                    OnStartSession="@StartSession"
                    OnEndSession="@ShowEndSessionModal" />

        @* ── Two-panel workspace ── *@
        <div class="live-workspace">

            @* Left sidebar: activity queue *@
            <aside class="live-sidebar @(_sidebarCollapsed ? "live-sidebar--collapsed" : "") @(_sidebarMobileOpen ? "live-sidebar--open" : "")">
                <LiveActivitiesList Activities="@activities"
                                    SelectedActivityId="@selectedActivityId"
                                    IsSessionEnded="@(session.Status == SessionStatus.Ended || session.Status == SessionStatus.Expired)"
                                    OnSelectActivity="@SelectActivity"
                                    OnAddActivity="@ShowAddActivityModal"
                                    OnEditActivity="@ShowEditActivityModal"
                                    OnCopyActivity="@CopyActivity" />
            </aside>

            @* Mobile sidebar overlay backdrop *@
            @if (_sidebarMobileOpen)
            {
                <div class="d-lg-none position-fixed top-0 start-0 w-100 h-100"
                     style="background: rgba(0,0,0,0.4); z-index: 199;"
                     @onclick="@(() => _sidebarMobileOpen = false)"></div>
            }

            @* Main stage *@
            <section class="live-stage">
                @{
                    var displayedActivity = GetDisplayedActivity();
                    var showCurrentControls = IsDisplayingCurrentActivity(displayedActivity);
                }

                <div class="live-stage-floating-metrics">
                    @if (session.Status == SessionStatus.Live)
                    {
                        <span class="badge bg-success d-inline-flex align-items-center gap-1 px-2 py-1" style="font-size: 0.72rem;">
                            <span class="pulse-dot"></span>LIVE
                        </span>
                    }

                    <span class="live-response-badge">
                        <i class="fas fa-users"></i> @participantCount Participants
                    </span>

                    @if (currentActivity != null)
                    {
                        <span class="live-response-badge">
                            <i class="fas fa-reply"></i> @GetCurrentActivityResponseCount() / @participantCount
                        </span>

                        @if (currentActivity.DurationMinutes.HasValue && currentActivity.OpenedAt.HasValue)
                        {
                            <div id="activity-timer"
                                 data-duration="@currentActivity.DurationMinutes.Value"
                                 data-opened-at="@currentActivity.OpenedAt.Value.ToString("o")"
                                 class="live-timer-badge">
                                <i class="fas fa-clock"></i>
                                <span class="timer-text">--:--</span>
                            </div>
                        }
                        else if (currentActivity.DurationMinutes.HasValue)
                        {
                            <span class="live-timer-badge" style="background: var(--pulse-gray-200); color: var(--pulse-text-mid); box-shadow: none;">
                                <i class="fas fa-clock"></i> @currentActivity.DurationMinutes&#8202;m
                            </span>
                        }
                        else if (session.Status == SessionStatus.Live)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowSetTimerModal">
                                <i class="fas fa-clock me-1"></i>Set Timer
                            </button>
                        }
                    }
                </div>

                @if (displayedActivity != null)
                {
                    <LiveCurrentActivity Activity="@displayedActivity"
                                         SessionCode="@sessionCode"
                                         IsPerformingAction="@isPerformingAction"
                                         HasPrevious="@HasPreviousActivity()"
                                         HasNext="@HasNextActivity()"
                                         ShowCurrentControls="@showCurrentControls"
                                         CanStart="@(currentActivity == null && displayedActivity.Status == ActivityStatus.Pending && session.Status != SessionStatus.Ended && session.Status != SessionStatus.Expired)"
                                         IsSessionEnded="@(session.Status == SessionStatus.Ended || session.Status == SessionStatus.Expired)"
                                         OnClose="@CloseCurrentActivity"
                                         OnGoBack="@GoBack"
                                         OnMoveNext="@MoveNext"
                                         OnStart="@OpenSelectedActivity"
                                         OnReopen="@ReopenSelectedActivity" />
                }
                else
                {
                    @* Idle state *@
                    <div class="live-stage-idle">
                        <div class="text-center">
                            <div class="mb-3" style="font-size: 3.5rem; color: var(--pulse-gray-300);">
                                <i class="fas fa-play-circle"></i>
                            </div>
                            <h5 class="fw-semibold text-muted mb-1">No activity running</h5>
                            <p class="text-muted small mb-3">Select an activity from the queue on the left to launch it.</p>
                            <button class="btn btn-sm btn-outline-primary d-lg-none" @onclick="@(() => _sidebarMobileOpen = true)">
                                <i class="fas fa-list me-1"></i>View Activities
                            </button>
                        </div>

                        @if (_hasAiInsight)
                        {
                            <div class="card border-0 shadow-sm" style="max-width: 480px; width: 100%;">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <i class="fas fa-robot text-primary"></i>
                                        <strong class="small">AI Insights</strong>
                                        <span class="text-muted small ms-auto">@(_aiInsightTimestamp.ToLocalTime().ToString("HH:mm"))</span>
                                    </div>
                                    @if (_aiInsightJson.ValueKind != System.Text.Json.JsonValueKind.Undefined)
                                    {
                                        @if (_aiInsightJson.TryGetProperty("Analysis", out var analysisEl) && analysisEl.ValueKind == System.Text.Json.JsonValueKind.String)
                                        {
                                            <p class="small mb-1">@analysisEl.GetString()</p>
                                        }
                                        @if (_aiInsightJson.TryGetProperty("FacilitatorPrompt", out var promptEl) && promptEl.ValueKind == System.Text.Json.JsonValueKind.String)
                                        {
                                            <div class="alert alert-info py-1 px-2 small mb-0">
                                                <i class="fas fa-lightbulb me-1"></i>@promptEl.GetString()
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }

                        <button class="btn btn-sm btn-outline-secondary" @onclick="ShowQRModal">
                            <i class="fas fa-qrcode me-1"></i>Show Joining Info
                        </button>
                    </div>
                }
            </section>
        </div>

    </div>

    @* ── Modals (unchanged) ── *@
    <LiveQRModal SessionCode="@sessionCode" JoinUrl="@joinUrl" OnCopyUrl="@CopyJoinUrl" />

    <LiveTimerModal TimerDuration="@timerDurationInput"
                    OnTimerDurationChanged="@((value) => timerDurationInput = value)"
                    OnSetTimer="@SetActivityTimer" />

    <div class="modal fade" id="endSessionModal" tabindex="-1" aria-labelledby="endSessionModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="endSessionModalLabel">End session?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" disabled="@isPerformingAction"></button>
                </div>
                <div class="modal-body">
                    This will end the session for all participants and it cannot be restarted.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" disabled="@isPerformingAction">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmEndSession" disabled="@isPerformingAction">
                        @(isPerformingAction ? "Ending..." : "Yes, End Session")
                    </button>
                </div>
            </div>
        </div>
    </div>

    <EditActivityModal @ref="editActivityModal"
                       SessionCode="@sessionCode"
                       OnActivityUpdated="HandleActivityUpdated"
                       OnActivityDeleted="HandleActivityDeleted" />

    @if (!string.IsNullOrEmpty(activityModalsHtml))
    {
        @((MarkupString)activityModalsHtml)
    }
}

@code {
    // UI-only state for the two-panel layout
    private bool _sidebarCollapsed = false;
    private bool _sidebarMobileOpen = false;
}
