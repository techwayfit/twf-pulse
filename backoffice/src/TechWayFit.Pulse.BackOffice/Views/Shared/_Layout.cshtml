<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "BackOffice") — Pulse Ops</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/css/backoffice-ui.css" />
    <link rel="stylesheet" href="~/css/backoffice-icons.css" />
</head>
<body>

@{
    var activeNav = ViewBag.ActiveNav as string ?? "";
    bool authed = User.Identity?.IsAuthenticated == true;
    bool isSA   = authed && User.IsInRole("SuperAdmin");
    var successMsg = TempData["Success"] as string;
    var errorMsg   = TempData["Error"] as string;
}

@if (authed)
{
    <nav class="bo-nav">
        <a class="bo-nav-logo" asp-controller="Dashboard" asp-action="Index">
            <span class="bo-nav-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 12h4l2-5 4 10 2-5h6" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>Pulse BackOffice
        </a>
        <div class="bo-nav-links">
            <a class="bo-nav-link @(activeNav=="dashboard"?"active":"")" asp-controller="Dashboard" asp-action="Index"><i class="boi boi-sm boi-dashboard boi-mr"></i>Dashboard</a>
            <a class="bo-nav-link @(activeNav=="users"?"active":"")"     asp-controller="Users"     asp-action="Index"><i class="boi boi-sm boi-users boi-mr"></i>Users</a>
            <a class="bo-nav-link @(activeNav=="sessions"?"active":"")" asp-controller="Sessions" asp-action="Index"><i class="boi boi-sm boi-sessions boi-mr"></i>Sessions</a>
            <a class="bo-nav-link @(activeNav=="audit"?"active":"")"    asp-controller="Audit"    asp-action="Index"><i class="boi boi-sm boi-audit boi-mr"></i>Audit Log</a>
            @if (isSA)
            {
                <a class="bo-nav-link @(activeNav=="operators"?"active":"")" asp-controller="BackOfficeUsers" asp-action="Index"><i class="boi boi-sm boi-settings boi-mr"></i>Operators</a>
            }
        </div>
        <div class="bo-nav-right">
            <span class="bo-operator-name">@User.Identity!.Name</span>
            <span class="bo-role-badge @(isSA ? "" : "operator")">@(isSA ? "SuperAdmin" : "Operator")</span>
            <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="bo-logout-btn"><i class="boi boi-xs boi-logout boi-mr"></i>Logout</button>
            </form>
        </div>
    </nav>

    <div class="bo-layout">
        <aside class="bo-sidebar">
            <div class="bo-sidebar-section">Main</div>
            <a class="bo-sidebar-item @(activeNav=="dashboard"?"active":"")" asp-controller="Dashboard" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-dashboard"></i></span> Dashboard</a>
            <a class="bo-sidebar-item @(activeNav=="users"?"active":"")"     asp-controller="Users"     asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-users"></i></span> Users</a>
            <a class="bo-sidebar-item @(activeNav=="sessions"?"active":"")" asp-controller="Sessions" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-sessions"></i></span> Sessions</a>
            @if (isSA)
            {
                <div class="bo-sidebar-section">Commercialization</div>
                <a class="bo-sidebar-item @(activeNav=="plans"?"active":"")" asp-controller="Plans" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-settings"></i></span> Plans</a>
                <a class="bo-sidebar-item @(activeNav=="subscriptions"?"active":"")" asp-controller="Subscriptions" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-users"></i></span> Subscriptions</a>
                <a class="bo-sidebar-item @(activeNav=="activity-types"?"active":"")" asp-controller="ActivityTypes" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-settings"></i></span> Activity Types</a>
                <a class="bo-sidebar-item @(activeNav=="promo-codes"?"active":"")" asp-controller="PromoCodes" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-ticket"></i></span> Promo Codes</a>
            }
            <div class="bo-sidebar-section">Admin</div>
            <a class="bo-sidebar-item @(activeNav=="audit"?"active":"")" asp-controller="Audit" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-audit"></i></span> Audit Log</a>
            @if (isSA)
            {
                <a class="bo-sidebar-item @(activeNav=="operators"?"active":"")" asp-controller="BackOfficeUsers" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-operators"></i></span> Operators</a>
                <a class="bo-sidebar-item @(activeNav=="cache"?"active":"")" asp-controller="Cache" asp-action="Index"><span class="bo-sicon"><i class="boi boi-sm boi-settings"></i></span> Cache</a>
            }
        </aside>
        <main class="bo-main">
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

<div class="bo-toast" id="bo-toast"></div>
<script src="~/js/backoffice-ui.js"></script>
@if (successMsg != null || errorMsg != null)
{
    <script>boInitToasts('@Html.Raw(successMsg?.Replace("'","\\'"))', '@Html.Raw(errorMsg?.Replace("'","\\'"))');</script>
}
</body>
</html>
