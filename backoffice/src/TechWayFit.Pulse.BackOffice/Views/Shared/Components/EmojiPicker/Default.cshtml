@model TechWayFit.Pulse.BackOffice.ViewComponents.EmojiPickerModel
@{
    var modalId   = $"ep-modal-{Model.InputId}";
    var hiddenId  = $"ep-hidden-{Model.InputId}";
    var previewId = $"ep-preview-{Model.InputId}";
    var gridId    = $"ep-grid-{Model.InputId}";

    var groups = new (string Name, string[] Emojis)[]
    {
        ("Workshop",            new[] { "📊","📈","📉","💡","🎯","🗺️","📝","✏️","📌","📋","🗒️","🔖" }),
        ("Retrospective",       new[] { "🔄","⚡","🛑","✅","⚠️","🏃","🚧","🔍","🧐","📡","🩹","💣" }),
        ("Team & People",       new[] { "👥","🤝","👏","🙋","🧑‍💼","👂","💬","🗣️","🤔","💭","🫂","🧑‍🤝‍🧑" }),
        ("Tech & Engineering",  new[] { "💻","🖥️","🔧","⚙️","🐛","🚀","🏗️","📱","🔌","🛠️","🧪","🔬" }),
        ("Planning & Strategy", new[] { "📅","⏱️","🗓️","⌚","⏰","🗂️","🗃️","📆","🔭","🧭","🏁","🎌" }),
        ("Business",            new[] { "💼","🏢","💰","📈","💹","🤑","🪙","🏦","✍️","🖊️","📜","🤝" }),
        ("Awards & Wins",       new[] { "🌟","⭐","🏆","🥇","🎉","🎊","🎖️","🏅","🌈","🎈","🥳","🙌" }),
        ("Incidents & Risk",    new[] { "🔥","💥","🚨","🛡️","🔒","🔑","⛔","🚫","☠️","🩺","🧯","📟" }),
        ("Fun & Icebreakers",   new[] { "🎮","🎲","🧩","⚽","🎸","🎭","🎨","🃏","🏄","🧠","🪩","🎪" }),
        ("Misc",                new[] { "📚","📖","🌱","🌍","☀️","❄️","🦅","🦁","🐝","💎","🧲","🪄" }),
    };
}

<div class="ep-widget">
    <input type="hidden" id="@hiddenId" name="@Model.InputName" value="@Model.CurrentValue" />
    <div style="display:flex;align-items:center;gap:10px">
        <div class="ep-preview" id="@previewId">
            @if (!string.IsNullOrEmpty(Model.CurrentValue))
            {
                @Model.CurrentValue
            }
            else
            {
                <span class="ep-placeholder">—</span>
            }
        </div>
        <button type="button" class="bo-btn bo-btn-ghost bo-btn-sm" onclick="epOpen('@modalId')">
            <i class="boi boi-sm boi-pen boi-mr"></i>Pick Emoji
        </button>
        <button type="button" class="bo-btn bo-btn-ghost bo-btn-sm ep-clear-btn"
                style="color:var(--text-muted);@(string.IsNullOrEmpty(Model.CurrentValue) ? "display:none" : "")"
                onclick="epClear('@hiddenId','@previewId',this)">&#10005; Clear</button>
    </div>
</div>

<div class="bo-modal-overlay" id="@modalId">
    <div class="bo-modal" style="width:540px;max-width:95vw">
        <div class="bo-modal-header">
            <span class="bo-modal-title">Pick an Emoji</span>
            <button type="button" class="bo-modal-close" onclick="boCloseModal('@modalId')">&times;</button>
        </div>
        <input type="text" class="bo-input" style="margin-bottom:14px"
               placeholder="Search emojis…" autocomplete="off"
               oninput="epFilter('@gridId',this.value)" />
        <div id="@gridId" style="max-height:360px;overflow-y:auto;padding-right:4px">
            @foreach (var group in groups)
            {
                <div class="ep-group">
                    <div class="ep-group-label">@group.Name</div>
                    <div class="ep-grid">
                        @foreach (var emoji in group.Emojis)
                        {
                            <button type="button" class="ep-cell" data-emoji="@emoji"
                                    onclick="epSelect('@hiddenId','@previewId','@modalId',this)">@emoji</button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
function epOpen(modalId) {
    boOpenModal(modalId);
    var modal = document.getElementById(modalId);
    if (!modal) return;
    var search = modal.querySelector('input[type=text]');
    if (search) { search.value = ''; epFilter(modal.querySelector('[id^="ep-grid"]')?.id || '', ''); search.focus(); }
}
function epClear(hiddenId, previewId, btn) {
    document.getElementById(hiddenId).value = '';
    var preview = document.getElementById(previewId);
    preview.innerHTML = '<span class="ep-placeholder">\u2014</span>';
    if (btn) btn.style.display = 'none';
}
function epFilter(gridId, query) {
    var container = document.getElementById(gridId);
    if (!container) return;
    var q = (query || '').trim();
    container.querySelectorAll('.ep-group').forEach(function(group) {
        var visible = 0;
        group.querySelectorAll('.ep-cell').forEach(function(cell) {
            var show = !q || cell.dataset.emoji.includes(q);
            cell.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        group.style.display = visible > 0 ? '' : 'none';
    });
}
function epSelect(hiddenId, previewId, modalId, btn) {
    var emoji = btn.dataset.emoji;
    document.getElementById(hiddenId).value = emoji;
    document.getElementById(previewId).textContent = emoji;
    var widget = btn.closest('.bo-modal-overlay')?.previousElementSibling;
    if (widget) {
        var clearBtn = widget.querySelector('.ep-clear-btn');
        if (clearBtn) clearBtn.style.display = '';
    }
    boCloseModal(modalId);
}
</script>
