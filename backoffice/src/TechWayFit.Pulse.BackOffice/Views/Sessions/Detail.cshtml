@model TechWayFit.Pulse.BackOffice.Core.Models.Sessions.SessionDetailViewModel
@using TechWayFit.Pulse.Domain.Enums
@{
    ViewBag.Title = $"Session — {Model.Code}";
    ViewBag.ActiveNav = "sessions";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    var statusPill = Model.Status switch {
        SessionStatus.Live    => "live",
        SessionStatus.Draft   => "draft",
        SessionStatus.Ended   => "closed",
        SessionStatus.Expired => "inactive",
        _                     => "pending"
    };
}

<div class="bo-breadcrumb"><a asp-action="Index">Sessions</a> / @Model.Code</div>

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon green"><i class="boi boi-lg boi-sessions"></i></div>
        <div>
            <div class="bo-page-title">@Model.Code <span style="color:var(--text-muted);font-weight:400">— @Model.Title</span></div>
            <div class="bo-page-sub">
                <span class="bo-pill @statusPill">@Model.Status</span>
                @if (Model.IsAdminLocked) { <span class="bo-pill inactive" style="margin-left:6px">Admin Locked</span> }
            </div>
        </div>
    </div>
    <a asp-action="Index" class="bo-btn bo-btn-ghost bo-btn-sm">&larr; Back</a>
</div>

<div class="bo-stats-row">
    <div class="bo-mini-stat"><div class="val">@Model.ParticipantCount</div><div class="lbl">Participants</div></div>
    <div class="bo-mini-stat"><div class="val">@Model.Activities.Count</div><div class="lbl">Activities</div></div>
    <div class="bo-mini-stat"><div class="val">@Model.Activities.Count(a => a.Status == "Open")</div><div class="lbl">Open</div></div>
    <div class="bo-mini-stat"><div class="val">@Model.ExpiresAt.ToString("dd MMM")</div><div class="lbl">Expires</div></div>
    <div class="bo-mini-stat"><div class="val">@Model.CreatedAt.ToString("dd MMM")</div><div class="lbl">Created</div></div>
</div>

<div class="bo-tab-bar" id="session-tabs">
    <button class="bo-tab active" onclick="boSwitchTab('tab-overview', this)">Overview</button>
    <button class="bo-tab" onclick="boSwitchTab('tab-activities', this)">Activities (@Model.Activities.Count)</button>
    <button class="bo-tab" onclick="boSwitchTab('tab-admin', this)">Admin Actions</button>
</div>

@* ── Overview tab ───────────────────────────────────────────────────────── *@
<div class="bo-tab-pane" id="tab-overview">
    <div class="bo-two-col">
        <div class="bo-card">
            <div class="bo-card-header">Session Details</div>
            <div class="bo-card-body">
                <div class="bo-info-grid cols2">
                    <div class="bo-info-item"><div class="lbl">Code</div><div class="val bo-td-code">@Model.Code</div></div>
                    <div class="bo-info-item"><div class="lbl">Status</div><div class="val"><span class="bo-pill @statusPill">@Model.Status</span></div></div>
                    <div class="bo-info-item"><div class="lbl">Owner</div><div class="val bo-td-mono">@Model.OwnerEmail</div></div>
                    <div class="bo-info-item"><div class="lbl">Goal</div><div class="val">@(Model.Goal ?? "—")</div></div>
                    <div class="bo-info-item"><div class="lbl">Created</div><div class="val bo-td-muted">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC</div></div>
                    <div class="bo-info-item"><div class="lbl">Expires</div><div class="val bo-td-muted">@Model.ExpiresAt.ToString("dd MMM yyyy HH:mm") UTC</div></div>
                    <div class="bo-info-item" style="grid-column:1/-1"><div class="lbl">Internal ID</div><div class="val bo-td-mono" style="font-size:11px">@Model.Id</div></div>
                </div>
            </div>
        </div>

        <div class="bo-card">
            <div class="bo-card-header">Activity Composition</div>
            <div class="bo-card-body">
                @if (!Model.Activities.Any())
                {
                    <p class="bo-td-muted" style="margin:0">No activities.</p>
                }
                else
                {
                    @foreach (var grp in Model.Activities.GroupBy(a => a.Type))
                    {
                        var typeCls = grp.Key.ToLower().Replace("generalfeedback", "feedback").Replace("fivewhys", "fivewhys");
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                            <span class="bo-type-badge @typeCls">@grp.Key</span>
                            <span class="bo-td-muted">&#215;@grp.Count()</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ── Activities tab ─────────────────────────────────────────────────────── *@
<div class="bo-tab-pane" id="tab-activities" style="display:none">
    <div class="bo-card">
        <div class="bo-table-wrap">
            <table class="bo-table">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Opened</th>
                        <th>Closed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Activities)
                    {
                        var actStatusPill = a.Status switch {
                            "Open"   => "open",
                            "Closed" => "closed",
                            _        => "pending"
                        };
                        var typeCls = a.Type.ToLower().Replace("generalfeedback", "feedback").Replace("fivewhys", "fivewhys");
                        <tr>
                            <td class="bo-td-muted">@a.Order</td>
                            <td class="bo-td-primary">
                                <a asp-controller="Activities" asp-action="Detail" asp-route-id="@a.Id" class="bo-link-btn">@a.Title</a>
                            </td>
                            <td><span class="bo-type-badge @typeCls">@a.Type</span></td>
                            <td><span class="bo-pill @actStatusPill">@a.Status</span></td>
                            <td class="bo-td-muted">@(a.OpenedAt?.ToString("HH:mm") ?? "—")</td>
                            <td class="bo-td-muted">@(a.ClosedAt?.ToString("HH:mm") ?? "—")</td>
                            <td>
                                @if (a.Status == "Open")
                                {
                                    <form asp-action="ForceCloseActivity" method="post" style="display:flex;gap:6px;align-items:center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="activityId" value="@a.Id" />
                                        <input type="hidden" name="sessionId" value="@Model.Id" />
                                        <input type="text" name="reason" class="bo-input" placeholder="Reason" required style="width:120px;padding:4px 8px;font-size:12px" />
                                        <button type="submit" class="bo-btn bo-btn-warning bo-btn-sm">Force Close</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Admin Actions tab ───────────────────────────────────────────────────── *@
<div class="bo-tab-pane" id="tab-admin" style="display:none">
    <div class="bo-section-header">Override Actions &mdash; <span style="color:var(--text-muted);font-weight:400">All changes are audited</span></div>
    <div class="bo-actions-grid cols3">

        @* Extend Expiry *@
        <div class="bo-action-card">
            <div class="bo-action-title"><i class="boi boi-sm boi-sessions boi-mr"></i>Extend Expiry</div>
            <div class="bo-action-desc">Add days to the session expiry date.</div>
            <form asp-action="ExtendExpiry" method="post" style="margin-top:12px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label class="bo-field-label">Additional days</label>
                <input type="number" name="additionalDays" class="bo-input" min="1" max="@(isSuperAdmin ? 365 : 30)" value="7" required style="margin-bottom:8px" />
                <label class="bo-field-label">Reason</label>
                <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                <button type="submit" class="bo-btn bo-btn-primary bo-btn-sm">Extend</button>
            </form>
        </div>

        @* Lock / Unlock *@
        <div class="bo-action-card">
            @{ var lockIconCls = Model.IsAdminLocked ? "boi-unlock" : "boi-lock"; }
            <div class="bo-action-title"><i class="boi boi-sm boi-mr @lockIconCls"></i>@(Model.IsAdminLocked ? "Unlock Session" : "Lock Session")</div>
            <div class="bo-action-desc">@(Model.IsAdminLocked ? "Remove admin lock and allow facilitator edits." : "Prevent facilitator from making edits.")</div>
            <form asp-action="SetLock" method="post" style="margin-top:12px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="locked" value="@(!Model.IsAdminLocked)" />
                <label class="bo-field-label">Reason</label>
                <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                <button type="submit" class="bo-btn @(Model.IsAdminLocked ? "bo-btn-success" : "bo-btn-warning") bo-btn-sm">
                    @(Model.IsAdminLocked ? "Unlock" : "Lock")
                </button>
            </form>
        </div>

        @* Force End *@
        @if (Model.Status == SessionStatus.Live)
        {
            <div class="bo-action-card">
                <div class="bo-action-title"><i class="boi boi-sm boi-bolt boi-mr"></i>Force End Session</div>
                <div class="bo-action-desc">Immediately end this live session.</div>
                <form asp-action="ForceEnd" method="post" style="margin-top:12px"
                      onsubmit="return boConfirmAction('Force-end this live session?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="bo-field-label">Reason</label>
                    <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                    <button type="submit" class="bo-btn bo-btn-warning bo-btn-sm">Force End</button>
                </form>
            </div>
        }

        @* Delete (SuperAdmin only) *@
        @if (isSuperAdmin)
        {
            <div class="bo-action-card danger">
                <div class="bo-action-title"><i class="boi boi-sm boi-trash boi-mr"></i>Delete Session <span class="bo-pill locked" style="font-size:10px;padding:2px 7px;vertical-align:middle">SuperAdmin</span></div>
                <div class="bo-action-desc">Permanently delete this session and all its data. This cannot be undone.</div>
                <form asp-action="Delete" method="post" style="margin-top:12px"
                      onsubmit="return boConfirmAction('PERMANENTLY delete this session and all its data?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="bo-field-label">Type session code to confirm</label>
                    <input type="text" name="confirmationCode" class="bo-input" placeholder="@Model.Code" required style="margin-bottom:8px" />
                    <label class="bo-field-label">Reason</label>
                    <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                    <button type="submit" class="bo-btn bo-btn-danger bo-btn-sm">Delete Permanently</button>
                </form>
            </div>
        }
    </div>
