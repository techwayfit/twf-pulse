@model TechWayFit.Pulse.BackOffice.Core.Models.Auth.CreateBackOfficeUserRequest
@{
    ViewBag.Title = "New Operator";
    ViewBag.ActiveNav = "operators";
}

<div class="bo-breadcrumb"><a asp-action="Index">Operators</a> / New</div>

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon purple"><i class="boi boi-lg boi-operators"></i></div>
        <div>
            <div class="bo-page-title">Create Operator Account</div>
            <div class="bo-page-sub">Add a new back-office operator</div>
        </div>
    </div>
    <a asp-action="Index" class="bo-btn bo-btn-ghost bo-btn-sm">&larr; Back</a>
</div>

<div class="bo-card" style="max-width:480px">
    <div class="bo-card-header">Account Details</div>
    <div class="bo-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:14px">
                <label class="bo-field-label">Username</label>
                <input asp-for="Username" class="bo-input" required autocomplete="off" />
            </div>
            <div style="margin-bottom:14px">
                <label class="bo-field-label">Password</label>
                <input asp-for="Password" type="password" class="bo-input" required autocomplete="new-password" />
                <div class="bo-info-note" style="margin-top:4px">Minimum 12 characters recommended.</div>
            </div>
            <div style="margin-bottom:18px">
                <label class="bo-field-label">Role</label>
                <select asp-for="Role" class="bo-select">
                    <option value="Operator">Operator</option>
                    <option value="SuperAdmin">SuperAdmin</option>
                </select>
            </div>
            <button type="submit" class="bo-btn bo-btn-primary bo-btn-block"><i class="boi boi-sm boi-check boi-mr"></i>Create Account</button>
        </form>
    </div>
</div>