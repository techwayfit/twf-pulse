@model TechWayFit.Pulse.BackOffice.Core.Models.Users.UserSearchResult
@{
    ViewBag.Title = "Users";
    ViewBag.ActiveNav = "users";
    var query = ViewBag.Query as TechWayFit.Pulse.BackOffice.Core.Models.Users.UserSearchQuery;
}

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon blue"><i class="boi boi-lg boi-users"></i></div>
        <div>
            <div class="bo-page-title">Facilitator Users</div>
            <div class="bo-page-sub">All registered facilitator accounts</div>
        </div>
    </div>
    <span style="font-size:12px;color:var(--text-muted);font-family:var(--mono);align-self:flex-end">@Model.TotalCount result(s)</span>
</div>

<form method="get" class="bo-search-bar">
    <div class="bo-search-field">
        <label>Email</label>
        <input type="text" name="email" class="bo-input" value="@query?.EmailContains" placeholder="Search by email…" />
    </div>
    <div class="bo-search-field">
        <label>Name</label>
        <input type="text" name="name" class="bo-input" value="@query?.NameContains" placeholder="Search by name…" />
    </div>
    <div class="bo-search-field" style="max-width:140px">
        <label>Status</label>
        <select name="disabled" class="bo-select">
            <option value="">All</option>
            @if (query?.IsDisabled == false)
            {
                <option value="false" selected>Active</option>
                 <option value="true">Disabled</option>
            }
            else
            {
                <option value="true" selected>Disabled</option>
                <option value="false">Active</option>
            }
        </select>
    </div>
    <button type="submit" class="bo-btn bo-btn-primary bo-btn-sm"><i class="boi boi-sm boi-search boi-mr"></i>Search</button>
</form>

<div class="bo-card">
    <div class="bo-table-wrap">
        <table class="bo-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Display Name</th>
                    <th>Status</th>
                    <th>Sessions</th>
                    <th>Created</th>
                    <th>Last Login</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Items)
                {
                    <tr class="clickable" onclick="location.href='@Url.Action("Detail", "Users", new { id = user.Id })'">
                        <td class="bo-td-mono">@user.Email</td>
                        <td class="bo-td-primary">@user.DisplayName</td>
                        <td><span class="bo-pill @(user.IsDisabled ? "inactive" : "active")">@(user.IsDisabled ? "Disabled" : "Active")</span></td>
                        <td class="bo-td-mono">@user.SessionCount</td>
                        <td class="bo-td-muted">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="bo-td-muted">@(user.LastLoginAt?.ToString("dd MMM yyyy") ?? "Never")</td>
                        <td><a class="bo-link-btn" asp-action="Detail" asp-route-id="@user.Id">View &#8594;</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalCount > Model.PageSize)
{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:8px">
        <span style="font-size:12px;color:var(--text-muted);font-family:var(--mono)">Page @Model.Page of @totalPages &mdash; @Model.TotalCount result(s)</span>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
            @for (var p = 1; p <= totalPages; p++)
            {
                <a class="bo-btn @(p == Model.Page ? "bo-btn-primary" : "bo-btn-ghost") bo-btn-sm"
                   asp-action="Index"
                   asp-route-email="@query?.EmailContains"
                   asp-route-name="@query?.NameContains"
                   asp-route-disabled="@query?.IsDisabled"
                   asp-route-page="@p">@p</a>
            }
        </div>
    </div>
}