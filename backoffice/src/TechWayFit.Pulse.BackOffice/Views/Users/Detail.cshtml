@model TechWayFit.Pulse.BackOffice.Core.Models.Users.UserDetailViewModel
@{
    ViewBag.Title = $"User — {Model.Email}";
    ViewBag.ActiveNav = "users";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
}

<div class="bo-breadcrumb"><a asp-action="Index">Users</a> / @Model.Email</div>

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon blue"><i class="boi boi-lg boi-users"></i></div>
        <div>
            <div class="bo-page-title">@Model.DisplayName</div>
            <div class="bo-page-sub">
                <span class="bo-pill @(Model.IsDisabled ? "inactive" : "active")">@(Model.IsDisabled ? "Disabled" : "Active")</span>
            </div>
        </div>
    </div>
    <a asp-action="Index" class="bo-btn bo-btn-ghost bo-btn-sm">&larr; Back</a>
</div>

<div class="bo-card" style="margin-bottom:20px">
    <div class="bo-card-header">Account Details</div>
    <div class="bo-card-body">
        <div class="bo-info-grid cols3">
            <div class="bo-info-item"><div class="lbl">Email</div><div class="val bo-td-mono">@Model.Email</div></div>
            <div class="bo-info-item"><div class="lbl">Display Name</div><div class="val">@Model.DisplayName</div></div>
            <div class="bo-info-item"><div class="lbl">Sessions</div><div class="val bo-td-mono">@Model.SessionCount</div></div>
            <div class="bo-info-item"><div class="lbl">Created</div><div class="val bo-td-muted">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC</div></div>
            <div class="bo-info-item"><div class="lbl">Last Login</div><div class="val bo-td-muted">@(Model.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</div></div>
            @if (Model.IsDisabled)
            {
                <div class="bo-info-item"><div class="lbl">Disabled</div><div class="val bo-td-muted">@Model.DisabledAt?.ToString("dd MMM yyyy") &mdash; @Model.DisabledReason</div></div>
            }
            <div class="bo-info-item" style="grid-column:1/-1"><div class="lbl">ID</div><div class="val bo-td-mono" style="font-size:11px">@Model.Id</div></div>
        </div>
    </div>
</div>

<div class="bo-section-header">Override Actions &mdash; <span style="color:var(--text-muted);font-weight:400">All changes are audited</span></div>
<div class="bo-actions-grid cols2">

    <div class="bo-action-card">
        <div class="bo-action-title"><i class="boi boi-sm boi-pen boi-mr"></i>Update Display Name</div>
        <div class="bo-action-desc">Change the facilitator's display name shown in sessions.</div>
        <form asp-action="UpdateDisplayName" method="post" style="margin-top:12px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <label class="bo-field-label">New Display Name</label>
            <input type="text" name="newDisplayName" class="bo-input" value="@Model.DisplayName" required style="margin-bottom:8px" />
            <label class="bo-field-label">Reason</label>
            <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
            <button type="submit" class="bo-btn bo-btn-warning bo-btn-sm">Update Name</button>
        </form>
    </div>

    <div class="bo-action-card">
        @{ var enaIconCls = Model.IsDisabled ? "boi-check" : "boi-warning"; }
        <div class="bo-action-title"><i class="boi boi-sm boi-mr @enaIconCls"></i>@(Model.IsDisabled ? "Enable Account" : "Disable Account")</div>
        <div class="bo-action-desc">@(Model.IsDisabled ? "Re-enable this facilitator's access." : "Prevent this facilitator from logging in.")</div>
        <form asp-action="SetDisabled" method="post" style="margin-top:12px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="disable" value="@(!Model.IsDisabled)" />
            <label class="bo-field-label">Reason</label>
            <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
            <button type="submit" class="bo-btn @(Model.IsDisabled ? "bo-btn-success" : "bo-btn-warning") bo-btn-sm">
                @(Model.IsDisabled ? "Enable Account" : "Disable Account")
            </button>
        </form>
    </div>

    @if (isSuperAdmin)
    {
        <div class="bo-action-card">
            <div class="bo-action-title">&#64; Update Email <span class="bo-pill locked" style="font-size:10px;padding:2px 7px;vertical-align:middle">SuperAdmin</span></div>
            <div class="bo-action-desc">Change the facilitator's login email address.</div>
            <form asp-action="UpdateEmail" method="post" style="margin-top:12px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label class="bo-field-label">New Email</label>
                <input type="email" name="newEmail" class="bo-input" value="@Model.Email" required style="margin-bottom:8px" />
                <label class="bo-field-label">Reason</label>
                <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                <button type="submit" class="bo-btn bo-btn-warning bo-btn-sm">Update Email</button>
            </form>
        </div>

        <div class="bo-action-card danger">
            <div class="bo-action-title"><i class="boi boi-sm boi-trash boi-mr"></i>Delete Account <span class="bo-pill locked" style="font-size:10px;padding:2px 7px;vertical-align:middle">SuperAdmin</span></div>
            <div class="bo-action-desc">Permanently delete this account and all session data. Cannot be undone.</div>
            <form asp-action="Delete" method="post" style="margin-top:12px"
                  onsubmit="return boConfirmAction('Permanently delete this account and all associated data?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label class="bo-field-label">Type user email to confirm</label>
                <input type="email" name="confirmationEmail" class="bo-input" placeholder="@Model.Email" required style="margin-bottom:8px" />
                <label class="bo-field-label">Reason</label>
                <input type="text" name="reason" class="bo-input" placeholder="Required" required style="margin-bottom:10px" />
                <button type="submit" class="bo-btn bo-btn-danger bo-btn-sm">Delete Permanently</button>
            </form>
        </div>
    }
</div>

@if (Model.UserData.Any())
{
    <div class="bo-card" style="margin-top:20px">
        <div class="bo-card-header">User Data (Settings)</div>
        <div class="bo-table-wrap">
            <table class="bo-table">
                <thead>
                    <tr><th>Key</th><th>Sensitive</th><th>Created</th><th>Updated</th></tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.UserData)
                    {
                        <tr>
                            <td class="bo-td-mono">@d.Key</td>
                            <td class="bo-td-muted">@(d.IsSensitive ? "Yes" : "No")</td>
                            <td class="bo-td-muted">@d.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="bo-td-muted">@d.UpdatedAt.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
