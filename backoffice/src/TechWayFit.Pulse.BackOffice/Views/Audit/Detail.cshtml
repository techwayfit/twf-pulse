@model TechWayFit.Pulse.BackOffice.Core.Models.Audit.AuditLogEntry
@{
    ViewBag.Title = "Audit Record";
    ViewBag.ActiveNav = "audit";
    var actCls = Model.Action?.ToLower() switch {
        var a when a?.Contains("create")  == true => "create",
        var a when a?.Contains("update")  == true => "update",
        var a when a?.Contains("delete")  == true => "delete",
        var a when a?.Contains("disable") == true => "disable",
        _ => ""
    };
}

<div class="bo-breadcrumb"><a asp-action="Index">Audit Log</a> / Record</div>

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon orange"><i class="boi boi-lg boi-audit"></i></div>
        <div>
            <div class="bo-page-title">Audit Record</div>
            <div class="bo-page-sub"><span class="bo-action-tag @actCls">@Model.Action</span></div>
        </div>
    </div>
    <a asp-action="Index" class="bo-btn bo-btn-ghost bo-btn-sm">&larr; Back</a>
</div>

<div class="bo-card">
    <div class="bo-card-header">Event Details</div>
    <div class="bo-card-body">
        <div class="bo-info-grid cols3">
            <div class="bo-info-item"><div class="lbl">Occurred</div><div class="val bo-td-mono">@Model.OccurredAt.ToString("dd MMM yyyy HH:mm:ss") UTC</div></div>
            <div class="bo-info-item"><div class="lbl">Operator</div><div class="val bo-td-mono">@Model.OperatorId</div></div>
            <div class="bo-info-item"><div class="lbl">Role</div><div class="val"><span class="bo-pill @(Model.OperatorRole == "SuperAdmin" ? "superadmin" : "operator")">@Model.OperatorRole</span></div></div>
            <div class="bo-info-item"><div class="lbl">Action</div><div class="val"><span class="bo-action-tag @actCls">@Model.Action</span></div></div>
            <div class="bo-info-item"><div class="lbl">Entity Type</div><div class="val bo-td-muted">@Model.EntityType</div></div>
            <div class="bo-info-item"><div class="lbl">Entity ID</div><div class="val bo-td-mono" style="font-size:11px">@Model.EntityId</div></div>
            <div class="bo-info-item"><div class="lbl">Field</div><div class="val bo-td-muted">@(Model.FieldName ?? "—")</div></div>
            <div class="bo-info-item"><div class="lbl">Reason</div><div class="val">@(Model.Reason ?? "—")</div></div>
            <div class="bo-info-item"><div class="lbl">IP Address</div><div class="val bo-td-mono">@Model.IpAddress</div></div>
            <div class="bo-info-item" style="grid-column:1/-1"><div class="lbl">Record ID</div><div class="val bo-td-mono" style="font-size:11px">@Model.Id</div></div>
        </div>
    </div>
</div>

<div class="bo-two-col" style="margin-top:16px">
    <div class="bo-card">
        <div class="bo-card-header">Old Value</div>
        <div class="bo-card-body">
            <pre class="bo-code-editor" style="height:auto;min-height:80px;padding:12px">@(Model.OldValue ?? "—")</pre>
        </div>
    </div>
    <div class="bo-card">
        <div class="bo-card-header">New Value</div>
        <div class="bo-card-body">
            <pre class="bo-code-editor" style="height:auto;min-height:80px;padding:12px">@(Model.NewValue ?? "—")</pre>
        </div>
    </div>
</div>