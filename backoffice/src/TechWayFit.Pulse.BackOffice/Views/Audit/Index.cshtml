@model TechWayFit.Pulse.BackOffice.Core.Models.Audit.AuditSearchResult
@{
    ViewBag.Title = "Audit Log";
    ViewBag.ActiveNav = "audit";
    var query = ViewBag.Query as TechWayFit.Pulse.BackOffice.Core.Models.Audit.AuditSearchQuery;
}

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon orange"><i class="boi boi-lg boi-audit"></i></div>
        <div>
            <div class="bo-page-title">Audit Log</div>
            <div class="bo-page-sub">All operator actions</div>
        </div>
    </div>
    <div style="display:flex;gap:8px;align-self:flex-end">
        <span style="font-size:12px;color:var(--text-muted);font-family:var(--mono);line-height:32px">@Model.TotalCount record(s)</span>
        <a asp-action="Export"
           asp-route-operatorId="@query?.OperatorId"
           asp-route-entityType="@query?.EntityType"
           asp-route-entityId="@query?.EntityId"
           asp-route-actionFilter="@query?.Action"
           class="bo-btn bo-btn-ghost bo-btn-sm"><i class="boi boi-sm boi-export boi-mr"></i>Export CSV</a>
    </div>
</div>

<form method="get" class="bo-search-bar">
    <div class="bo-search-field">
        <label>Operator ID</label>
        <input type="text" name="operatorId" class="bo-input" value="@query?.OperatorId" placeholder="Username" />
    </div>
    <div class="bo-search-field">
        <label>Entity Type</label>
        <input type="text" name="entityType" class="bo-input" value="@query?.EntityType" placeholder="e.g. Session" />
    </div>
    <div class="bo-search-field">
        <label>Entity ID</label>
        <input type="text" name="entityId" class="bo-input" value="@query?.EntityId" />
    </div>
    <div class="bo-search-field">
        <label>Action</label>
        <input type="text" name="actionFilter" class="bo-input" value="@query?.Action" />
    </div>
    <button type="submit" class="bo-btn bo-btn-primary bo-btn-sm"><i class="boi boi-sm boi-search boi-mr"></i>Search</button>
</form>

<div class="bo-card">
    <div class="bo-table-wrap">
        <table class="bo-table">
            <thead>
                <tr>
                    <th>When (UTC)</th>
                    <th>Operator</th>
                    <th>Role</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Field</th>
                    <th>Reason</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Items)
                {
                    var actCls = e.Action?.ToLower() switch {
                        var a when a?.Contains("create") == true  => "create",
                        var a when a?.Contains("update") == true  => "update",
                        var a when a?.Contains("delete") == true  => "delete",
                        var a when a?.Contains("disable") == true => "disable",
                        _                                          => ""
                    };
                    var rolePill = e.OperatorRole == "SuperAdmin" ? "superadmin" : "operator";
                    <tr class="clickable" onclick="location.href='@Url.Action("Detail", "Audit", new { id = e.Id })'">
                        <td class="bo-td-mono" style="font-size:12px;white-space:nowrap">@e.OccurredAt.ToString("dd MMM HH:mm")</td>
                        <td class="bo-td-mono">@e.OperatorId</td>
                        <td><span class="bo-pill @rolePill">@e.OperatorRole</span></td>
                        <td><span class="bo-action-tag @actCls">@e.Action</span></td>
                        <td class="bo-td-muted" style="font-size:12px">@e.EntityType / <span class="bo-td-code" style="font-size:11px">@(e.EntityId?.Length > 8 ? e.EntityId[..8] + "…" : e.EntityId ?? "—")</span></td>
                        <td class="bo-td-muted">@(e.FieldName ?? "—")</td>
                        <td class="bo-td-muted" style="max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@(e.Reason?.Length > 40 ? e.Reason[..40] + "…" : e.Reason ?? "—")</td>
                        <td><a class="bo-link-btn" asp-action="Detail" asp-route-id="@e.Id">Detail &#8594;</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalCount > Model.PageSize)
{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:8px">
        <span style="font-size:12px;color:var(--text-muted);font-family:var(--mono)">Page @Model.Page of @totalPages &mdash; @Model.TotalCount result(s)</span>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
            @for (var p = 1; p <= totalPages; p++)
            {
                <a class="bo-btn @(p == Model.Page ? "bo-btn-primary" : "bo-btn-ghost") bo-btn-sm"
                   asp-action="Index"
                   asp-route-operatorId="@query?.OperatorId"
                   asp-route-entityType="@query?.EntityType"
                   asp-route-entityId="@query?.EntityId"
                   asp-route-actionFilter="@query?.Action"
                   asp-route-from="@query?.From"
                   asp-route-to="@query?.To"
                   asp-route-page="@p">@p</a>
            }
        </div>
    </div>
}