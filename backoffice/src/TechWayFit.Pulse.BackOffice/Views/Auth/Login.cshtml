@model TechWayFit.Pulse.BackOffice.Core.Models.Auth.LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Operator Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pulse BackOffice — Login</title>
    <link rel="stylesheet" href="~/css/backoffice-ui.css" />
</head>
<body>
<div class="bo-login-wrap">
    <div class="bo-login-card">
        <div class="bo-login-logo">
            <span class="bo-nav-badge" style="width:36px;height:36px;border-radius:9px">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 12h4l2-5 4 10 2-5h6" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            <span class="bo-login-logo-text">Pulse BackOffice</span>
        </div>
        <div class="bo-login-sub">Operator Access Only</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bo-error-msg">@Model.ErrorMessage</div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="bo-form-group" style="margin-bottom:14px">
                <label class="bo-field-label">Username</label>
                <input asp-for="Username" class="bo-input" autocomplete="username" autofocus />
            </div>
            <div class="bo-form-group" style="margin-bottom:20px">
                <label class="bo-field-label">Password</label>
                <input asp-for="Password" type="password" class="bo-input" autocomplete="current-password" />
            </div>

            <button type="submit" class="bo-btn bo-btn-primary bo-btn-block"><i class="boi boi-sm boi-check boi-mr"></i>Sign In</button>
        </form>
    </div>
</div>
</body>
</html>
