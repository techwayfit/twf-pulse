@{
    ViewBag.Title = "Dashboard";
    ViewBag.ActiveNav = "dashboard";
}

<div class="bo-page-header">
    <div class="bo-page-title-row">
        <div class="bo-page-icon blue"><i class="boi boi-lg boi-dashboard"></i></div>
        <div>
            <div class="bo-page-title">Operations Dashboard</div>
            <div class="bo-page-sub">@DateTimeOffset.UtcNow.ToString("dd MMM yyyy HH:mm") UTC</div>
        </div>
    </div>
</div>

<div class="bo-four-col" style="margin-bottom:24px">
    <a class="bo-stat-card clickable" asp-controller="Users" asp-action="Index" style="text-decoration:none">
        <div class="bo-stat-top">
            <div class="bo-stat-icon blue"><i class="boi boi-lg boi-users"></i></div>
            <span class="bo-stat-trend neutral">–</span>
        </div>
        <div class="bo-stat-number">@ViewBag.UserCount</div>
        <div class="bo-stat-label">Facilitator Accounts</div>
        <div class="bo-stat-action">Manage Users →</div>
    </a>
    <a class="bo-stat-card clickable" asp-controller="Sessions" asp-action="Index" style="text-decoration:none">
        <div class="bo-stat-top">
            <div class="bo-stat-icon green"><i class="boi boi-lg boi-sessions"></i></div>
            <span class="bo-stat-trend neutral">–</span>
        </div>
        <div class="bo-stat-number">@ViewBag.SessionCount</div>
        <div class="bo-stat-label">Total Sessions</div>
        <div class="bo-stat-action">Browse Sessions →</div>
    </a>
    <div class="bo-stat-card">
        <div class="bo-stat-top">
            <div class="bo-stat-icon yellow"><i class="boi boi-lg boi-participants"></i></div>
            <span class="bo-stat-trend neutral">–</span>
        </div>
        <div class="bo-stat-number">@ViewBag.ParticipantCount</div>
        <div class="bo-stat-label">Total Participants</div>
        <div class="bo-stat-action" style="color:var(--text-muted)">Across all sessions</div>
    </div>
    <a class="bo-stat-card clickable" asp-controller="Audit" asp-action="Index" style="text-decoration:none">
        <div class="bo-stat-top">
            <div class="bo-stat-icon purple"><i class="boi boi-lg boi-audit"></i></div>
            <span class="bo-stat-trend neutral">–</span>
        </div>
        <div class="bo-stat-number">@ViewBag.AuditLogCount</div>
        <div class="bo-stat-label">Audit Records</div>
        <div class="bo-stat-action">View Audit Log →</div>
    </a>
</div>

<div class="bo-alert-banner">
    <i class="boi boi-md boi-warning" style="flex-shrink:0"></i>
    <div class="bo-alert-text">
        <strong>All actions in this portal are audited.</strong> Every change you make is permanently recorded with your username, IP address, and the reason provided.
    </div>
</div>

<div class="bo-two-col">
    <div class="bo-card">
        <div class="bo-card-header">
            <div class="bo-card-title">Recent Activity</div>
            <a class="bo-link-btn" asp-controller="Audit" asp-action="Index">View all →</a>
        </div>
        @if (ViewBag.RecentAuditEntries is IEnumerable<TechWayFit.Pulse.BackOffice.Core.Models.Audit.AuditLogEntry> entries && entries.Any())
        {
            @foreach (var e in entries)
            {
                <div class="bo-activity-item">
                    <div class="bo-activity-dot blue"></div>
                    <div class="bo-activity-content">
                        <div class="bo-activity-main">@e.Action — @e.EntityType</div>
                        <div class="bo-activity-meta">by @e.OperatorId</div>
                    </div>
                    <div class="bo-activity-time">@e.OccurredAt.ToString("dd MMM, HH:mm")</div>
                </div>
            }
        }
        else
        {
            <div style="padding:20px;font-size:13px;color:var(--text-muted)">No recent activity.</div>
        }
    </div>

    <div style="display:flex;flex-direction:column;gap:12px">
        <div class="bo-card">
            <div class="bo-card-header"><div class="bo-card-title">Session Breakdown</div></div>
            <div class="bo-card-body" style="display:flex;flex-direction:column;gap:10px">
                @{
                    var draft  = ViewBag.SessionDraft  ?? 0;
                    var live   = ViewBag.SessionLive   ?? 0;
                    var closed = ViewBag.SessionClosed ?? 0;
                }
                <div style="display:flex;align-items:center;justify-content:space-between">
                    <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-secondary)"><span style="width:8px;height:8px;border-radius:2px;background:var(--surface-3);display:inline-block"></span>Draft</span>
                    <span style="font-family:var(--mono);font-size:13px;color:var(--text-primary)">@draft</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between">
                    <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-secondary)"><span style="width:8px;height:8px;border-radius:2px;background:var(--accent);display:inline-block"></span>Live</span>
                    <span style="font-family:var(--mono);font-size:13px;color:var(--text-primary)">@live</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between">
                    <span style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-secondary)"><span style="width:8px;height:8px;border-radius:2px;background:var(--text-muted);display:inline-block"></span>Closed</span>
                    <span style="font-family:var(--mono);font-size:13px;color:var(--text-primary)">@closed</span>
                </div>
            </div>
        </div>
    </div>
</div>
