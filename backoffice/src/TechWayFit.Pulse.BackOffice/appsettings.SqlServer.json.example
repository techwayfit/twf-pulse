{
  "ConnectionStrings": {
    "PulseDb": "Server=localhost,1433;Database=pulse;User Id=sa;Password=YourStrong@Password;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Pulse": {
    "DatabaseProvider": "SqlServer"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "BackOffice": {
    "SeedAdminUsername": "admin",
    "SeedAdminPassword": "ChangeMe!123"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5100"
      },
      "Https": {
        "Url": "https://localhost:5101"
      }
    }
  }
}
